---
// Brands.astro - Marcas destacadas del catálogo.
// Muestra un logo (si existe en /images/marcas/<slug>.png) o el nombre de la
// marca como respaldo. Cada marca enlaza a la tienda filtrada por esa marca.
import { products } from '../data/products';

const slugify = (s) =>
	s.normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');

const counts = {};
for (const p of products) counts[p.brand] = (counts[p.brand] || 0) + 1;

const brands = Object.entries(counts)
	.filter(([name]) => name && name.toLowerCase() !== 'genérico' && name.toLowerCase() !== 'generico')
	.sort((a, b) => b[1] - a[1])
	.slice(0, 14)
	.map(([name]) => ({ name, slug: slugify(name) }));
---

<section class="bg-white py-14 border-t border-gray-100">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
		<div class="text-center mb-8">
			<h2 class="text-2xl lg:text-3xl font-bold text-gray-900">Trabajamos con las mejores marcas</h2>
			<p class="mt-2 text-gray-600">Equipos originales con respaldo y garantía.</p>
		</div>
		<div class="grid grid-cols-3 sm:grid-cols-4 lg:grid-cols-7 gap-4">
			{brands.map((b) => (
				<a
					href={`/productos?q=${encodeURIComponent(b.name)}`}
					class="group flex items-center justify-center h-20 rounded-xl border border-gray-200 bg-white hover:border-accent-light hover:shadow-md transition px-3"
					title={`Ver productos ${b.name}`}
				>
					<img
						src={`/images/marcas/${b.slug}.png`}
						alt={b.name}
						class="max-h-10 max-w-full object-contain opacity-80 group-hover:opacity-100 transition"
						loading="lazy"
						onerror="this.style.display='none'; this.nextElementSibling.style.display='block';"
					/>
					<span class="hidden text-sm font-bold text-gray-500 group-hover:text-accent-main text-center uppercase tracking-wide">{b.name}</span>
				</a>
			))}
		</div>
	</div>
</section>
