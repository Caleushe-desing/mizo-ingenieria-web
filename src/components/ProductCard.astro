---
// ProductCard.astro - Tarjeta de producto para la tienda
import { sellingPrice, formatCLP, categories, type Product } from '../data/products';

interface Props {
	product: Product;
}

const { product } = Astro.props;
const price = sellingPrice(product.basePrice);
const catIcon = categories.find((c) => c.id === product.category)?.icon ?? '📦';
const detailUrl = `/productos/${product.id}`;

const lowStock = typeof product.stock === 'number' && product.stock > 0 && product.stock <= 5;
---

<div class="group flex flex-col bg-white rounded-xl border border-gray-200 shadow-sm hover:shadow-lg hover:border-accent-light transition duration-300 overflow-hidden">
	<a href={detailUrl} class="relative flex items-center justify-center h-48 bg-white p-4 border-b border-gray-100">
		<img
			src={product.image}
			alt={product.name}
			class="max-h-40 w-auto object-contain mix-blend-multiply"
			loading="lazy"
			width="300"
			height="300"
			onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
		/>
		<span class="hidden absolute inset-0 items-center justify-center text-6xl bg-accent-soft" aria-hidden="true">{catIcon}</span>
		{product.tag && (
			<span class="absolute top-3 left-3 px-2.5 py-1 text-xs font-bold rounded-full bg-accent-main text-white shadow z-10">
				{product.tag}
			</span>
		)}
		{lowStock && (
			<span class="absolute top-3 right-3 px-2.5 py-1 text-xs font-bold rounded-full bg-amber-500 text-white shadow z-10">
				¡Últimas {product.stock}!
			</span>
		)}
	</a>

	<div class="flex flex-col flex-grow p-5">
		<span class="text-xs font-semibold uppercase tracking-wide text-accent-main mb-1">{product.brand}</span>
		<a href={detailUrl} class="block">
			<h3 class="text-base font-bold text-gray-900 leading-snug mb-2 hover:text-accent-main transition line-clamp-2">{product.name}</h3>
		</a>
		<p class="text-sm text-gray-600 leading-relaxed flex-grow line-clamp-3">{product.description}</p>

		<div class="mt-4 pt-4 border-t border-gray-100">
			<p class="text-2xl font-extrabold text-gray-900">{formatCLP(price)}</p>
			<p class="text-xs text-green-600 font-medium mb-3 flex items-center gap-1">
				<span class="inline-block w-2 h-2 rounded-full bg-green-500"></span>
				Disponible
			</p>
			<div class="flex gap-2">
				<button
					type="button"
					data-add-to-cart
					data-id={product.id}
					data-name={product.name}
					data-price={price}
					data-image={product.image}
					class="flex-grow text-center px-4 py-2.5 rounded-md text-sm font-semibold text-white bg-accent-main hover:bg-accent-hover transition duration-200"
				>
					Agregar al carrito
				</button>
				<a
					href={detailUrl}
					class="flex-shrink-0 inline-flex items-center justify-center px-3 py-2.5 rounded-md text-sm font-semibold text-accent-main border border-accent-main hover:bg-accent-soft transition"
					aria-label={`Ver detalle de ${product.name}`}
				>
					Ver
				</a>
			</div>
		</div>
	</div>
</div>
