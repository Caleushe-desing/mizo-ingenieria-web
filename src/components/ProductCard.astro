---
// ProductCard.astro - Tarjeta de producto para la tienda
import { sellingPrice, formatCLP, categories, type Product } from '../data/products';

interface Props {
	product: Product;
}

const { product } = Astro.props;
const price = sellingPrice(product.basePrice);
const catIcon = categories.find((c) => c.id === product.category)?.icon ?? '📦';
const catLabel = categories.find((c) => c.id === product.category)?.label ?? 'Producto';
const detailUrl = `/productos/detalle?sku=${encodeURIComponent(product.sku || product.id)}`;
const stock = Math.max(0, Number(product.stock) || 0);
const available = product.available !== false && stock > 0;
const publicBrand = product.brand && product.brand.toLowerCase() !== 'mizo' ? product.brand : '';
const lowStock = available && stock <= 5;
const stockLabel = available ? `Stock · ${stock} disp.` : 'Sin Stock';
---

<article class="product-item group flex h-full w-full flex-col overflow-hidden border-y border-gray-100 bg-white shadow-none transition duration-300 hover:border-accent-light sm:rounded-3xl sm:border sm:shadow-sm sm:hover:-translate-y-1 sm:hover:shadow-lg" data-sku={product.sku || ''}>
	<a href={detailUrl} data-astro-reload class="flex flex-1 flex-row text-inherit sm:flex-col" aria-label={`Ver detalle de ${product.name}`}>
		<div class="relative w-32 shrink-0 border-r border-gray-100 bg-gradient-to-b from-gray-50 to-white sm:w-full sm:border-r-0 sm:border-b">
			<div class="flex h-full min-h-36 items-center justify-center p-3 sm:h-52 sm:p-4 md:h-44">
				<img
					src={product.image}
					alt={product.name}
					class="max-h-[120px] w-auto object-contain mix-blend-multiply transition duration-500 group-hover:scale-105 sm:max-h-[175px] md:max-h-[155px]"
					loading="lazy"
					width="240"
					height="240"
					onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
				/>
				<span class="hidden absolute inset-0 items-center justify-center text-4xl bg-accent-soft" aria-hidden="true">{catIcon}</span>
			</div>
			<span class="absolute left-2 top-2 hidden rounded-full bg-emerald-50 px-2 py-0.5 text-[0.58rem] font-black uppercase tracking-wide text-emerald-700 shadow-sm sm:inline-flex">
				Mejor Precio Garantizado
			</span>
			{lowStock && (
				<span class="absolute bottom-2 left-2 rounded-full bg-amber-500 px-2 py-0.5 text-[0.68rem] font-bold text-white shadow">
					Últimas {product.stock}
				</span>
			)}
		</div>

		<div class="flex min-w-0 flex-1 flex-col p-3 sm:p-4 md:pb-3">
			<div class="mb-2 flex items-center justify-between gap-2">
				<span class="truncate rounded-full bg-accent-soft px-2 py-0.5 text-[0.58rem] font-black uppercase tracking-wide text-accent-main">Categoría: {catLabel}</span>
				{product.sku && <span class="max-w-[6rem] truncate font-mono text-[0.65rem] text-gray-400 whitespace-nowrap">{product.sku}</span>}
			</div>
			<h3 class="text-sm font-black leading-snug text-gray-950 transition group-hover:text-accent-main line-clamp-2 sm:min-h-[2.35rem] sm:text-base">{product.name}</h3>
			{publicBrand && <p class="mt-1 text-xs font-semibold uppercase tracking-wide text-gray-500 line-clamp-1 md:text-sm">{publicBrand}</p>}

			<div class="mt-3 rounded-2xl border border-accent-main/15 bg-accent-soft/50 p-3">
				<p class="text-[0.62rem] font-bold uppercase tracking-wide text-gray-400">Precio venta</p>
				<p class="text-lg font-black tracking-tight text-gray-950 md:text-xl">
					<span class="product-price" data-fallback-price={price}>{formatCLP(price)}</span>
				</p>
				<p
					class:list={[
						'product-stock-status mt-1.5 inline-flex items-center gap-1.5 rounded-full px-2 py-0.5 text-[0.68rem] font-black',
						available ? 'bg-green-50 text-green-700' : 'bg-red-50 text-red-700',
					]}
					data-stock-status
				>
					<span
						class:list={[
							'inline-block h-1.5 w-1.5 rounded-full',
							available ? 'bg-green-500' : 'bg-red-500',
						]}
						data-stock-dot
					></span>
					<span data-stock-label>{stockLabel}</span>
				</p>
			</div>
		</div>
	</a>

	<div class="px-3 pb-3 md:px-4 md:pb-4">
		<button
			type="button"
			data-add-to-cart
			data-id={product.sku || product.id}
			data-name={product.name}
			data-price={price}
			data-image={product.image}
			data-qty="1"
			class="add-to-cart-card inline-flex w-full items-center justify-center gap-1.5 rounded-lg bg-accent-main px-3 py-2 text-xs font-black text-white transition hover:bg-accent-hover disabled:cursor-not-allowed disabled:opacity-50"
			disabled={!available}
		>
			<span aria-hidden="true">🛒</span>
			Agregar al Carrito
		</button>
	</div>
</article>

