---
// src/components/WhatsAppButton.astro

// Define tu número de teléfono con código de país (sin +)
// Ejemplo: 56912345678
const phoneNumber = "56994390870"; 

// Define el mensaje inicial que aparecerá en el chat de WhatsApp
const defaultMessage = "Hola Mizo Ingeniería, me interesa saber más sobre sus servicios.";

// Codifica el mensaje para la URL
const encodedMessage = encodeURIComponent(defaultMessage);

// Construye el enlace de WhatsApp
const whatsappLink = `https://wa.me/${phoneNumber}?text=${encodedMessage}`;
---

<a 
    href={whatsappLink}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Contactar a Mizo Ingeniería por WhatsApp"
    class="fixed bottom-6 right-6 z-50 p-4 rounded-full 
           bg-green-500 text-white shadow-lg 
           hover:bg-green-600 transition duration-300 transform hover:scale-105"
>
    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h.01a1 1 0 100-2H10v-3a1 1 0 00-1-1zm6 0a1 1 0 00-1-1h-1a1 1 0 100 2h1a1 1 0 001-1z" clip-rule="evenodd" />
    </svg>
    <style>
        /* Aseguramos que el SVG se vea como el icono de WhatsApp si no tienes el SVG oficial */
        .bg-green-500 {
            background-color: #25D366; /* Color oficial de WhatsApp */
        }
        .hover\:bg-green-600:hover {
            background-color: #128C7E;
        }
    </style>
</a>