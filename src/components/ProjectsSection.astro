---
// ProjectsSection.astro — proyectos cargados desde /api/proyectos.php (admin)
---

<section id="proyectos" class="bg-white py-16">
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<div class="mb-10 max-w-2xl">
			<p class="text-xs font-bold uppercase tracking-[0.2em] text-accent-main">Proyectos</p>
			<h2 class="mt-3 text-3xl font-black text-ink md:text-4xl">Algunos trabajos que hemos desarrollado</h2>
			<p class="mt-4 text-base leading-relaxed text-gray-600">
				Cada instalación es distinta. Estos ejemplos muestran el tipo de recintos y soluciones que entregamos habitualmente.
			</p>
		</div>

		<div id="projects-grid" class="grid gap-5 sm:grid-cols-2"></div>
		<p id="projects-empty" class="hidden text-sm font-semibold text-gray-500">Cargando proyectos…</p>
		<p id="projects-meta" class="mt-5 hidden text-center text-xs font-semibold text-gray-400"></p>
	</div>
</section>

<script is:inline>
	(function () {
		const grid = document.getElementById('projects-grid');
		const empty = document.getElementById('projects-empty');
		const meta = document.getElementById('projects-meta');
		if (!grid || !empty) return;

		function esc(value) {
			return String(value ?? '').replace(/[&<>"']/g, (ch) => ({
				'&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;',
			}[ch]));
		}

		function projectImages(project) {
			const images = Array.isArray(project.images) ? project.images.filter(Boolean) : [];
			if (images.length) return images;
			if (project.image) return [project.image];
			return [];
		}

		function renderImageCarousel(projectId, images, title) {
			if (!images.length) {
				return '<div class="flex h-full w-full items-center justify-center bg-gray-200 text-xs font-semibold uppercase tracking-wide text-gray-500">Sin fotografía</div>';
			}

			if (images.length <= 1) {
				return `<img src="${esc(images[0])}" alt="${esc(title)}" class="h-full w-full object-cover transition duration-500 group-hover:scale-105" loading="lazy" width="1200" height="700" />`;
			}

			const slides = images.map((src, index) => `
				<img
					src="${esc(src)}"
					alt="${esc(title)} — imagen ${index + 1}"
					class="project-slide absolute inset-0 h-full w-full object-cover transition-opacity duration-500 ${index === 0 ? 'opacity-100' : 'opacity-0'}"
					data-project="${esc(projectId)}"
					data-slide="${index}"
					loading="${index === 0 ? 'eager' : 'lazy'}"
					width="1200"
					height="700"
				/>
			`).join('');

			const dots = images.map((_, index) => `
				<button
					type="button"
					class="project-dot h-1.5 rounded-full transition-all ${index === 0 ? 'w-5 bg-brand-orange' : 'w-1.5 bg-white/60'}"
					data-project="${esc(projectId)}"
					data-dot="${index}"
					aria-label="Ver imagen ${index + 1}"
				></button>
			`).join('');

			return `
				<div class="project-carousel relative h-full w-full" data-project="${esc(projectId)}" data-count="${images.length}">
					${slides}
					<div class="absolute bottom-3 right-3 z-10 flex gap-1.5">${dots}</div>
				</div>
			`;
		}

		function bindCarousels() {
			document.querySelectorAll('.project-carousel').forEach((carousel) => {
				const projectId = carousel.getAttribute('data-project') || '';
				const slides = carousel.querySelectorAll('.project-slide');
				const dots = carousel.querySelectorAll('.project-dot');
				if (!slides.length) return;

				let current = 0;
				let timer = null;

				function goTo(index) {
					current = (index + slides.length) % slides.length;
					slides.forEach((slide, i) => {
						slide.classList.toggle('opacity-100', i === current);
						slide.classList.toggle('opacity-0', i !== current);
					});
					dots.forEach((dot, i) => {
						dot.classList.toggle('w-5', i === current);
						dot.classList.toggle('bg-brand-orange', i === current);
						dot.classList.toggle('w-1.5', i !== current);
						dot.classList.toggle('bg-white/60', i !== current);
					});
				}

				function start() {
					stop();
					if (slides.length < 2) return;
					timer = setInterval(() => goTo(current + 1), 4500);
				}

				function stop() {
					if (timer) clearInterval(timer);
					timer = null;
				}

				dots.forEach((dot) => {
					dot.addEventListener('click', (event) => {
						event.preventDefault();
						event.stopPropagation();
						goTo(Number(dot.getAttribute('data-dot') || 0));
						start();
					});
				});

				carousel.addEventListener('mouseenter', stop);
				carousel.addEventListener('mouseleave', start);
				start();
			});
		}

		function renderProjects(projects) {
			if (!projects.length) {
				grid.innerHTML = '';
				empty.classList.remove('hidden');
				empty.textContent = 'Aún no hay proyectos publicados.';
				if (meta) meta.classList.add('hidden');
				return;
			}

			empty.classList.add('hidden');
			grid.innerHTML = projects.map((project) => {
				const images = projectImages(project);
				return `<article class="group overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm">
					<div class="relative h-52 overflow-hidden">
						${renderImageCarousel(project.id || project.title, images, project.title)}
						<div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-ink/80 to-transparent"></div>
						<span class="absolute bottom-4 left-4 rounded-md bg-brand-orange px-2.5 py-1 text-[0.65rem] font-bold uppercase tracking-wide text-white">
							${esc(project.type || 'Proyecto')}
						</span>
					</div>
					<div class="p-5">
						<h3 class="text-lg font-black text-ink">${esc(project.title)}</h3>
						<p class="mt-2 text-sm leading-relaxed text-gray-600">${esc(project.description || project.scope || '')}</p>
					</div>
				</article>`;
			}).join('');

			if (meta) {
				meta.textContent = `${projects.length} proyecto(s) publicado(s)`;
				meta.classList.remove('hidden');
			}

			bindCarousels();
		}

		async function loadProjects() {
			empty.classList.remove('hidden');
			empty.textContent = 'Cargando proyectos…';

			try {
				const response = await fetch('/api/proyectos.php', { headers: { Accept: 'application/json' }, cache: 'no-store' });
				const payload = await response.json();
				if (payload?.ok && Array.isArray(payload.projects)) {
					renderProjects(payload.projects);
					return;
				}
			} catch (error) {
				console.warn('proyectos.php no disponible', error);
			}

			try {
				const fallback = await fetch('/proyectos-default.json', { headers: { Accept: 'application/json' }, cache: 'no-store' });
				const payload = await fallback.json();
				const projects = (payload?.projects || []).filter((project) => project.published !== false);
				renderProjects(projects);
			} catch (error) {
				empty.textContent = 'No se pudieron cargar los proyectos.';
				console.warn('proyectos-default.json no disponible', error);
			}
		}

		document.addEventListener('DOMContentLoaded', loadProjects);
		document.addEventListener('astro:page-load', loadProjects);
	})();
</script>
