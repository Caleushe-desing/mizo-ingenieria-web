---
// Header.astro - Navegación corporativa + canales directos de contacto
const currentPath = Astro.url.pathname;

const navLinks = [
    { title: 'Inicio', url: '/' },
    { title: 'Diagnóstico Técnico', url: '/configurador' },
    { title: 'Soluciones', url: '/servicios' },
    { title: 'Nosotros', url: '/nosotros' },
    { title: 'Contacto', url: '/contacto' },
];

const isActive = (url: string) => {
    const base = url.split('?')[0];
    return currentPath === base || (base !== '/' && currentPath.startsWith(base));
};

const waLink = 'https://wa.me/56994390870?text=Hola%20Mizo,%20quiero%20dise%C3%B1ar%20una%20soluci%C3%B3n%20audiovisual';
const logoSrc = "/mizo-logo.png";
const logoAlt = "Mizo - Sonido, Audiovisual e Instalaciones";
---

<header class="sticky top-0 z-50 shadow-sm">
    <!-- CINTILLO DE POSICIONAMIENTO -->
    <div class="bg-brand-neon text-gray-900">
        <div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8">
            <div class="flex min-h-9 items-center justify-center gap-3 text-center text-xs sm:text-sm font-black uppercase tracking-wide">
                <span class="hidden sm:inline-flex rounded-full bg-white px-2.5 py-0.5 text-[0.65rem] text-brand-neon-dark">Mizo Pro</span>
                <span>Soluciones de Ingeniería Audiovisual Corporativa en todo Chile</span>
            </div>
        </div>
    </div>

    <!-- BANNER PRINCIPAL (fondo blanco) -->
    <div class="bg-white text-gray-900 border-b border-gray-100">
        <div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8">
            <div class="flex items-center gap-3 sm:gap-6 h-16 sm:h-20">
                <a href="/" class="flex-shrink-0 flex items-center">
                    <img src={logoSrc} alt={logoAlt} class="h-11 sm:h-14 w-auto object-contain" width="180" height="60" onerror="this.onerror=null; this.src='/mizo-logo.svg';" />
                </a>

                <div class="hidden flex-grow items-center justify-center gap-4 text-sm font-bold text-gray-700 lg:flex">
                    <a href="tel:+56994390870" class="hover:text-accent-main">+56 9 9439 0870</a>
                    <span class="h-4 w-px bg-gray-200"></span>
                    <a href="mailto:ventas@mizo.cl" class="hover:text-accent-main">ventas@mizo.cl</a>
                </div>

                <div class="flex items-center gap-1 sm:gap-2 ml-auto sm:ml-0">
                    <a
                        href={waLink}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="hidden sm:inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-semibold text-white bg-green-600 hover:bg-green-700 transition"
                    >
                        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.945C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 018.413 3.488 11.82 11.82 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.51 5.26l-.999 3.648 3.929-1.03zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg>
                        WhatsApp
                    </a>

                    <a
                        href="/configurador"
                        class="hidden rounded-full bg-accent-main px-4 py-2 text-sm font-black text-white transition hover:bg-accent-hover sm:inline-flex"
                    >
                        Diagnóstico
                    </a>

                    <button
                        id="mobile-menu-button"
                        type="button"
                        class="md:hidden inline-flex items-center justify-center p-2 rounded-md text-accent-main hover:bg-accent-soft focus:outline-none"
                        aria-controls="mobile-menu"
                        aria-expanded="false"
                    >
                        <span class="sr-only">Abrir menú principal</span>
                        <svg id="icon-menu" class="h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                        </svg>
                        <svg id="icon-close" class="h-6 w-6 hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                    </button>
                </div>
            </div>
            <div class="grid gap-2 pb-3 text-sm font-bold text-gray-700 sm:hidden">
                <a href="tel:+56994390870" class="rounded-full bg-accent-soft px-4 py-2 text-center text-accent-main">+56 9 9439 0870</a>
                <a href="mailto:ventas@mizo.cl" class="rounded-full bg-slate-50 px-4 py-2 text-center">ventas@mizo.cl</a>
            </div>
        </div>
    </div>

    <!-- SUB-BARRA: navegación principal -->
    <div class="hidden md:block bg-accent-dark border-b border-accent-hover">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center h-11">
                <nav class="flex items-center gap-1">
                    {navLinks.map((link) => (
                        <a
                            href={link.url}
                            class:list={[
                                "px-3 py-1.5 rounded-md text-sm font-semibold transition duration-200",
                                {
                                    "bg-white/15 text-white": isActive(link.url),
                                    "text-white/90 hover:bg-white/10 hover:text-white": !isActive(link.url),
                                }
                            ]}
                            aria-current={isActive(link.url) ? "page" : undefined}
                        >
                            {link.title}
                        </a>
                    ))}
                </nav>
            </div>
        </div>
    </div>

    <!-- MENÚ MÓVIL -->
    <div class="md:hidden hidden bg-accent-dark border-t border-accent-hover" id="mobile-menu">
        <div class="px-2 pt-2 pb-3 space-y-1 sm:px-3">
            {navLinks.map((link) => (
                <a
                    href={link.url}
                    class:list={[
                        "block px-3 py-2 rounded-md text-base font-semibold transition duration-200",
                        {
                            "bg-white/15 text-white": isActive(link.url),
                            "text-white/90 hover:text-white hover:bg-white/10": !isActive(link.url),
                        }
                    ]}
                    aria-current={isActive(link.url) ? "page" : undefined}
                >
                    {link.title}
                </a>
            ))}
            <a
                href={waLink}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center justify-center gap-2 w-full text-center mt-3 px-4 py-2.5 text-base font-semibold rounded-md text-white bg-green-600 hover:bg-green-700 transition"
            >
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.945C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 018.413 3.488 11.82 11.82 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24z"/></svg>
                Consultar por WhatsApp
            </a>
            <a
                href="/configurador"
                class="block w-full rounded-md bg-white px-4 py-2.5 text-center text-base font-black text-accent-main transition hover:bg-accent-soft"
            >
                Abrir diagnóstico técnico
            </a>
        </div>
    </div>
</header>

<script is:inline>
    function initMobileMenu() {
        const button = document.getElementById('mobile-menu-button');
        const menu = document.getElementById('mobile-menu');
        const iconMenu = document.getElementById('icon-menu');
        const iconClose = document.getElementById('icon-close');

        if (!button || !menu || !iconMenu || !iconClose) return;

        menu.classList.add('hidden');
        iconMenu.classList.remove('hidden');
        iconClose.classList.add('hidden');
        document.body.classList.remove('overflow-hidden');

        const toggleMenu = () => {
            const wasHidden = menu.classList.toggle('hidden');
            const isNowOpen = !wasHidden;
            iconMenu.classList.toggle('hidden', isNowOpen);
            iconClose.classList.toggle('hidden', !isNowOpen);
            document.body.classList.toggle('overflow-hidden', isNowOpen);
            button.setAttribute('aria-expanded', isNowOpen.toString());
        };

        button.removeEventListener('click', toggleMenu);
        button.addEventListener('click', toggleMenu);

        const closeMenuOnLinkClick = (event) => {
            if (event.target.tagName === 'A') {
                if (!menu.classList.contains('hidden')) {
                    toggleMenu();
                }
            }
        };
        menu.removeEventListener('click', closeMenuOnLinkClick);
        menu.addEventListener('click', closeMenuOnLinkClick);
    }

    document.addEventListener('DOMContentLoaded', initMobileMenu);
    document.addEventListener('astro:page-load', initMobileMenu);
</script>
