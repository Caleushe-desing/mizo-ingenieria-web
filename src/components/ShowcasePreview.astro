---
const FEATURED_COUNT = 9;
---

<section class="bg-slate-50 py-16 border-t border-slate-100">
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
			<div class="max-w-2xl">
				<p class="text-xs font-black uppercase tracking-[0.22em] text-brand-orange">Equipamiento de referencia</p>
				<h2 class="mt-2 text-2xl font-black text-ink sm:text-3xl">Tecnología que integramos en proyectos reales</h2>
				<p class="mt-3 text-sm leading-6 text-gray-600 sm:text-base">
					Equipos que usamos habitualmente en proyectos de sonido y videoproyección.
				</p>
			</div>
			<a href="/productos" class="inline-flex self-start rounded-full border border-accent-main px-5 py-2.5 text-sm font-black text-accent-main transition hover:bg-accent-soft">
				Ver catálogo de productos
			</a>
		</div>
		<div id="showcase-preview-grid" class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3"></div>
		<p id="showcase-preview-meta" class="mt-5 text-center text-xs font-semibold text-slate-400">Selección aleatoria · cambia en cada visita</p>
		<p id="showcase-preview-empty" class="hidden text-sm font-semibold text-slate-500">Cargando equipamiento de referencia…</p>
	</div>
</section>

<script is:inline define:vars={{ featuredCount: FEATURED_COUNT }}>
	(function () {
		const grid = document.getElementById('showcase-preview-grid');
		const empty = document.getElementById('showcase-preview-empty');
		if (!grid || !empty) return;

		function esc(value) {
			return String(value ?? '').replace(/[&<>"']/g, (ch) => ({
				'&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;',
			}[ch]));
		}

		function shuffle(list) {
			const copy = list.slice();
			for (let i = copy.length - 1; i > 0; i -= 1) {
				const j = Math.floor(Math.random() * (i + 1));
				[copy[i], copy[j]] = [copy[j], copy[i]];
			}
			return copy;
		}

		function normalizeProduct(raw) {
			return {
				id: raw.id || '',
				sku: raw.sku || '',
				name: raw.name || '',
				brand: raw.brand || '',
				category: raw.category || '',
				categoryLabel: raw.categoryLabel || raw.category || '',
				description: raw.description || '',
				image: raw.image || '',
				sourceImage: raw.sourceImage || raw.source?.image || '',
			};
		}

		function hasImage(product) {
			return Boolean(product.image || product.sourceImage);
		}

		async function readJsonResponse(response) {
			const text = await response.text();
			if (!text || !text.trim()) throw new Error('Respuesta vacía');
			return JSON.parse(text);
		}

		async function loadProducts() {
			try {
				const response = await fetch('/api/showcase.php', { headers: { Accept: 'application/json' }, cache: 'no-store' });
				const payload = await readJsonResponse(response);
				if (payload?.ok && Array.isArray(payload.products) && payload.products.length) {
					return payload.products;
				}
			} catch (error) {
				console.warn('showcase.php no disponible', error);
			}
			const response = await fetch('/catalogo-productos.json', { headers: { Accept: 'application/json' }, cache: 'no-store' });
			const payload = await readJsonResponse(response);
			if (!Array.isArray(payload)) return [];
			return payload.map(normalizeProduct).filter(hasImage);
		}

		function card(product) {
			const brand = product.brand && product.brand.toLowerCase() !== 'mizo' ? product.brand : '';
			const detailUrl = '/productos/' + encodeURIComponent(product.id || '');
			const imgSrc = product.image || product.sourceImage || '/mizo-logo.png';
			const imgFallback = product.sourceImage && product.sourceImage !== imgSrc ? product.sourceImage : '/mizo-logo.png';
			return `<article class="overflow-hidden rounded-[1.5rem] border border-slate-200 bg-white shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
				<a href="${detailUrl}" class="block">
				<div class="flex h-40 items-center justify-center bg-slate-50 p-4">
					<img src="${esc(imgSrc)}" data-fallback="${esc(imgFallback)}" alt="${esc(product.name)}" class="max-h-full w-auto max-w-full object-contain" loading="lazy" referrerpolicy="no-referrer" onerror="if(this.dataset.fallback&&!this.dataset.tried){this.dataset.tried='1';this.src=this.dataset.fallback}else{this.onerror=null;this.src='/mizo-logo.png';}" />
				</div>
				</a>
				<div class="p-5">
					${brand ? `<p class="text-[0.65rem] font-black uppercase tracking-[0.18em] text-brand-orange">${esc(brand)}</p>` : ''}
					<h3 class="mt-1 text-sm font-black leading-snug text-ink line-clamp-2"><a href="${detailUrl}">${esc(product.name)}</a></h3>
					${product.description ? `<p class="mt-2 text-xs leading-5 text-slate-600 line-clamp-2">${esc(product.description)}</p>` : ''}
					<a href="${detailUrl}" class="mt-4 inline-flex rounded-full bg-accent-main px-4 py-2 text-[0.68rem] font-black text-white transition hover:bg-accent-hover">Ver producto</a>
				</div>
			</article>`;
		}

		loadProducts()
			.then((products) => {
				empty.classList.add('hidden');
				const picked = shuffle(products.filter(hasImage)).slice(0, featuredCount);
				if (!picked.length) {
					grid.innerHTML = '';
					empty.textContent = 'Equipamiento de referencia disponible en /equipamiento';
					empty.classList.remove('hidden');
					return;
				}
				grid.innerHTML = picked.map(card).join('');
			})
			.catch(() => {
				empty.textContent = 'Equipamiento de referencia disponible en /equipamiento';
				empty.classList.remove('hidden');
			});
	})();
</script>
