---
---

<section class="bg-slate-50 py-16 border-t border-slate-100">
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
			<div class="max-w-2xl">
				<p class="text-xs font-black uppercase tracking-[0.22em] text-brand-orange">Equipamiento de referencia</p>
				<h2 class="mt-2 text-2xl font-black text-ink sm:text-3xl">Tecnología que integramos en proyectos reales</h2>
				<p class="mt-3 text-sm leading-6 text-slate-600 sm:text-base">
					Una selección editorial de equipos profesionales. Sin precios ni stock: el foco es mostrar con qué marcas y soluciones trabaja Mizo.
				</p>
			</div>
			<a href="/equipamiento" class="inline-flex self-start rounded-full border border-accent-main px-5 py-2.5 text-sm font-black text-accent-main transition hover:bg-accent-soft">
				Ver vitrina completa
			</a>
		</div>
		<div id="showcase-preview-grid" class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3"></div>
		<p id="showcase-preview-empty" class="hidden text-sm font-semibold text-slate-500">Cargando equipamiento de referencia…</p>
	</div>
</section>

<script is:inline>
	(function () {
		const grid = document.getElementById('showcase-preview-grid');
		const empty = document.getElementById('showcase-preview-empty');
		if (!grid || !empty) return;

		function esc(value) {
			return String(value ?? '').replace(/[&<>"']/g, (ch) => ({
				'&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;',
			}[ch]));
		}

		function card(product) {
			const brand = product.brand && product.brand.toLowerCase() !== 'mizo' ? product.brand : '';
			return `<article class="overflow-hidden rounded-[1.5rem] border border-slate-200 bg-white shadow-sm">
				<div class="flex h-40 items-center justify-center bg-gradient-to-b from-slate-50 to-white p-4">
					<img src="${esc(product.image || '/mizo-logo.png')}" alt="${esc(product.name)}" class="max-h-full w-auto object-contain mix-blend-multiply" loading="lazy" onerror="this.onerror=null;this.src='/mizo-logo.png';" />
				</div>
				<div class="p-5">
					${brand ? `<p class="text-[0.65rem] font-black uppercase tracking-[0.18em] text-brand-orange">${esc(brand)}</p>` : ''}
					<h3 class="mt-1 text-sm font-black leading-snug text-ink line-clamp-2">${esc(product.name)}</h3>
					${product.description ? `<p class="mt-2 text-xs leading-5 text-slate-600 line-clamp-2">${esc(product.description)}</p>` : ''}
					<a href="/configurador?ref=${encodeURIComponent(product.sku || product.id || '')}" class="mt-4 inline-flex rounded-full bg-accent-main px-4 py-2 text-[0.68rem] font-black text-white transition hover:bg-accent-hover">Dimensionar proyecto</a>
				</div>
			</article>`;
		}

		fetch('/api/showcase.php', { headers: { Accept: 'application/json' }, cache: 'no-store' })
			.then((response) => response.json())
			.then((payload) => {
				const items = Array.isArray(payload?.products) ? payload.products.slice(0, 6) : [];
				empty.classList.add('hidden');
				if (!items.length) {
					grid.innerHTML = '';
					empty.textContent = 'La vitrina se configurará desde el panel de administración.';
					empty.classList.remove('hidden');
					return;
				}
				grid.innerHTML = items.map(card).join('');
			})
			.catch(() => {
				empty.textContent = 'Equipamiento de referencia disponible en /equipamiento';
				empty.classList.remove('hidden');
			});
	})();
</script>
