---
// PageHero.astro - Banner de sección unificado: imagen sobre fondo oscuro (ink),
// degradados elegantes, tipografía ordenada y acento naranja del logo.
interface Props {
	title: string;
	eyebrow?: string;
	subtitle?: string;
	image?: string;
	align?: 'left' | 'center';
	size?: 'sm' | 'md' | 'lg';
	chips?: string[];
	meta?: string;
}

const {
	title,
	eyebrow,
	subtitle,
	image = 'https://images.unsplash.com/photo-1516321318423-f06f85e504b3?auto=format&fit=crop&w=1600&q=80',
	align = 'left',
	size = 'md',
	chips = [],
	meta,
} = Astro.props;

const padding =
	size === 'sm'
		? 'py-14 sm:py-20'
		: size === 'lg'
			? 'py-24 sm:py-32'
			: 'py-20 sm:py-28';

const isCenter = align === 'center';
const wrapper = isCenter
	? 'mx-auto max-w-3xl items-center text-center'
	: 'max-w-3xl items-start text-left';
const overlay = isCenter
	? 'bg-gradient-to-b from-ink/55 via-ink/40 to-ink/70'
	: 'bg-gradient-to-r from-ink/60 via-ink/45 to-ink/25';
---

<section class="relative isolate overflow-hidden bg-ink text-white">
	<img
		src={image}
		alt=""
		aria-hidden="true"
		class="absolute inset-0 h-full w-full object-cover"
		loading="eager"
		width="1600"
		height="900"
	/>
	<div class={`absolute inset-0 ${overlay}`}></div>
	<div class="absolute inset-0 bg-gradient-to-t from-ink/45 via-transparent to-transparent"></div>
	<div
		class="absolute inset-0 opacity-[0.12]"
		style="background-image: radial-gradient(#1c9bd8 1px, transparent 1px); background-size: 26px 26px;"
	>
	</div>
	<div class="pointer-events-none absolute -right-24 -top-24 h-72 w-72 rounded-full bg-accent-main/25 blur-3xl"></div>
	<div class="pointer-events-none absolute -bottom-24 -left-16 h-64 w-64 rounded-full bg-brand-orange/15 blur-3xl"></div>

	<div class={`relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 ${padding}`}>
		<div class={`flex flex-col gap-5 ${wrapper}`}>
			{eyebrow && (
				<span class="inline-flex items-center gap-2 rounded-full border border-brand-orange/40 bg-brand-orange/10 px-4 py-1.5 text-[0.7rem] font-black uppercase tracking-[0.22em] text-brand-orange backdrop-blur">
					<span class="h-1.5 w-1.5 rounded-full bg-brand-orange"></span>
					{eyebrow}
				</span>
			)}

			<h1 class="text-balance text-3xl font-black leading-[1.1] tracking-tight text-white sm:text-4xl lg:text-5xl">
				{title}
			</h1>

			{subtitle && (
				<p class="max-w-2xl text-pretty text-base leading-relaxed text-white/70 sm:text-lg">
					{subtitle}
				</p>
			)}

			{chips.length > 0 && (
				<div class={`flex flex-wrap gap-2.5 ${isCenter ? 'justify-center' : ''}`}>
					{chips.map((chip) => (
						<span class="rounded-full border border-white/15 bg-white/5 px-3.5 py-1.5 text-xs font-bold text-white/80 backdrop-blur">
							{chip}
						</span>
					))}
				</div>
			)}

			{meta && <p class="text-sm font-semibold text-white/55">{meta}</p>}

			<slot />
		</div>
	</div>
</section>
