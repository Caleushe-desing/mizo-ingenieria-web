---
// Card.astro - Tarjeta de servicio (tema claro)
interface Props {
	title: string;
	description: string;
    icon: string;
    href?: string;
}

const { title, description, icon, href = "/servicios" } = Astro.props;
---

<a href={href} class="group block h-full">
    <div class="bg-white h-full p-7 rounded-xl border border-gray-200 shadow-sm hover:shadow-lg hover:border-accent-light transition duration-300">
        
        <div class="text-4xl mb-4 inline-flex h-14 w-14 items-center justify-center rounded-lg bg-accent-soft">
            {icon}
        </div>
        
        <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-accent-main transition duration-300">
            {title}
        </h3>
        
        <p class="text-gray-600 text-base leading-relaxed">
            {description}
        </p>

        <span class="mt-4 inline-flex items-center text-sm font-semibold text-accent-main">
            Ver más
            <svg class="w-4 h-4 ml-1 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
        </span>
    </div>
</a>
