---
interface Props {
	product: {
		id: string;
		sku?: string;
		name: string;
		brand?: string;
		categoryLabel?: string;
		engineeringCategory?: string;
		description?: string;
		image?: string;
		sourceImage?: string;
		note?: string;
	};
	compact?: boolean;
}

const { product, compact = false } = Astro.props;
const brand = product.brand && product.brand.toLowerCase() !== 'mizo' ? product.brand : '';
const detailUrl = `/productos/${product.id}`;
const configUrl = `/configurador?ref=${encodeURIComponent(product.sku || product.id)}`;
---

<article class="showcase-card group flex h-full flex-col overflow-hidden rounded-[1.5rem] border border-slate-200 bg-white shadow-sm transition hover:-translate-y-0.5 hover:border-accent-main/40 hover:shadow-lg">
	<a href={detailUrl} class="relative block overflow-hidden bg-gradient-to-b from-slate-50 to-white">
		<div class:list={['flex items-center justify-center bg-slate-50 p-5', compact ? 'h-40' : 'h-48 sm:h-52']}>
			<img
				src={product.image || product.sourceImage || '/mizo-logo.png'}
				alt={product.name}
				class="max-h-full w-auto max-w-full object-contain transition duration-500 group-hover:scale-105"
				loading="lazy"
				width="240"
				height="240"
				referrerpolicy="no-referrer"
				onerror="if(this.dataset.fallback&&!this.dataset.tried){this.dataset.tried='1';this.src=this.dataset.fallback}else{this.onerror=null;this.src='/mizo-logo.png';}"
				data-fallback={product.sourceImage && product.sourceImage !== product.image ? product.sourceImage : '/mizo-logo.png'}
			/>
		</div>
		{product.categoryLabel && (
			<span class="absolute left-3 top-3 rounded-full border border-accent-main/20 bg-white/90 px-2.5 py-1 text-[0.62rem] font-black uppercase tracking-[0.16em] text-accent-main backdrop-blur">
				{product.categoryLabel}
			</span>
		)}
	</a>

	<div class="flex flex-1 flex-col p-5">
		{brand && (
			<p class="text-[0.68rem] font-black uppercase tracking-[0.18em] text-brand-orange">{brand}</p>
		)}
		<h3 class="mt-1 text-base font-black leading-snug text-ink transition group-hover:text-accent-main line-clamp-2">
			<a href={detailUrl}>{product.name}</a>
		</h3>
		{product.note && (
			<p class="mt-2 rounded-xl border border-brand-orange/20 bg-brand-orange-soft/60 px-3 py-2 text-xs font-semibold leading-5 text-brand-orange-dark">
				{product.note}
			</p>
		)}
		{product.description && (
			<p class="mt-3 flex-1 text-sm leading-6 text-slate-600 line-clamp-3">{product.description}</p>
		)}
		{product.engineeringCategory && !compact && (
			<p class="mt-3 text-xs font-semibold uppercase tracking-wide text-slate-400">{product.engineeringCategory}</p>
		)}

		<div class="mt-5 grid gap-2 sm:grid-cols-2">
			<a
				href={configUrl}
				class="inline-flex items-center justify-center rounded-full bg-accent-main px-4 py-2.5 text-xs font-black text-white transition hover:bg-accent-hover"
			>
				Dimensionar proyecto
			</a>
			<a
				href={detailUrl}
				class="inline-flex items-center justify-center rounded-full border border-slate-200 px-4 py-2.5 text-xs font-black text-slate-700 transition hover:border-accent-main hover:text-accent-main"
			>
				Ver producto
			</a>
		</div>
	</div>
</article>
