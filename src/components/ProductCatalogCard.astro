---
import type { CatalogProduct } from '../lib/catalog';

interface Props {
	product: CatalogProduct;
	compact?: boolean;
}

const { product, compact = false } = Astro.props;
const brand = product.brand && product.brand.toLowerCase() !== 'mizo' ? product.brand : '';
const detailUrl = `/productos/${product.id}`;
const imgSrc = product.image || product.sourceImage || '/mizo-logo.png';
const imgFallback =
	product.sourceImage && product.sourceImage !== imgSrc ? product.sourceImage : '/mizo-logo.png';
---

<article class="product-card group flex h-full flex-col overflow-hidden rounded-[1.5rem] border border-slate-200 bg-white shadow-sm transition hover:-translate-y-0.5 hover:border-accent-main/40 hover:shadow-lg">
	<a href={detailUrl} class="relative block overflow-hidden bg-slate-50">
		<div class:list={['flex items-center justify-center p-5', compact ? 'h-40' : 'h-48 sm:h-52']}>
			<img
				src={imgSrc}
				alt={product.name}
				class="max-h-full w-auto max-w-full object-contain transition duration-500 group-hover:scale-105"
				loading="lazy"
				width="240"
				height="240"
				referrerpolicy="no-referrer"
				data-fallback={imgFallback}
				onerror="if(this.dataset.fallback&&!this.dataset.tried){this.dataset.tried='1';this.src=this.dataset.fallback}else{this.onerror=null;this.src='/mizo-logo.png';}"
			/>
		</div>
		{product.categoryLabel && (
			<span class="absolute left-3 top-3 rounded-full border border-accent-main/20 bg-white/90 px-2.5 py-1 text-[0.62rem] font-black uppercase tracking-[0.16em] text-accent-main backdrop-blur">
				{product.categoryLabel}
			</span>
		)}
	</a>

	<div class="flex flex-1 flex-col p-5">
		{brand && (
			<p class="text-[0.68rem] font-black uppercase tracking-[0.18em] text-brand-orange">{brand}</p>
		)}
		<h3 class="mt-1 text-base font-black leading-snug text-ink transition group-hover:text-accent-main line-clamp-2">
			<a href={detailUrl}>{product.name}</a>
		</h3>
		{product.description && (
			<p class="mt-3 flex-1 text-sm leading-6 text-slate-600 line-clamp-3">{product.description}</p>
		)}
		<a
			href={detailUrl}
			class="mt-5 inline-flex items-center justify-center rounded-full bg-accent-main px-4 py-2.5 text-xs font-black text-white transition hover:bg-accent-hover"
		>
			Ver producto
		</a>
	</div>
</article>
