---
// SectionCTA.astro - Llamada a la acción (banda azul con texto blanco)
interface Props {
    title: string;
    subtitle: string;
    buttonText: string;
    buttonLink: string;
}

const { title, subtitle, buttonText, buttonLink } = Astro.props;
---

<section class="bg-charcoal py-16 sm:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-3xl sm:text-4xl font-black text-white mb-4">
            {title}
        </h2>
        <p class="text-lg sm:text-xl text-gray-400 max-w-3xl mx-auto mb-10">
            {subtitle}
        </p>
        <a 
            href={buttonLink}
            class="inline-block px-10 py-4 text-lg font-bold rounded-md transition duration-300 bg-brand-orange text-white hover:bg-brand-orange-hover"
        >
            {buttonText}
        </a>
    </div>
</section>
