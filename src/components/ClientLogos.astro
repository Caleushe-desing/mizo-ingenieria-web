---
// ClientLogos.astro - Hilera de logos de clientes (tema claro)
const clients = [
    { name: "Cliente A", logo: "/images/clientes/cliente_a.png" }, 
    { name: "Cliente B", logo: "/images/clientes/cliente_b.png" }, 
    { name: "Cliente C", logo: "/images/clientes/cliente_c.png" }, 
    { name: "Cliente D", logo: "/images/clientes/cliente_d.png" }, 
    { name: "Cliente E", logo: "/images/clientes/cliente_e.png" }, 
    { name: "Cliente F", logo: "/images/clientes/cliente_f.png" }, 
    { name: "Cliente G", logo: "/images/clientes/cliente_g.png" }, 
];
---

<section class="bg-white py-16 border-t border-gray-100"> 
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

        <div class="text-center">
            <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-2"> 
                Confían en Mizo 
            </h2>
            <p class="text-gray-500 mb-10">Empresas y hogares que ya disfrutan de nuestras instalaciones.</p>
            
            <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-6 items-center justify-center">
                {clients.map((client) => (
                    <div class="bg-white p-4 rounded-lg border border-gray-200 shadow-sm flex justify-center items-center h-24 transition duration-300 hover:shadow-md hover:border-accent-light">
                        <img 
                            src={client.logo} 
                            alt={`Logo de ${client.name}`} 
                            class="max-h-14 w-auto object-contain opacity-80" 
                            loading="lazy"
                        />
                    </div>
                ))}
            </div>
        </div>
        
    </div>
</section>
