---
// Layout.astro (INTEGRACIÓN MINIMALISTA Y FINAL)
import { ViewTransitions } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro'; // <--- 1. IMPORTACIÓN AÑADIDA
import '../styles/global.css';

interface Props {
    title: string;
    description: string;
    noindex?: boolean;
    // Propiedades para SEO avanzado
    ogTitle?: string;
    ogDescription?: string;
    ogImage?: string;
}

const { 
    title, 
    description,
	noindex = false,
    ogTitle = title, 
    ogDescription = description, 
    ogImage = '/mizo-social-preview.jpg' // Imagen social por defecto
} = Astro.props;

// URL base para Open Graph
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="es" class="scroll-smooth">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        
        <link rel="icon" type="image/png" href="/favicon.png" />
        
        <meta name="generator" content={Astro.generator} />
        
        <link rel="canonical" href={canonicalURL} />
        
        <title>{title}</title>
        <meta name="description" content={description} />
        <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />

        <meta property="og:title" content={ogTitle} />
        <meta property="og:description" content={ogDescription} />
        <meta property="og:type" content="website" />
        <meta property="og:url" content={canonicalURL} />
        <meta property="og:image" content={new URL(ogImage, Astro.site).href} />
        <meta property="og:site_name" content="Mizo Ingeniería" />

        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:site" content="@mizo-ing" /> 
 <meta name="twitter:creator" content="@mizo-ing" />
 <meta name="twitter:title" content={ogTitle} />
 <meta name="twitter:description" content={ogDescription} />
 <meta name="twitter:image" content={new URL(ogImage, Astro.site).href} />

 <ViewTransitions />
 </head>
 <body class="bg-white text-gray-900 min-h-screen flex flex-col">
<Header />
 <main class="flex-grow w-full"> 
 <slot />
 </main>
 
<Footer />
        <WhatsAppButton />

        <script is:inline>
            (function () {
                const KEY = 'mizo-cart';
                const read = () => {
                    try { return JSON.parse(localStorage.getItem(KEY)) || []; } catch (e) { return []; }
                };
                const write = (items) => {
                    localStorage.setItem(KEY, JSON.stringify(items));
                    // Solo invalida la cotización; los datos de despacho del cliente se conservan.
                    localStorage.removeItem('mizo-ship-quote');
                    updateBadge();
                    document.dispatchEvent(new CustomEvent('cart:updated'));
                };
                const Cart = {
                    items: read,
                    count: () => read().reduce((n, i) => n + i.qty, 0),
                    subtotal: () => read().reduce((n, i) => n + i.price * i.qty, 0),
                    weight: () => read().reduce((n, i) => n + (Number(i.weight) || 0) * i.qty, 0),
                    add(p, qty) {
                        qty = qty || 1;
                        const items = read();
                        const e = items.find((i) => i.id === p.id);
                        if (e) e.qty += qty;
                        else items.push({ id: p.id, name: p.name, price: Number(p.price), image: p.image, weight: Number(p.weight) || 0, qty });
                        write(items);
                    },
                    setQty(id, qty) {
                        let items = read();
                        if (qty <= 0) items = items.filter((i) => i.id !== id);
                        else { const e = items.find((i) => i.id === id); if (e) e.qty = qty; }
                        write(items);
                    },
                    remove: (id) => write(read().filter((i) => i.id !== id)),
                    clear: () => write([]),
                };
                window.MizoCart = Cart;

                function updateBadge() {
                    const n = Cart.count();
                    document.querySelectorAll('[data-cart-count]').forEach((el) => {
                        el.textContent = n;
                        el.classList.toggle('hidden', n === 0);
                    });
                }
                window.__mizoUpdateCartBadge = updateBadge;

                if (!window.__mizoCartBound) {
                    window.__mizoCartBound = true;
                    document.addEventListener('click', function (ev) {
                        const btn = ev.target.closest('[data-add-to-cart]');
                        if (!btn) return;
                        ev.preventDefault();
                        Cart.add({
                            id: btn.dataset.id,
                            name: btn.dataset.name,
                            price: Number(btn.dataset.price),
                            image: btn.dataset.image,
                            weight: Number(btn.dataset.weight) || 0,
                        }, Number(btn.dataset.qty) || 1);
                        const original = btn.getAttribute('data-label') || btn.textContent;
                        btn.setAttribute('data-label', original);
                        btn.textContent = '✓ Agregado';
                        btn.classList.add('opacity-80');
                        setTimeout(() => {
                            btn.textContent = btn.getAttribute('data-label');
                            btn.classList.remove('opacity-80');
                        }, 1200);
                    });
                }

                document.addEventListener('astro:page-load', updateBadge);
                updateBadge();
            })();
        </script>
    </body>
</html>
<style is:global>
/* El bloque de estilo se deja tal como estaba en tu versión estable */
</style>