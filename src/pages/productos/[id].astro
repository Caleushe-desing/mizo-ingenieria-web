---
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import SectionCTA from '../../components/SectionCTA.astro';
import { products, sellingPrice, formatCLP, categories, type Product } from '../../data/products';

export function getStaticPaths() {
	return products.map((product) => ({
		params: { id: product.id },
		props: { product },
	}));
}

interface Props {
	product: Product;
}

const { product } = Astro.props;
const price = sellingPrice(product.basePrice);
const cat = categories.find((c) => c.id === product.category);
const catLabel = cat?.label ?? 'Producto';
const catIcon = cat?.icon ?? '📦';

const lowStock = typeof product.stock === 'number' && product.stock > 0 && product.stock <= 5;

// Productos relacionados de la misma categoría (excluyendo el actual).
const related = products
	.filter((p) => p.category === product.category && p.id !== product.id)
	.slice(0, 4);

const waNumber = '56994390870';
const waText = encodeURIComponent(
	`Hola Mizo, me interesa: ${product.name} (${formatCLP(price)}). ¿Está disponible?`,
);
const waLink = `https://wa.me/${waNumber}?text=${waText}`;
---

<Layout
	title={`${product.name} | Mizo`}
	description={`${product.name} — ${product.brand}. ${product.description}`}
	ogImage={product.image}
>
	<section class="bg-white py-8 sm:py-12">
		<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
			<nav class="text-sm text-gray-500 mb-6 flex flex-wrap items-center gap-1">
				<a href="/" class="hover:text-accent-main">Inicio</a>
				<span>/</span>
				<a href="/productos" class="hover:text-accent-main">Productos</a>
				<span>/</span>
				<span class="text-gray-700">{catLabel}</span>
			</nav>

			<div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
				<div class="relative flex items-center justify-center bg-white rounded-2xl border border-gray-200 p-8 min-h-[20rem]">
					<img
						src={product.image}
						alt={product.name}
						class="max-h-[26rem] w-auto object-contain mix-blend-multiply"
						width="600"
						height="600"
						onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
					/>
					<span class="hidden absolute inset-0 items-center justify-center text-8xl bg-accent-soft rounded-2xl" aria-hidden="true">{catIcon}</span>
				</div>

				<div class="flex flex-col">
					<span class="text-sm font-semibold uppercase tracking-wide text-accent-main mb-2">{product.brand} · {catLabel}</span>
					<h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900 leading-tight">{product.name}</h1>

					<p class="mt-4 text-gray-600 leading-relaxed">{product.description}</p>

					<div class="mt-6 flex items-end gap-3">
						<p class="text-4xl font-extrabold text-gray-900">{formatCLP(price)}</p>
						<span class="text-sm text-gray-400 mb-1">IVA incluido</span>
					</div>

					<p class="mt-2 text-sm text-green-600 font-medium flex items-center gap-1.5">
						<span class="inline-block w-2.5 h-2.5 rounded-full bg-green-500"></span>
						{lowStock ? `Disponible — ¡últimas ${product.stock} unidades!` : 'Disponible para entrega'}
					</p>

					<div class="mt-8 flex flex-col sm:flex-row gap-3">
						<button
							type="button"
							data-add-to-cart
							data-id={product.id}
							data-name={product.name}
							data-price={price}
							data-image={product.image}
							class="flex-grow text-center px-6 py-3.5 rounded-md text-base font-semibold text-white bg-accent-main hover:bg-accent-hover transition duration-200"
						>
							Agregar al carrito
						</button>
						<a
							href="/carrito"
							class="flex-grow text-center px-6 py-3.5 rounded-md text-base font-semibold text-accent-main border border-accent-main hover:bg-accent-soft transition"
						>
							Ir al carrito
						</a>
					</div>

					<a
						href={waLink}
						target="_blank"
						rel="noopener noreferrer"
						class="mt-3 inline-flex items-center justify-center gap-2 px-6 py-3 rounded-md text-base font-semibold text-white bg-green-600 hover:bg-green-700 transition"
					>
						<svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.945C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 018.413 3.488 11.82 11.82 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.51 5.26l-.999 3.648 3.929-1.03z"/></svg>
						Consultar por WhatsApp
					</a>
					<p class="mt-2 text-sm text-gray-500 text-center sm:text-left">¿Dudas sobre este equipo o su instalación? Escríbenos y te asesoramos.</p>

					<div class="mt-8 grid grid-cols-3 gap-3 text-center text-xs text-gray-500 border-t border-gray-100 pt-6">
						<div>
							<p class="text-accent-main font-bold text-lg">✓</p>
							Equipos originales
						</div>
						<div>
							<p class="text-accent-main font-bold text-lg">⚡</p>
							Instalación opcional
						</div>
						<div>
							<p class="text-accent-main font-bold text-lg">🇨🇱</p>
							Despacho en Chile
						</div>
					</div>
				</div>
			</div>

			{related.length > 0 && (
				<div class="mt-20">
					<h2 class="text-2xl font-bold text-gray-900 mb-6">También te puede interesar</h2>
					<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
						{related.map((p) => <ProductCard product={p} />)}
					</div>
				</div>
			)}
		</div>
	</section>

	<SectionCTA
		title="¿Buscas equipamiento e instalación profesional?"
		subtitle="Combinamos la venta de equipos con instalación garantizada de sonido, audio y video."
		buttonText="Solicitar Cotización"
		buttonLink="/contacto"
	/>
</Layout>
