---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Redirigiendo… | Mizo" description="La tienda online fue reemplazada por la vitrina de equipamiento de referencia Mizo." noindex={true}>
	<section class="flex min-h-[50vh] items-center justify-center bg-white px-4 py-20 text-center">
		<div>
			<p class="text-sm font-semibold text-slate-500">Redirigiendo a equipamiento de referencia…</p>
			<a href="/equipamiento" class="mt-4 inline-flex text-sm font-black text-accent-main hover:underline">Ir ahora</a>
		</div>
	</section>
	<script is:inline>location.replace('/equipamiento' + (location.search || ''));</script>
</Layout>
