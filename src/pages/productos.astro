---
import Layout from '../layouts/Layout.astro';
import SectionCTA from '../components/SectionCTA.astro';
---

<Layout
	title="Tienda | Mizo - Parlantes, Proyectores y Cámaras"
	description="Compra equipos de audio y video en Chile: parlantes, proyectores y cámaras de las mejores marcas. Con opción de instalación profesional. Precios en CLP."
>
	<!-- Encabezado tienda -->
	<section class="bg-gradient-to-b from-accent-soft to-white py-7 sm:py-14">
		<div class="mx-auto w-full max-w-[1920px] px-3 text-center sm:px-6 lg:px-8">
			<h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 leading-tight">
				Tienda Mizo de <span class="text-accent-main">audio y video</span>
			</h1>
			<p class="mt-3 text-base sm:text-lg text-gray-600 max-w-2xl mx-auto">
				Todos los productos viven aquí. Usa los filtros para ver Audio Profesional, Proyectores o Cámaras sin salir de la tienda.
			</p>

		</div>
	</section>

	<section class="bg-slate-100 py-3 sm:bg-white sm:py-8">
		<div class="mx-auto w-full max-w-[1920px] px-0 sm:px-6 lg:px-8">
			<div class="sticky top-[6.75rem] z-40 mb-2 border-y border-gray-100 bg-white/95 p-3 shadow-sm backdrop-blur sm:mb-5 sm:rounded-2xl sm:border md:top-[10rem]">
				<label for="catalog-search" class="sr-only">Buscar productos</label>
				<div class="relative">
					<input
						id="catalog-search"
						data-catalog-search
						type="search"
						placeholder="Buscar por nombre, marca o SKU..."
						aria-label="Buscar productos"
						class="w-full rounded-2xl border border-gray-200 bg-white py-3 pl-10 pr-4 text-sm text-gray-900 shadow-sm outline-none transition placeholder:text-gray-400 focus:border-accent-main focus:ring-2 focus:ring-accent-main/10"
					/>
					<svg class="absolute left-3.5 top-1/2 h-4 w-4 -translate-y-1/2 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m21 21-4.35-4.35M17 11a6 6 0 11-12 0 6 6 0 0112 0z"/></svg>
				</div>
			</div>

			<details class="mx-3 mb-3 rounded-2xl border border-gray-200 bg-white p-4 shadow-sm lg:hidden">
				<summary class="cursor-pointer text-sm font-black text-gray-900">Filtros del catálogo</summary>
				<div class="mt-4 grid gap-3 sm:grid-cols-2">
					<label class="grid gap-1 text-xs font-bold text-gray-500">
						Categoría
						<select data-filter-control="category" class="rounded-xl border border-gray-200 bg-white px-3 py-2 text-sm text-gray-800 outline-none focus:border-accent-main">
							<option value="all">Todas</option>
						</select>
					</label>
					<label class="grid gap-1 text-xs font-bold text-gray-500">
						Marca
						<select data-filter-control="brand" class="rounded-xl border border-gray-200 bg-white px-3 py-2 text-sm text-gray-800 outline-none focus:border-accent-main">
							<option value="all">Todas</option>
						</select>
					</label>
					<label class="grid gap-1 text-xs font-bold text-gray-500">
						Precio mínimo
						<input data-filter-control="min-price" type="number" min="0" inputmode="numeric" placeholder="$ min" class="rounded-xl border border-gray-200 bg-white px-3 py-2 text-sm text-gray-800 outline-none focus:border-accent-main" />
					</label>
					<label class="grid gap-1 text-xs font-bold text-gray-500">
						Precio máximo
						<input data-filter-control="max-price" type="number" min="0" inputmode="numeric" placeholder="$ max" class="rounded-xl border border-gray-200 bg-white px-3 py-2 text-sm text-gray-800 outline-none focus:border-accent-main" />
					</label>
					<label class="grid gap-1 text-xs font-bold text-gray-500 sm:col-span-2">
						Orden
						<select data-sort-select class="rounded-xl border border-gray-200 bg-white px-3 py-2 text-sm text-gray-800 outline-none focus:border-accent-main">
							<option value="relevance">Destacados</option>
							<option value="price-asc">Menor precio</option>
							<option value="price-desc">Mayor precio</option>
							<option value="name">Nombre (A-Z)</option>
						</select>
					</label>
					<button type="button" data-reset-filters class="rounded-xl border border-gray-200 bg-white px-3 py-2 text-xs font-black text-gray-700 transition hover:border-accent-light hover:text-accent-main sm:col-span-2">
						Limpiar filtros
					</button>
				</div>
			</details>

			<div class="grid gap-4 lg:grid-cols-[16rem_minmax(0,1fr)] xl:grid-cols-[17rem_minmax(0,1fr)] 2xl:gap-6">
				<aside class="sticky top-[10rem] hidden h-[calc(100vh-11rem)] self-start overflow-y-auto rounded-2xl border border-gray-200 bg-gray-50 p-3 shadow-sm lg:block xl:p-4">
					<p class="text-xs font-black uppercase tracking-wide text-gray-500">Filtros</p>
					<div class="mt-4 grid gap-3">
						<label class="grid gap-1 text-xs font-bold text-gray-500">
							Categoría
							<select data-filter-control="category" class="rounded-xl border border-gray-200 bg-white px-3 py-2 text-sm text-gray-800 outline-none focus:border-accent-main">
								<option value="all">Todas</option>
							</select>
						</label>
						<label class="grid gap-1 text-xs font-bold text-gray-500">
							Marca
							<select data-filter-control="brand" class="rounded-xl border border-gray-200 bg-white px-3 py-2 text-sm text-gray-800 outline-none focus:border-accent-main">
								<option value="all">Todas</option>
							</select>
						</label>
						<label class="grid gap-1 text-xs font-bold text-gray-500">
							Precio mínimo
							<input data-filter-control="min-price" type="number" min="0" inputmode="numeric" placeholder="$ min" class="rounded-xl border border-gray-200 bg-white px-3 py-2 text-sm text-gray-800 outline-none focus:border-accent-main" />
						</label>
						<label class="grid gap-1 text-xs font-bold text-gray-500">
							Precio máximo
							<input data-filter-control="max-price" type="number" min="0" inputmode="numeric" placeholder="$ max" class="rounded-xl border border-gray-200 bg-white px-3 py-2 text-sm text-gray-800 outline-none focus:border-accent-main" />
						</label>
						<label class="grid gap-1 text-xs font-bold text-gray-500">
							Orden
							<select data-sort-select class="rounded-xl border border-gray-200 bg-white px-3 py-2 text-sm text-gray-800 outline-none focus:border-accent-main">
								<option value="relevance">Destacados</option>
								<option value="price-asc">Menor precio</option>
								<option value="price-desc">Mayor precio</option>
								<option value="name">Nombre (A-Z)</option>
							</select>
						</label>
						<button type="button" data-reset-filters class="rounded-xl border border-gray-200 bg-white px-3 py-2 text-xs font-black text-gray-700 transition hover:border-accent-light hover:text-accent-main">
							Limpiar filtros
						</button>
					</div>
				</aside>

				<div class="min-w-0">
					<div class="mb-2 flex flex-wrap items-center justify-between gap-2 px-3 sm:mb-3 sm:px-0">
						<p id="result-count" class="text-xs font-bold uppercase tracking-wide text-gray-500"></p>
						<p id="active-filter-summary" class="text-xs text-gray-400"></p>
					</div>

					<div id="product-grid" class="grid grid-cols-1 gap-2 sm:grid-cols-2 sm:gap-3 md:grid-cols-3 md:gap-4 xl:grid-cols-4" aria-live="polite">
						<div class="col-span-full border-y border-gray-200 bg-white p-10 text-center text-gray-600 sm:rounded-2xl sm:border sm:bg-gray-50">
							Cargando productos publicados desde el catálogo Mizo...
						</div>
					</div>

					<!-- Sin resultados -->
					<div id="no-results" class="hidden text-center py-20">
						<div class="text-5xl mb-4">🔍</div>
						<h2 class="text-xl font-bold text-gray-900">No encontramos productos</h2>
						<p class="mt-2 text-gray-600">Prueba con otra palabra, categoría, marca o rango de precio.</p>
						<a href="/contacto" class="mt-6 inline-block px-6 py-3 rounded-md font-semibold text-white bg-accent-main hover:bg-accent-hover transition">
							Solicitar cotización
						</a>
					</div>
				</div>
			</div>

			<p class="mt-10 text-center text-sm text-gray-500 max-w-2xl mx-auto">
				Los valores publicados son referenciales y pueden variar según disponibilidad y tipo de cambio.
				Todos los equipos cuentan con opción de instalación profesional.
			</p>
		</div>
	</section>

	<SectionCTA
		title="¿Necesitas equipamiento e instalación?"
		subtitle="Combinamos la venta de equipos con instalación profesional de proyectores y sistemas de sonido para entregarte una solución completa y garantizada."
		buttonText="Solicitar Cotización"
		buttonLink="/contacto"
	/>
</Layout>

<script is:inline>
	function initStore() {
		const grid = document.getElementById('product-grid');
		const searchInputs = Array.from(document.querySelectorAll('[data-catalog-search]'));
		const categoryControls = Array.from(document.querySelectorAll('[data-filter-control="category"]'));
		const brandControls = Array.from(document.querySelectorAll('[data-filter-control="brand"]'));
		const minPriceControls = Array.from(document.querySelectorAll('[data-filter-control="min-price"]'));
		const maxPriceControls = Array.from(document.querySelectorAll('[data-filter-control="max-price"]'));
		const sortControls = Array.from(document.querySelectorAll('[data-sort-select]'));
		const resetButtons = Array.from(document.querySelectorAll('[data-reset-filters]'));
		const noResults = document.getElementById('no-results');
		const resultCount = document.getElementById('result-count');
		const activeFilterSummary = document.getElementById('active-filter-summary');
		if (!grid) return;

		let products = [];
		let currentCategory = 'all';
		let currentBrand = 'all';
		let currentQuery = '';
		let currentMinPrice = '';
		let currentMaxPrice = '';
		let currentSort = 'relevance';
		let filterBrands = [];

		const fmt = (value) => '$' + Number(value || 0).toLocaleString('es-CL');
		const esc = (value) => String(value ?? '').replace(/[&<>"']/g, (ch) => ({
			'&': '&amp;',
			'<': '&lt;',
			'>': '&gt;',
			'"': '&quot;',
			"'": '&#39;',
		}[ch]));
		const categoryIcon = { sonido: '🔊', proyector: '📽️', camara: '📹' };

		const stateKey = 'mizoCatalogState';
		const params = new URLSearchParams(window.location.search);
		const savedState = (() => {
			try {
				return JSON.parse(sessionStorage.getItem(stateKey) || '{}');
			} catch (error) {
				return {};
			}
		})();
		const navEntry = performance.getEntriesByType?.('navigation')?.[0];
		const isHistoryNavigation = navEntry?.type === 'back_forward' || window.performance?.navigation?.type === 2;
		const hasUrlState = ['q', 'cat', 'brand', 'min', 'max', 'sort'].some((key) => params.has(key));
		const stateSource = hasUrlState || !isHistoryNavigation ? {} : savedState;

		currentQuery = String(params.get('q') ?? stateSource.q ?? '').toLowerCase();
		currentCategory = String(params.get('cat') ?? stateSource.cat ?? 'all') || 'all';
		currentBrand = String(params.get('brand') ?? stateSource.brand ?? 'all') || 'all';
		currentMinPrice = String(params.get('min') ?? stateSource.min ?? '');
		currentMaxPrice = String(params.get('max') ?? stateSource.max ?? '');
		currentSort = String(params.get('sort') ?? stateSource.sort ?? 'relevance') || 'relevance';

		function inferBrand(product) {
			const explicit = String(product.brand || '').trim();
			return explicit && explicit.toLowerCase() !== 'mizo' ? explicit : '';
		}

		function categoryLabel(product) {
			return product.categoryLabel || product.category || 'Sin categoría';
		}

		function syncControls(source) {
			searchInputs.forEach((input) => { if (input !== source) input.value = currentQuery; });
			categoryControls.forEach((select) => { if (select !== source) select.value = currentCategory; });
			brandControls.forEach((select) => { if (select !== source) select.value = currentBrand; });
			minPriceControls.forEach((input) => { if (input !== source) input.value = currentMinPrice; });
			maxPriceControls.forEach((input) => { if (input !== source) input.value = currentMaxPrice; });
			sortControls.forEach((select) => { if (select !== source) select.value = currentSort; });
		}

		function catalogState() {
			return {
				q: currentQuery,
				cat: currentCategory,
				brand: currentBrand,
				min: currentMinPrice,
				max: currentMaxPrice,
				sort: currentSort,
				scrollY: window.scrollY,
			};
		}

		function persistCatalogState(updateUrl = true) {
			const state = catalogState();
			try {
				sessionStorage.setItem(stateKey, JSON.stringify(state));
			} catch (error) {
				// sessionStorage can be unavailable in private browsing modes.
			}
			if (!updateUrl) return;

			const url = new URL(window.location.href);
			const setOrDelete = (key, value, fallback = '') => {
				if (value && value !== fallback) url.searchParams.set(key, value);
				else url.searchParams.delete(key);
			};
			setOrDelete('q', currentQuery);
			setOrDelete('cat', currentCategory, 'all');
			setOrDelete('brand', currentBrand, 'all');
			setOrDelete('min', currentMinPrice);
			setOrDelete('max', currentMaxPrice);
			setOrDelete('sort', currentSort, 'relevance');
			window.history.replaceState({ ...window.history.state, mizoCatalog: state }, '', url);
		}

		function restoreScrollPosition() {
			const storedY = Number(savedState.scrollY);
			if (!Number.isFinite(storedY) || storedY <= 0 || !isHistoryNavigation) return;
			window.setTimeout(() => window.scrollTo({ top: storedY, left: 0, behavior: 'auto' }), 80);
		}

		function option(value, label) {
			return `<option value="${esc(value)}">${esc(label)}</option>`;
		}

		function populateFilterOptions() {
			const categoriesMap = new Map();
			const brands = new Set();

			products.forEach((product) => {
				const category = product.category || '';
				if (category) categoriesMap.set(category, categoryLabel(product));
			});
			(filterBrands.length ? filterBrands : products.map(inferBrand)).forEach((brand) => {
				const value = String(brand || '').trim();
				if (value !== '' && value.toLowerCase() !== 'mizo') brands.add(value);
			});

			const categoryOptions = option('all', 'Todas') + Array.from(categoriesMap.entries())
				.sort((a, b) => a[1].localeCompare(b[1]))
				.map(([value, label]) => option(value, label))
				.join('');
			const brandOptions = option('all', 'Todas') + Array.from(brands)
				.sort((a, b) => a.localeCompare(b))
				.map((brand) => option(brand, brand))
				.join('');

			categoryControls.forEach((select) => { select.innerHTML = categoryOptions; });
			brandControls.forEach((select) => { select.innerHTML = brandOptions; });

			if (currentCategory !== 'all' && !categoriesMap.has(currentCategory)) currentCategory = 'all';
			if (currentBrand !== 'all' && !brands.has(currentBrand)) currentBrand = 'all';
			syncControls();
		}

		function filterSummary() {
			const parts = [];
			if (currentCategory !== 'all') {
				const product = products.find((item) => item.category === currentCategory);
				parts.push(categoryLabel(product || { category: currentCategory }));
			}
			if (currentBrand !== 'all') parts.push(currentBrand);
			if (currentMinPrice) parts.push(`desde ${fmt(currentMinPrice)}`);
			if (currentMaxPrice) parts.push(`hasta ${fmt(currentMaxPrice)}`);
			return parts.join(' · ');
		}

		function bindControl(control, eventName, handler) {
			if (!control || control.dataset.bound === '1') return;
			control.dataset.bound = '1';
			control.addEventListener(eventName, handler);
		}

		function bindFilters() {
			searchInputs.forEach((input) => bindControl(input, 'input', () => {
				currentQuery = input.value.trim().toLowerCase();
				syncControls(input);
				persistCatalogState();
				apply();
			}));
			categoryControls.forEach((select) => bindControl(select, 'change', () => {
				currentCategory = select.value || 'all';
				syncControls(select);
				persistCatalogState();
				apply();
			}));
			brandControls.forEach((select) => bindControl(select, 'change', () => {
				currentBrand = select.value || 'all';
				syncControls(select);
				persistCatalogState();
				apply();
			}));
			minPriceControls.forEach((input) => bindControl(input, 'input', () => {
				currentMinPrice = input.value;
				syncControls(input);
				persistCatalogState();
				apply();
			}));
			maxPriceControls.forEach((input) => bindControl(input, 'input', () => {
				currentMaxPrice = input.value;
				syncControls(input);
				persistCatalogState();
				apply();
			}));
			sortControls.forEach((select) => bindControl(select, 'change', () => {
				currentSort = select.value || 'relevance';
				syncControls(select);
				persistCatalogState();
				sort();
				apply();
			}));
			resetButtons.forEach((button) => bindControl(button, 'click', () => {
				currentQuery = '';
				currentCategory = 'all';
				currentBrand = 'all';
				currentMinPrice = '';
				currentMaxPrice = '';
				currentSort = 'relevance';
				syncControls();
				persistCatalogState();
				sort();
				apply();
			}));
		}

		searchInputs.forEach((input) => {
			input.value = currentQuery;
		});

		function card(product) {
			const available = product.available !== false && Number(product.stock) > 0;
			const stockLabel = available ? `${Number(product.stock)} disponibles` : 'Sin Stock';
			const detailUrl = `/productos/detalle?sku=${encodeURIComponent(product.sku || product.id || '')}`;
			const cartId = product.sku || product.id || product.name;
			const image = product.image || '/mizo-logo.png';
			const price = Number(product.price) || 0;
			const brand = inferBrand(product);
			const displayCategory = product.categoryLabel || product.category || 'Producto';
			const brandMarkup = brand
				? `<p class="mt-1 text-xs font-semibold uppercase tracking-wide text-gray-500 line-clamp-1 md:text-sm">${esc(brand)}</p>`
				: '';

			return `<article class="product-item group flex h-full flex-col overflow-hidden border-y border-gray-100 bg-white shadow-none transition duration-300 hover:border-accent-light sm:rounded-2xl sm:border sm:shadow-sm sm:hover:-translate-y-1 sm:hover:shadow-lg" data-category="${esc(product.category)}" data-brand="${esc(brand)}" data-name="${esc(`${product.name} ${brand} ${product.sku}`.toLowerCase())}" data-price="${price}" data-sku="${esc(product.sku || '')}" data-published="${product.published === false ? '0' : '1'}">
				<a href="${esc(detailUrl)}" data-astro-reload class="flex flex-1 flex-row text-inherit sm:flex-col" aria-label="Ver detalle de ${esc(product.name)}">
					<div class="relative w-32 shrink-0 border-r border-gray-100 bg-gradient-to-b from-gray-50 to-white sm:w-full sm:border-r-0 sm:border-b">
						<div class="flex h-full min-h-36 items-center justify-center p-3 sm:h-40 md:h-44 md:p-4">
							<img src="${esc(image)}" alt="${esc(product.name)}" class="max-h-[120px] w-auto object-contain mix-blend-multiply transition duration-500 group-hover:scale-105 sm:max-h-[145px] md:max-h-[155px]" loading="lazy" width="240" height="240" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
							<span class="hidden absolute inset-0 items-center justify-center text-4xl bg-accent-soft" aria-hidden="true">${esc(categoryIcon[product.category] || '📦')}</span>
						</div>
						<span class="absolute left-2 top-2 hidden rounded-full bg-emerald-50 px-2 py-0.5 text-[0.58rem] font-black uppercase tracking-wide text-emerald-700 shadow-sm sm:inline-flex">
							Mejor Precio Garantizado
						</span>
					</div>

					<div class="flex min-w-0 flex-1 flex-col p-3 md:p-4 md:pb-3">
						<div class="mb-2 flex items-center justify-between gap-2">
							<span class="truncate rounded-full bg-accent-soft px-2 py-0.5 text-[0.58rem] font-black uppercase tracking-wide text-accent-main">Categoría: ${esc(displayCategory)}</span>
							<span class="max-w-[6rem] truncate font-mono text-[0.65rem] font-bold text-gray-400">${esc(product.sku)}</span>
						</div>

						<h3 class="text-sm font-bold leading-snug text-gray-950 transition group-hover:text-accent-main line-clamp-2 md:min-h-[2.35rem] md:text-base">${esc(product.name)}</h3>
						${brandMarkup}
						<p class="mt-1.5 hidden flex-1 text-xs leading-snug text-gray-500 line-clamp-2 sm:block md:text-sm">${esc(product.description || 'Producto publicado en el catálogo Mizo.')}</p>

						<div class="mt-2.5">
							<p class="text-[0.62rem] font-bold uppercase tracking-wide text-gray-400">Precio venta</p>
							<p class="text-lg font-black tracking-tight text-gray-950 md:text-xl">${fmt(price)}</p>
							<p class="product-stock-status mt-1.5 inline-flex items-center gap-1.5 rounded-full px-2 py-0.5 text-[0.68rem] font-black ${available ? 'bg-green-50 text-green-700' : 'bg-red-50 text-red-700'}" data-stock-status>
								<span class="inline-block h-1.5 w-1.5 rounded-full ${available ? 'bg-green-500' : 'bg-red-500'}" data-stock-dot></span>
								<span data-stock-label>${available ? `Stock · ${Number(product.stock)} disp.` : stockLabel}</span>
							</p>
						</div>
					</div>
				</a>

				<div class="px-3 pb-3 sm:px-3 md:px-4 md:pb-4">
					<button
						type="button"
						data-add-to-cart
						data-id="${esc(cartId)}"
						data-name="${esc(product.name)}"
						data-price="${price}"
						data-image="${esc(image)}"
						data-qty="1"
						class="add-to-cart-card inline-flex w-full items-center justify-center gap-1.5 rounded-lg bg-accent-main px-3 py-2 text-xs font-black text-white transition hover:bg-accent-hover disabled:cursor-not-allowed disabled:opacity-50"
						${available ? '' : 'disabled'}
					>
						<span aria-hidden="true">🛒</span>
						Agregar al Carrito
					</button>
				</div>
			</article>`;
		}

		function setStockStatus(item, stock, available) {
			item.dataset.price = item.dataset.price || '0';
			const status = item.querySelector('[data-stock-status]');
			const dot = item.querySelector('[data-stock-dot]');
			const label = item.querySelector('[data-stock-label]');
			const button = item.querySelector('[data-add-to-cart]');
			if (!status || !dot || !label) return;
			status.classList.toggle('bg-green-50', available);
			status.classList.toggle('text-green-700', available);
			status.classList.toggle('bg-red-50', !available);
			status.classList.toggle('text-red-700', !available);
			dot.classList.toggle('bg-green-500', available);
			dot.classList.toggle('bg-red-500', !available);
			label.textContent = available ? `Stock · ${stock} disp.` : 'Sin Stock';
			if (button) button.disabled = !available;
		}

		async function refreshLiveStockSequentially() {
			const items = Array.from(document.querySelectorAll('.product-item[data-sku]:not(.hidden)'));
			for (const item of items) {
				const sku = item.getAttribute('data-sku');
				if (!sku) continue;
				try {
					const response = await fetch(`/api-get-live-stock.php?sku=${encodeURIComponent(sku)}&ts=${Date.now()}`, {
						headers: { Accept: 'application/json' },
						cache: 'no-store',
					});
					const payload = await response.json();
					if (response.ok && payload?.ok) {
						setStockStatus(item, Number(payload.stock) || 0, Boolean(payload.disponible));
					}
				} catch (error) {
					console.warn('No se pudo refrescar stock vivo', { sku, error });
				}
				await new Promise((resolve) => window.setTimeout(resolve, 250));
			}
		}

		function render() {
			if (products.length === 0) {
				grid.innerHTML = '<div class="col-span-full rounded-2xl border border-gray-200 bg-gray-50 p-10 text-center text-gray-600">Aún no hay productos publicados. Publica productos desde el panel de administración para poblar la tienda.</div>';
				if (noResults) noResults.classList.add('hidden');
				if (resultCount) resultCount.textContent = '0 productos publicados';
				return;
			}

			grid.innerHTML = products.map(card).join('');
			grid.querySelectorAll('.product-item').forEach((item, index) => {
				item.setAttribute('data-sku', products[index]?.sku || '');
			});
			sort();
			apply();
			restoreScrollPosition();
		}

		function apply() {
			const items = Array.from(document.querySelectorAll('.product-item'));
			let visible = 0;
			const minPrice = currentMinPrice === '' ? null : Number(currentMinPrice);
			const maxPrice = currentMaxPrice === '' ? null : Number(currentMaxPrice);
			items.forEach((item) => {
				const cat = item.getAttribute('data-category');
				const brand = item.getAttribute('data-brand');
				const name = item.getAttribute('data-name') || '';
				const price = Number(item.dataset.price) || 0;
				const matchCat = currentCategory === 'all' || cat === currentCategory;
				const matchBrand = currentBrand === 'all' || brand === currentBrand;
				const matchText = !currentQuery || name.includes(currentQuery);
				const matchMin = minPrice === null || price >= minPrice;
				const matchMax = maxPrice === null || price <= maxPrice;
				const show = matchCat && matchBrand && matchText && matchMin && matchMax;
				item.classList.toggle('hidden', !show);
				if (show) visible++;
			});
			if (noResults) noResults.classList.toggle('hidden', visible > 0);
			if (resultCount) resultCount.textContent = visible + (visible === 1 ? ' producto' : ' productos');
			if (activeFilterSummary) activeFilterSummary.textContent = filterSummary();
			persistCatalogState(false);
		}

		function sort() {
			const items = Array.from(document.querySelectorAll('.product-item'));
			const mode = currentSort;
			const sorted = [...items];
			if (mode === 'price-asc') sorted.sort((a, b) => (+a.dataset.price) - (+b.dataset.price));
			else if (mode === 'price-desc') sorted.sort((a, b) => (+b.dataset.price) - (+a.dataset.price));
			else if (mode === 'name') sorted.sort((a, b) => a.dataset.name.localeCompare(b.dataset.name));
			sorted.forEach((el) => grid.appendChild(el));
		}

		async function loadProducts() {
			try {
				const response = await fetch(`/api-productos-publicados.php?ts=${Date.now()}`, { headers: { Accept: 'application/json' }, cache: 'no-store' });
				const payload = await response.json();
				if (!response.ok || !payload?.ok) throw new Error(payload?.error || 'No se pudo cargar el catálogo.');
				products = Array.isArray(payload.products) ? payload.products.filter((product) => product?.published !== false) : [];
				filterBrands = Array.isArray(payload.filters?.brands)
					? payload.filters.brands.filter((brand) => String(brand || '').trim().toLowerCase() !== 'mizo')
					: [];
				populateFilterOptions();
				bindFilters();
				render();
				window.__mizoCatalogRefreshStock = refreshLiveStockSequentially;
				window.__mizoCatalogPersistState = () => persistCatalogState(false);
				refreshLiveStockSequentially();
			} catch (error) {
				grid.innerHTML = '<div class="col-span-full rounded-2xl border border-red-200 bg-red-50 p-10 text-center text-red-700">No se pudo cargar el catálogo dinámico. Intenta nuevamente en unos minutos.</div>';
				if (resultCount) resultCount.textContent = 'Error al cargar productos';
				console.error(error);
			}
		}

		loadProducts();
	}

	document.addEventListener('DOMContentLoaded', initStore);
	document.addEventListener('astro:page-load', initStore);
</script>

<script is:inline>
	window.addEventListener('pagehide', function() {
		if (typeof window.__mizoCatalogPersistState === 'function') {
			window.__mizoCatalogPersistState();
		}
	});

	window.addEventListener('pageshow', function(event) {
		if (event.persisted || (typeof window.performance != 'undefined' && window.performance.navigation.type === 2)) {
			if (typeof window.__mizoCatalogRefreshStock === 'function') {
				window.__mizoCatalogRefreshStock();
			}
		}
	});
</script>
