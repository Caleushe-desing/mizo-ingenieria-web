---
import Layout from '../layouts/Layout.astro';
import SectionCTA from '../components/SectionCTA.astro';

const services = [
	{
		title: 'Sistemas de Sonido y Audio Profesional',
		description: 'Diseñamos e instalamos sistemas de audio, megafonía y música ambiental para comercios, oficinas, eventos y hogares. Sonido nítido y controlado en cada rincón.',
		icon: '🔊',
		details: [
			'Diseño acústico y selección de equipos de audio',
			'Parlantes de cielo, columnas y line array',
			'Amplificación y zonificación inteligente (multizona)',
			'Megafonía y sistemas de avisos de emergencia',
		],
		image: '/servicio-audio.jpg',
	},
	{
		title: 'Soluciones Audiovisuales',
		description: 'Proyección, pantallas, salas de reuniones y videovigilancia. Integramos imagen, video y control para que tus espacios comuniquen y se vean increíbles.',
		icon: '📽️',
		details: [
			'Proyectores y pantallas eléctricas para salas y home cinema',
			'Salas de reuniones y videoconferencia',
			'Cámaras de seguridad y CCTV/IP con monitoreo remoto',
			'Cableado estructurado y conectividad',
		],
		image: '/servicio-cctv.jpg',
	},
	{
		title: 'Instalaciones Eléctricas',
		description: 'Montaje, ampliación y certificación de instalaciones eléctricas seguras y eficientes para hogares e industria, cumpliendo la normativa eléctrica chilena.',
		icon: '⚡',
		details: [
			'Diseño de tableros eléctricos y distribución de potencia',
			'Instalación de iluminación de alta eficiencia',
			'Protecciones, diferenciales y puesta a tierra',
			'Mantenimiento preventivo y certificación de instalaciones',
		],
		image: '/servicio-electrico.jpg',
	},
];
---

<Layout
	title="Servicios | Mizo - Sonido, Audiovisual y Electricidad"
	description="Servicios de instalación de sistemas de sonido, soluciones audiovisuales e instalaciones eléctricas profesionales en Chile."
>
	<section class="bg-gradient-to-b from-accent-soft to-white py-20 sm:py-28">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
			<h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-gray-900 leading-tight">
				Servicios de <span class="text-accent-main">instalación profesional</span>
			</h1>
			<p class="mt-4 text-lg sm:text-xl text-gray-600 max-w-3xl mx-auto">
				Tres especialidades, un solo equipo. Llevamos sonido, imagen y energía a tu proyecto con trabajo prolijo y garantizado.
			</p>
		</div>
	</section>

	<section class="py-20 bg-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-20">
			{services.map((service, index) => (
				<div class:list={[
					"grid grid-cols-1 lg:grid-cols-2 gap-12 items-center",
					{ "lg:grid-flow-col-dense": index % 2 === 1 }
				]}>
					<div class:list={[{ "lg:col-start-2": index % 2 === 1 }]}>
						<div class="text-4xl mb-4 inline-flex h-16 w-16 items-center justify-center rounded-xl bg-accent-soft">
							{service.icon}
						</div>
						<h2 class="text-2xl lg:text-3xl font-bold text-gray-900 mb-4">
							{service.title}
						</h2>
						<p class="text-lg text-gray-600 mb-6">
							{service.description}
						</p>

						<ul class="space-y-3 text-gray-700">
							{service.details.map((detail) => (
								<li class="flex items-start">
									<svg class="w-6 h-6 text-accent-main mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
									{detail}
								</li>
							))}
						</ul>

						<div class="mt-8 flex flex-wrap gap-4">
							<a href="/contacto" class="px-6 py-3 text-base font-semibold rounded-md text-white bg-accent-main hover:bg-accent-hover transition duration-300">
								Cotizar este servicio
							</a>
							<a href="/productos" class="px-6 py-3 text-base font-semibold rounded-md text-accent-main border border-accent-main hover:bg-accent-soft transition duration-300">
								Ver equipos
							</a>
						</div>
					</div>

					<div class:list={[
						"h-80 rounded-2xl overflow-hidden border border-gray-200 shadow-sm bg-accent-soft",
						{ "lg:col-start-1": index % 2 === 1 }
					]}>
						<img
							src={service.image}
							alt={`Servicio: ${service.title}`}
							class="w-full h-full object-cover"
							loading="lazy"
							width="800"
							height="600"
						/>
					</div>
				</div>
			))}
		</div>
	</section>

	<SectionCTA
		title="¿Buscas una solución a medida?"
		subtitle="Nuestro equipo está listo para diseñar e instalar exactamente lo que tu proyecto necesita."
		buttonText="Solicitar Cotización"
		buttonLink="/contacto"
	/>
</Layout>
