---
import Layout from '../layouts/Layout.astro';
import SectionCTA from '../components/SectionCTA.astro';
import PageHero from '../components/PageHero.astro';

const services = [
	{
		title: 'Diseño acústico y sistemas de audio profesional',
		description: 'Calculamos cobertura, potencia, inteligibilidad, zonas y operación diaria para salas corporativas, auditorios, iglesias, colegios, retail y espacios premium.',
		kicker: 'Audio calibrado',
		details: [
			'Diseño acústico, selección de parlantes y distribución por zonas',
			'Microfonía, DSP, matrices, amplificación y sistemas multizona',
			'Medición, ecualización, control de feedback y pruebas de inteligibilidad',
			'Capacitación de usuarios y documentación de operación',
		],
		image: 'https://images.unsplash.com/photo-1598488035139-bdbb2231ce04?auto=format&fit=crop&w=1100&q=80',
	},
	{
		title: 'Proyección láser, salas AV y control integrado',
		description: 'Integramos imagen, audio, control, videoconferencia y escenas para que la tecnología sea simple de usar y robusta en operación.',
		kicker: 'Imagen + control',
		details: [
			'Proyectores láser, pantallas, soportes y ajuste geométrico',
			'Videoconferencia, matrices HDMI/AV, control y automatización',
			'Calibración de brillo, color, escenas y entradas de usuario',
			'Integración para directorios, auditorios, colegios y home cinema',
		],
		image: 'https://images.unsplash.com/photo-1497366754035-f200968a6e72?auto=format&fit=crop&w=1100&q=80',
	},
	{
		title: 'Canalización, cableado oculto y soportería pesada',
		description: 'Resolvemos la infraestructura que sostiene una instalación premium: rutas limpias, fijaciones confiables, etiquetado y terminaciones mantenibles.',
		kicker: 'Infraestructura AV',
		details: [
			'Canalización técnica, cableado estructural oculto y patching ordenado',
			'Montaje de soportería pesada para pantallas, proyectores y parlantes',
			'Anclajes, pasadas, terminaciones, pruebas y rotulación',
			'Criterio eléctrico y de seguridad para equipos audiovisuales sensibles',
		],
		image: 'https://images.unsplash.com/photo-1558618666-fcd25c85cd64?auto=format&fit=crop&w=1100&q=80',
	},
];

const process = [
	'Levantamiento técnico y diagnóstico del recinto',
	'Ingeniería de solución, marcas y presupuesto por etapas',
	'Ejecución limpia con coordinación de obra y pruebas',
	'Calibración, entrega documentada y soporte posterior',
];
---

<Layout
	title="Servicios | Mizo - Sonido, Audiovisual y Electricidad"
	description="Servicios de instalación de sistemas de sonido, soluciones audiovisuales e instalaciones eléctricas profesionales en Chile."
>
	<PageHero
		eyebrow="Integración audiovisual premium"
		title="Servicios profesionales para espacios que deben sonar, verse y operar perfecto."
		subtitle="Diseñamos e instalamos sistemas audiovisuales completos: acústica, cableado oculto, montaje estructural, proyección láser, control y calibración final."
		image="https://images.unsplash.com/photo-1516321318423-f06f85e504b3?auto=format&fit=crop&w=1600&q=80"
		chips={["Audio calibrado", "Imagen + control", "Infraestructura AV"]}
	/>

	<section class="bg-white py-20">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="grid grid-cols-1 gap-4 rounded-[2rem] border border-slate-200 bg-slate-50 p-4 shadow-sm sm:grid-cols-2 lg:grid-cols-4">
				{process.map((item, index) => (
					<div class="rounded-3xl bg-white p-5">
						<p class="text-xs font-black uppercase tracking-[0.18em] text-accent-main">Etapa {index + 1}</p>
						<p class="mt-2 text-sm font-bold leading-relaxed text-slate-700">{item}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<section class="bg-white pb-20">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-20">
			{services.map((service, index) => (
				<div class:list={[
					"grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-14 items-center",
					{ "lg:grid-flow-col-dense": index % 2 === 1 }
				]}>
					<div class:list={[{ "lg:col-start-2": index % 2 === 1 }]}>
						<span class="inline-flex rounded-full bg-accent-main/10 px-4 py-1.5 text-xs font-black uppercase tracking-[0.18em] text-accent-main">
							{service.kicker}
						</span>
						<h2 class="mt-5 text-3xl font-black leading-tight text-gray-950 lg:text-4xl">
							{service.title}
						</h2>
						<p class="mt-5 text-lg leading-relaxed text-gray-600">
							{service.description}
						</p>

						<ul class="mt-7 grid gap-3 text-gray-700">
							{service.details.map((detail) => (
								<li class="flex items-start rounded-2xl border border-slate-200 bg-slate-50 p-4">
									<svg class="mr-3 mt-0.5 h-5 w-5 flex-shrink-0 text-accent-main" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
									<span class="text-sm font-bold leading-relaxed">{detail}</span>
								</li>
							))}
						</ul>

						<div class="mt-8 flex flex-wrap gap-4">
							<a href="/contacto" class="rounded-full bg-accent-main px-6 py-3 text-sm font-black text-white shadow-lg transition hover:bg-accent-hover">
								Cotizar este servicio
							</a>
							<a href="/equipamiento" class="rounded-full border border-accent-main px-6 py-3 text-sm font-black text-accent-main transition hover:bg-accent-soft">
								Ver equipamiento
							</a>
						</div>
					</div>

					<div class:list={[
						"relative min-h-[360px] overflow-hidden rounded-[2rem] border border-gray-200 bg-slate-950 shadow-2xl",
						{ "lg:col-start-1": index % 2 === 1 }
					]}>
						<img
							src={service.image}
							alt={`Servicio: ${service.title}`}
							class="h-full min-h-[360px] w-full object-cover opacity-85"
							loading="lazy"
							width="1100"
							height="760"
						/>
						<div class="absolute inset-0 bg-gradient-to-t from-slate-950/85 via-transparent to-transparent"></div>
						<div class="absolute bottom-0 left-0 right-0 p-6 text-white">
							<p class="text-xs font-black uppercase tracking-[0.18em] text-brand-orange">Placeholder fotográfico HD</p>
							<p class="mt-2 text-xl font-black">Listo para reemplazar por obra Mizo</p>
						</div>
					</div>
				</div>
			))}
		</div>
	</section>

	<SectionCTA
		title="¿Buscas una solución a medida?"
		subtitle="Nuestro equipo está listo para diseñar e instalar exactamente lo que tu proyecto necesita."
		buttonText="Solicitar Cotización"
		buttonLink="/contacto"
	/>
</Layout>
