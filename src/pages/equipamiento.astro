---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import SectionCTA from '../components/SectionCTA.astro';
---

<Layout
	title="Equipamiento de referencia | Mizo"
	description="Conoce el equipamiento profesional que integramos en proyectos de audio, video e instalaciones audiovisuales en Chile."
>
	<PageHero
		eyebrow="Equipamiento de referencia"
		title="Tecnología profesional que integramos en cada proyecto"
		subtitle="Esta vitrina muestra equipos representativos de las marcas y soluciones que Mizo dimensiona, instala y calibra. No es una tienda: es una referencia técnica para apoyar tu diagnóstico y cotización."
		image="https://images.unsplash.com/photo-1598488035139-bdbb2231ce04?auto=format&fit=crop&w=1600&q=80"
		align="center"
		chips={['Audio profesional', 'Proyección AV', 'Video y CCTV']}
	/>

	<section class="border-b border-slate-200 bg-white py-6">
		<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
			<div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
				<div class="flex flex-wrap gap-2" id="category-tabs" aria-label="Filtrar por categoría"></div>
				<label class="relative block w-full max-w-md">
					<span class="sr-only">Buscar equipamiento</span>
					<input
						id="showcase-search"
						type="search"
						placeholder="Buscar por nombre o marca..."
						class="w-full rounded-full border border-slate-200 bg-slate-50 py-2.5 pl-10 pr-4 text-sm outline-none transition focus:border-accent-main focus:bg-white focus:ring-2 focus:ring-accent-soft"
					/>
					<svg class="pointer-events-none absolute left-3.5 top-1/2 h-4 w-4 -translate-y-1/2 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m21 21-4.35-4.35M17 11a6 6 0 11-12 0 6 6 0 0112 0z"/></svg>
				</label>
			</div>
			<p id="showcase-meta" class="mt-4 text-sm font-semibold text-slate-500">Cargando equipamiento...</p>
		</div>
	</section>

	<section class="bg-slate-50 py-12 sm:py-16">
		<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
			<div id="showcase-grid" class="grid gap-5 sm:grid-cols-2 xl:grid-cols-3"></div>
			<div id="showcase-empty" class="hidden rounded-[2rem] border border-dashed border-slate-300 bg-white p-10 text-center">
				<p class="text-lg font-black text-ink">Aún no hay equipos seleccionados para la vitrina.</p>
				<p class="mx-auto mt-3 max-w-xl text-sm leading-6 text-slate-500">
					El equipo Mizo puede activar referencias desde el panel de administración. Mientras tanto, usa el diagnóstico técnico para dimensionar tu proyecto.
				</p>
				<a href="/configurador" class="mt-6 inline-flex rounded-full bg-accent-main px-6 py-3 text-sm font-black text-white transition hover:bg-accent-hover">
					Abrir diagnóstico técnico
				</a>
			</div>
		</div>
	</section>

	<section class="bg-white py-14">
		<div class="mx-auto max-w-5xl px-4 text-center sm:px-6 lg:px-8">
			<p class="text-xs font-black uppercase tracking-[0.22em] text-brand-orange">Enfoque Mizo</p>
			<h2 class="mt-3 text-2xl font-black text-ink sm:text-3xl">Instalación, integración y validación técnica</h2>
			<p class="mx-auto mt-4 max-w-3xl text-base leading-7 text-slate-600">
				El equipamiento es solo una parte del proyecto. Mizo diseña la solución completa: acústica, cableado, montaje, calibración, capacitación y soporte posterior.
			</p>
			<div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
				<a href="/configurador" class="inline-flex rounded-full bg-accent-main px-7 py-3.5 text-sm font-black text-white shadow-lg transition hover:bg-accent-hover">
					Dimensionar mi espacio
				</a>
				<a href="/servicios" class="inline-flex rounded-full border border-slate-200 px-7 py-3.5 text-sm font-black text-slate-700 transition hover:border-accent-main hover:text-accent-main">
					Ver servicios de ingeniería
				</a>
			</div>
		</div>
	</section>

	<SectionCTA
		title="¿Quieres una propuesta técnica para tu proyecto?"
		subtitle="Cuéntanos tu espacio y un ingeniero Mizo te contactará con la solución integrada."
		buttonText="Solicitar cotización"
		buttonLink="/contacto"
	/>
</Layout>

<script is:inline>
	(function () {
		const grid = document.getElementById('showcase-grid');
		const empty = document.getElementById('showcase-empty');
		const meta = document.getElementById('showcase-meta');
		const tabs = document.getElementById('category-tabs');
		const search = document.getElementById('showcase-search');
		if (!grid || !empty || !meta || !tabs || !search) return;

		let products = [];
		let currentCategory = 'all';
		let currentBrand = '';
		let currentQuery = '';

		function esc(value) {
			return String(value ?? '').replace(/[&<>"']/g, (ch) => ({
				'&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;',
			}[ch]));
		}

		function cardHtml(product) {
			const brand = product.brand && product.brand.toLowerCase() !== 'mizo' ? product.brand : '';
			const consultUrl = '/contacto?equipo=' + encodeURIComponent(product.name || '');
			const configUrl = '/configurador?ref=' + encodeURIComponent(product.sku || product.id || '');
			return `<article class="showcase-card group flex h-full flex-col overflow-hidden rounded-[1.5rem] border border-slate-200 bg-white shadow-sm transition hover:-translate-y-0.5 hover:border-accent-main/40 hover:shadow-lg">
				<div class="relative overflow-hidden bg-gradient-to-b from-slate-50 to-white">
					<div class="flex h-48 items-center justify-center p-5 sm:h-52">
						<img src="${esc(product.image || '/mizo-logo.png')}" alt="${esc(product.name)}" class="max-h-full w-auto object-contain mix-blend-multiply transition duration-500 group-hover:scale-105" loading="lazy" onerror="this.onerror=null;this.src='/mizo-logo.png';" />
					</div>
					${product.categoryLabel ? `<span class="absolute left-3 top-3 rounded-full border border-accent-main/20 bg-white/90 px-2.5 py-1 text-[0.62rem] font-black uppercase tracking-[0.16em] text-accent-main backdrop-blur">${esc(product.categoryLabel)}</span>` : ''}
				</div>
				<div class="flex flex-1 flex-col p-5">
					${brand ? `<p class="text-[0.68rem] font-black uppercase tracking-[0.18em] text-brand-orange">${esc(brand)}</p>` : ''}
					<h3 class="mt-1 text-base font-black leading-snug text-ink transition group-hover:text-accent-main line-clamp-2">${esc(product.name)}</h3>
					${product.note ? `<p class="mt-2 rounded-xl border border-brand-orange/20 bg-brand-orange-soft/60 px-3 py-2 text-xs font-semibold leading-5 text-brand-orange-dark">${esc(product.note)}</p>` : ''}
					${product.description ? `<p class="mt-3 flex-1 text-sm leading-6 text-slate-600 line-clamp-3">${esc(product.description)}</p>` : ''}
					${product.engineeringCategory ? `<p class="mt-3 text-xs font-semibold uppercase tracking-wide text-slate-400">${esc(product.engineeringCategory)}</p>` : ''}
					<div class="mt-5 grid gap-2 sm:grid-cols-2">
						<a href="${configUrl}" class="inline-flex items-center justify-center rounded-full bg-accent-main px-4 py-2.5 text-xs font-black text-white transition hover:bg-accent-hover">Dimensionar proyecto</a>
						<a href="${consultUrl}" class="inline-flex items-center justify-center rounded-full border border-slate-200 px-4 py-2.5 text-xs font-black text-slate-700 transition hover:border-accent-main hover:text-accent-main">Consultar</a>
					</div>
				</div>
			</article>`;
		}

		function readUrlState() {
			const params = new URLSearchParams(window.location.search);
			currentBrand = String(params.get('marca') || params.get('brand') || '').trim();
			currentCategory = String(params.get('cat') || 'all');
			currentQuery = String(params.get('q') || '').trim().toLowerCase();
			search.value = currentQuery;
		}

		function filteredProducts() {
			return products.filter((product) => {
				if (currentCategory !== 'all' && product.category !== currentCategory) return false;
				if (currentBrand && String(product.brand || '').toLowerCase() !== currentBrand.toLowerCase()) return false;
				if (!currentQuery) return true;
				const haystack = [product.name, product.brand, product.description, product.categoryLabel, product.engineeringCategory]
					.join(' ').toLowerCase();
				return haystack.includes(currentQuery);
			});
		}

		function renderTabs(categories) {
			const entries = Object.entries(categories || {}).sort((a, b) => a[1].localeCompare(b[1]));
			const buttons = [
				`<button type="button" data-category="all" class="showcase-tab rounded-full px-4 py-2 text-xs font-black transition ${currentCategory === 'all' ? 'bg-accent-main text-white' : 'bg-slate-100 text-slate-600 hover:bg-accent-soft hover:text-accent-main'}">Todos</button>`,
				...entries.map(([value, label]) => {
					const active = currentCategory === value;
					return `<button type="button" data-category="${esc(value)}" class="showcase-tab rounded-full px-4 py-2 text-xs font-black transition ${active ? 'bg-accent-main text-white' : 'bg-slate-100 text-slate-600 hover:bg-accent-soft hover:text-accent-main'}">${esc(label)}</button>`;
				}),
			];
			tabs.innerHTML = buttons.join('');
			tabs.querySelectorAll('.showcase-tab').forEach((button) => {
				button.addEventListener('click', () => {
					currentCategory = button.getAttribute('data-category') || 'all';
					render();
				});
			});
		}

		function render() {
			const visible = filteredProducts();
			meta.textContent = visible.length === 1
				? '1 equipo de referencia'
				: `${visible.length} equipos de referencia`;
			grid.innerHTML = visible.map(cardHtml).join('');
			grid.classList.toggle('hidden', visible.length === 0);
			empty.classList.toggle('hidden', visible.length > 0);
			tabs.querySelectorAll('.showcase-tab').forEach((button) => {
				const active = (button.getAttribute('data-category') || 'all') === currentCategory;
				button.classList.toggle('bg-accent-main', active);
				button.classList.toggle('text-white', active);
				button.classList.toggle('bg-slate-100', !active);
				button.classList.toggle('text-slate-600', !active);
			});
		}

		search.addEventListener('input', () => {
			currentQuery = search.value.trim().toLowerCase();
			render();
		});

		fetch('/api/showcase.php', { headers: { Accept: 'application/json' }, cache: 'no-store' })
			.then((response) => response.json())
			.then((payload) => {
				if (!payload?.ok) throw new Error(payload?.error || 'No se pudo cargar la vitrina.');
				products = Array.isArray(payload.products) ? payload.products : [];
				readUrlState();
				renderTabs(payload.filters?.categories || {});
				render();
			})
			.catch(() => {
				meta.textContent = 'No se pudo cargar el equipamiento de referencia.';
				grid.classList.add('hidden');
				empty.classList.remove('hidden');
			});
	})();
</script>
