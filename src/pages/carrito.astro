---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Redirigiendo… | Mizo" description="Las cotizaciones de proyectos se gestionan mediante diagnóstico técnico Mizo." noindex={true}>
	<section class="flex min-h-[50vh] items-center justify-center bg-white px-4 py-20 text-center">
		<div>
			<p class="text-sm font-semibold text-slate-500">Redirigiendo al diagnóstico técnico…</p>
			<a href="/configurador" class="mt-4 inline-flex text-sm font-black text-accent-main hover:underline">Ir ahora</a>
		</div>
	</section>
	<script is:inline>location.replace('/configurador');</script>
</Layout>
