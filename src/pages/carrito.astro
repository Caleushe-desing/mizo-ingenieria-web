---
import Layout from '../layouts/Layout.astro';

// Regiones de Chile (deben coincidir con los IDs de la función cotizar-envio).
const regiones = [
	{ id: 'arica-parinacota', name: 'Arica y Parinacota' },
	{ id: 'tarapaca', name: 'Tarapacá' },
	{ id: 'antofagasta', name: 'Antofagasta' },
	{ id: 'atacama', name: 'Atacama' },
	{ id: 'coquimbo', name: 'Coquimbo' },
	{ id: 'valparaiso', name: 'Valparaíso' },
	{ id: 'metropolitana', name: 'Metropolitana de Santiago' },
	{ id: 'ohiggins', name: "O'Higgins" },
	{ id: 'maule', name: 'Maule' },
	{ id: 'nuble', name: 'Ñuble' },
	{ id: 'biobio', name: 'Biobío' },
	{ id: 'araucania', name: 'La Araucanía' },
	{ id: 'los-rios', name: 'Los Ríos' },
	{ id: 'los-lagos', name: 'Los Lagos' },
	{ id: 'aysen', name: 'Aysén' },
	{ id: 'magallanes', name: 'Magallanes' },
];
---

<Layout
	title="Carrito | Mizo"
	description="Revisa los productos de audio y video seleccionados y finaliza tu compra con Mercado Pago."
>
	<section class="bg-gradient-to-b from-accent-soft to-white py-12 sm:py-16">
		<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
			<h1 class="text-3xl sm:text-4xl font-extrabold text-gray-900">Tu carrito</h1>
			<p class="mt-2 text-gray-600">Revisa tus productos y finaliza la compra de forma segura.</p>
		</div>
	</section>

	<section class="py-10 bg-white">
		<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
			<!-- Carrito vacío -->
			<div id="cart-empty" class="hidden text-center py-20">
				<div class="text-6xl mb-4">🛒</div>
				<h2 class="text-xl font-bold text-gray-900">Tu carrito está vacío</h2>
				<p class="mt-2 text-gray-600">Explora nuestro catálogo de equipos de audio y video.</p>
				<a href="/productos" class="mt-6 inline-block px-6 py-3 rounded-md font-semibold text-white bg-accent-main hover:bg-accent-hover transition">
					Ver productos
				</a>
			</div>

			<!-- Carrito con contenido -->
			<div id="cart-content" class="hidden grid grid-cols-1 lg:grid-cols-3 gap-8">
				<div class="lg:col-span-2">
					<ul id="cart-items" class="divide-y divide-gray-100"></ul>
					<button id="cart-clear" type="button" class="mt-4 text-sm text-gray-400 hover:text-red-500 transition">
						Vaciar carrito
					</button>
				</div>

				<aside class="lg:col-span-1">
					<div class="bg-gray-50 rounded-xl border border-gray-200 p-6 sticky top-24">
						<h2 class="text-lg font-bold text-gray-900 mb-4">Resumen</h2>

						<!-- Datos de despacho -->
						<div class="mb-5 pb-5 border-b border-gray-200">
							<h3 class="text-sm font-semibold text-gray-700 mb-3">Datos de despacho</h3>
							<div class="space-y-2">
								<input id="ship-name" type="text" autocomplete="name" placeholder="Nombre completo *" class="w-full px-3 py-2 rounded-md border border-gray-300 bg-white text-sm focus:ring-2 focus:ring-accent-light focus:outline-none" />
								<input id="ship-phone" type="tel" autocomplete="tel" placeholder="Teléfono / WhatsApp *" class="w-full px-3 py-2 rounded-md border border-gray-300 bg-white text-sm focus:ring-2 focus:ring-accent-light focus:outline-none" />
								<input id="ship-email" type="email" autocomplete="email" placeholder="Correo electrónico *" class="w-full px-3 py-2 rounded-md border border-gray-300 bg-white text-sm focus:ring-2 focus:ring-accent-light focus:outline-none" />
								<select id="ship-region" class="w-full px-3 py-2.5 rounded-md border border-gray-300 bg-white text-sm text-gray-900 focus:ring-2 focus:ring-accent-light focus:outline-none">
									<option value="">Región *</option>
									{regiones.map((r) => <option value={r.id}>{r.name}</option>)}
								</select>
								<input id="ship-comuna" type="text" autocomplete="address-level2" placeholder="Comuna *" class="w-full px-3 py-2 rounded-md border border-gray-300 bg-white text-sm focus:ring-2 focus:ring-accent-light focus:outline-none" />
								<input id="ship-address" type="text" autocomplete="street-address" placeholder="Dirección (calle y número) *" class="w-full px-3 py-2 rounded-md border border-gray-300 bg-white text-sm focus:ring-2 focus:ring-accent-light focus:outline-none" />
								<input id="ship-reference" type="text" placeholder="Depto, block o referencia (opcional)" class="w-full px-3 py-2 rounded-md border border-gray-300 bg-white text-sm focus:ring-2 focus:ring-accent-light focus:outline-none" />
							</div>
							<button
								id="ship-calc"
								type="button"
								class="mt-3 w-full px-4 py-2.5 rounded-md text-sm font-semibold text-accent-main border border-accent-main hover:bg-accent-soft transition disabled:opacity-60"
							>
								Cotizar despacho
							</button>
							<p id="ship-result" class="mt-2 text-xs text-gray-500 hidden"></p>
							<p class="mt-2 text-[0.7rem] text-gray-400 flex items-center gap-1">
								<span>🚚</span> Despacho a domicilio con Starken desde Santiago.
							</p>
						</div>

						<div class="flex justify-between text-sm text-gray-600 mb-2">
							<span>Subtotal</span>
							<span id="cart-subtotal">$0</span>
						</div>
						<div class="flex justify-between text-sm text-gray-600 mb-4">
							<span>Despacho</span>
							<span id="cart-shipping" class="text-gray-400">Por calcular</span>
						</div>
						<div class="flex justify-between text-lg font-extrabold text-gray-900 border-t border-gray-200 pt-4">
							<span>Total</span>
							<span id="cart-total">$0</span>
						</div>

						<button
							id="checkout-btn"
							type="button"
							class="mt-6 w-full px-6 py-3.5 rounded-md text-base font-semibold text-white bg-accent-main hover:bg-accent-hover transition duration-200 disabled:opacity-60"
						>
							Pagar con Mercado Pago
						</button>
						<p id="checkout-msg" class="mt-3 text-center text-sm text-red-500 hidden"></p>

						<div class="mt-4 flex items-center justify-center gap-2 text-xs text-gray-400">
							<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
							Pago seguro mediante Mercado Pago
						</div>
					</div>
				</aside>
			</div>
		</div>
	</section>
</Layout>

<script is:inline>
	function initCartPage() {
		const Cart = window.MizoCart;
		const empty = document.getElementById('cart-empty');
		const content = document.getElementById('cart-content');
		const list = document.getElementById('cart-items');
		if (!Cart || !list) return;

		const fmt = (n) => '$' + Number(n).toLocaleString('es-CL');
		const DELIVERY_KEY = 'mizo-delivery';
		const QUOTE_KEY = 'mizo-ship-quote';

		const fields = {
			name: document.getElementById('ship-name'),
			phone: document.getElementById('ship-phone'),
			email: document.getElementById('ship-email'),
			region: document.getElementById('ship-region'),
			comuna: document.getElementById('ship-comuna'),
			address: document.getElementById('ship-address'),
			reference: document.getElementById('ship-reference'),
		};
		const calcBtn = document.getElementById('ship-calc');
		const shipResult = document.getElementById('ship-result');
		const shipRow = document.getElementById('cart-shipping');

		const loadJson = (key) => {
			try { return JSON.parse(localStorage.getItem(key)) || null; } catch (e) { return null; }
		};

		// Datos de despacho del cliente (persisten aunque cambie el carrito).
		let delivery = loadJson(DELIVERY_KEY) || {};
		// Cotización vigente (solo válida si coincide peso/cantidad del carrito).
		let quote = loadJson(QUOTE_KEY);

		const regionNames = {};
		if (fields.region) {
			for (const opt of fields.region.options) {
				if (opt.value) regionNames[opt.value] = opt.textContent;
			}
		}

		function readDeliveryFromForm() {
			return {
				name: (fields.name?.value || '').trim(),
				phone: (fields.phone?.value || '').trim(),
				email: (fields.email?.value || '').trim(),
				region: fields.region?.value || '',
				regionName: regionNames[fields.region?.value] || '',
				comuna: (fields.comuna?.value || '').trim(),
				address: (fields.address?.value || '').trim(),
				reference: (fields.reference?.value || '').trim(),
			};
		}

		function saveDelivery() {
			delivery = readDeliveryFromForm();
			localStorage.setItem(DELIVERY_KEY, JSON.stringify(delivery));
		}

		function fillDeliveryForm() {
			if (fields.name) fields.name.value = delivery.name || '';
			if (fields.phone) fields.phone.value = delivery.phone || '';
			if (fields.email) fields.email.value = delivery.email || '';
			if (fields.region) fields.region.value = delivery.region || '';
			if (fields.comuna) fields.comuna.value = delivery.comuna || '';
			if (fields.address) fields.address.value = delivery.address || '';
			if (fields.reference) fields.reference.value = delivery.reference || '';
		}

		function saveQuote() {
			if (quote) localStorage.setItem(QUOTE_KEY, JSON.stringify(quote));
			else localStorage.removeItem(QUOTE_KEY);
		}

		function isQuoteValid() {
			if (!quote || typeof quote.cost !== 'number') return false;
			return quote.cartWeight === Cart.weight() && quote.cartCount === Cart.count();
		}

		function invalidateQuote(message) {
			quote = null;
			saveQuote();
			if (shipResult && message) {
				shipResult.textContent = message;
				shipResult.className = 'mt-2 text-xs text-amber-600 font-medium';
				shipResult.classList.remove('hidden');
			}
		}

		function validateDelivery(forQuote) {
			saveDelivery();
			const missing = [];
			if (!delivery.name) missing.push('nombre');
			if (!delivery.phone) missing.push('teléfono');
			if (!delivery.email) missing.push('correo');
			if (!delivery.region) missing.push('región');
			if (!forQuote) {
				if (!delivery.comuna) missing.push('comuna');
				if (!delivery.address) missing.push('dirección');
			}
			if (missing.length) {
				return 'Completa: ' + missing.join(', ') + '.';
			}
			if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(delivery.email)) {
				return 'Ingresa un correo válido.';
			}
			if (delivery.phone.replace(/\D/g, '').length < 8) {
				return 'Ingresa un teléfono válido.';
			}
			return null;
		}

		fillDeliveryForm();
		if (quote && !isQuoteValid()) {
			quote = null;
			saveQuote();
		}

		Object.values(fields).forEach((el) => {
			if (!el) return;
			el.addEventListener('input', saveDelivery);
			el.addEventListener('change', () => {
				saveDelivery();
				if (quote && el === fields.region) {
					invalidateQuote('Cambiaste la región. Vuelve a cotizar el despacho.');
					render();
				}
			});
		});

		async function quoteShip() {
			const err = validateDelivery(true);
			if (err) {
				shipResult.textContent = err;
				shipResult.className = 'mt-2 text-xs text-red-500';
				shipResult.classList.remove('hidden');
				return;
			}
			calcBtn.disabled = true;
			calcBtn.textContent = 'Cotizando…';
			shipResult.classList.remove('hidden');
			try {
				const res = await fetch('/cotizar-envio.php', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ region: delivery.region, weightKg: Cart.weight() }),
				});
				const data = await res.json();
				if (!res.ok || !data.ok) throw new Error(data.error || 'No se pudo cotizar.');
				quote = {
					cost: data.cost,
					etaText: data.etaText,
					cartWeight: Cart.weight(),
					cartCount: Cart.count(),
				};
				saveQuote();
				delivery.regionName = data.regionName;
				saveDelivery();
				shipResult.textContent = `${data.regionName}: ${fmt(data.cost)} · Entrega aprox. ${data.etaText}.`;
				shipResult.className = 'mt-2 text-xs text-green-600';
				render();
			} catch (e) {
				invalidateQuote(e.message + ' Intenta de nuevo.');
				render();
			} finally {
				calcBtn.disabled = false;
				calcBtn.textContent = 'Cotizar despacho';
			}
		}

		if (calcBtn) calcBtn.onclick = quoteShip;

		function render() {
			const items = Cart.items();
			if (!items.length) {
				empty.classList.remove('hidden');
				content.classList.add('hidden');
				content.classList.remove('grid');
				return;
			}
			empty.classList.add('hidden');
			content.classList.remove('hidden');
			content.classList.add('grid');

			list.innerHTML = items.map((i) => `
				<li class="flex gap-4 py-5 items-center">
					<a href="/productos/${i.id}" class="flex-shrink-0 w-20 h-20 bg-white border border-gray-100 rounded-lg flex items-center justify-center p-1">
						<img src="${i.image}" alt="${i.name}" class="max-h-full max-w-full object-contain mix-blend-multiply" onerror="this.style.display='none'"/>
					</a>
					<div class="flex-grow min-w-0">
						<a href="/productos/${i.id}" class="block font-semibold text-gray-900 text-sm leading-snug hover:text-accent-main line-clamp-2">${i.name}</a>
						<p class="text-sm text-gray-500 mt-1">${fmt(i.price)} c/u</p>
						<div class="flex items-center gap-2 mt-2">
							<button data-dec="${i.id}" class="w-7 h-7 rounded border border-gray-300 text-gray-600 hover:border-accent-main hover:text-accent-main font-bold leading-none">−</button>
							<span class="w-8 text-center text-sm font-semibold">${i.qty}</span>
							<button data-inc="${i.id}" class="w-7 h-7 rounded border border-gray-300 text-gray-600 hover:border-accent-main hover:text-accent-main font-bold leading-none">+</button>
						</div>
					</div>
					<div class="flex flex-col items-end gap-2">
						<span class="font-bold text-gray-900">${fmt(i.price * i.qty)}</span>
						<button data-del="${i.id}" class="text-xs text-gray-400 hover:text-red-500">Quitar</button>
					</div>
				</li>
			`).join('');

			const subtotal = Cart.subtotal();
			document.getElementById('cart-subtotal').textContent = fmt(subtotal);

			const validQuote = isQuoteValid();
			if (validQuote) {
				shipRow.textContent = fmt(quote.cost);
				shipRow.className = 'text-gray-900 font-medium';
				if (shipResult && delivery.regionName) {
					shipResult.textContent = `${delivery.regionName}: ${fmt(quote.cost)} · Entrega aprox. ${quote.etaText}.`;
					shipResult.className = 'mt-2 text-xs text-green-600';
					shipResult.classList.remove('hidden');
				}
			} else {
				shipRow.textContent = 'Por calcular';
				shipRow.className = 'text-gray-400';
			}

			const total = subtotal + (validQuote ? quote.cost : 0);
			document.getElementById('cart-total').textContent = fmt(total);
		}

		list.onclick = (ev) => {
			const inc = ev.target.closest('[data-inc]');
			const dec = ev.target.closest('[data-dec]');
			const del = ev.target.closest('[data-del]');
			const items = Cart.items();
			if (inc) {
				const it = items.find((i) => i.id === inc.dataset.inc);
				Cart.setQty(inc.dataset.inc, (it ? it.qty : 0) + 1);
			} else if (dec) {
				const it = items.find((i) => i.id === dec.dataset.dec);
				Cart.setQty(dec.dataset.dec, (it ? it.qty : 0) - 1);
			} else if (del) {
				Cart.remove(del.dataset.del);
			}
		};

		const clearBtn = document.getElementById('cart-clear');
		if (clearBtn) clearBtn.onclick = () => {
			if (confirm('¿Vaciar el carrito?')) {
				Cart.clear();
				localStorage.removeItem(DELIVERY_KEY);
				localStorage.removeItem(QUOTE_KEY);
				delivery = {};
				quote = null;
				fillDeliveryForm();
			}
		};

		const checkoutBtn = document.getElementById('checkout-btn');
		const msg = document.getElementById('checkout-msg');
		if (checkoutBtn) {
			checkoutBtn.onclick = async () => {
				const items = Cart.items();
				if (!items.length) return;
				msg.classList.add('hidden');

				const deliveryErr = validateDelivery(false);
				if (deliveryErr) {
					msg.textContent = deliveryErr;
					msg.classList.remove('hidden');
					return;
				}
				if (!isQuoteValid()) {
					msg.textContent = 'El carrito cambió. Vuelve a pulsar "Cotizar despacho" antes de pagar.';
					msg.classList.remove('hidden');
					if (calcBtn) calcBtn.focus();
					return;
				}

				checkoutBtn.disabled = true;
				checkoutBtn.textContent = 'Generando pago...';
				try {
					const res = await fetch('/crear-preferencia.php', {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({
							items: items.map((i) => ({
								id: i.id,
								title: i.name,
								quantity: i.qty,
								unit_price: i.price,
							})),
							shipping: { cost: quote.cost, region: delivery.regionName },
							delivery,
						}),
					});
					const data = await res.json().catch(() => null);
					if (!res.ok) throw new Error((data && data.error) || 'No se pudo iniciar el pago (' + res.status + ')');
					if (data.init_point) {
						window.location.href = data.init_point;
					} else {
						throw new Error('Respuesta inválida del servidor de pago.');
					}
				} catch (err) {
					msg.textContent = err.message + ' Intenta nuevamente o contáctanos por WhatsApp.';
					msg.classList.remove('hidden');
					checkoutBtn.disabled = false;
					checkoutBtn.textContent = 'Pagar con Mercado Pago';
				}
			};
		}

		const onCartUpdated = () => {
			quote = loadJson(QUOTE_KEY);
			if (!isQuoteValid()) {
				invalidateQuote('El carrito cambió. Vuelve a cotizar el despacho (tus datos de envío se mantienen).');
			}
			render();
		};
		if (window.__mizoCartPageHandler) document.removeEventListener('cart:updated', window.__mizoCartPageHandler);
		window.__mizoCartPageHandler = onCartUpdated;
		document.addEventListener('cart:updated', onCartUpdated);
		render();
	}

	document.addEventListener('DOMContentLoaded', initCartPage);
	document.addEventListener('astro:page-load', initCartPage);
</script>
