---
import Layout from '../layouts/Layout.astro';
import HeroCarousel from '../components/HeroCarousel.astro';
import ProjectsSection from '../components/ProjectsSection.astro';
import Brands from '../components/Brands.astro';
import ShowcasePreview from '../components/ShowcasePreview.astro';

const heroSlides = [
	{
		image: 'https://images.unsplash.com/photo-1580582932707-520aed937b7b?auto=format&fit=crop&w=1600&q=80',
		alt: 'Sala de clases equipada con proyector y sistema de audio',
		tag: 'Educación',
		title: 'Aulas y salas de clases con proyección y sonido claro',
		desc: 'Instalamos proyectores, pantallas, amplificación y control para que profesores y alumnos escuchen y vean sin complicaciones.',
		detail: 'Proyectores láser, pantallas motorizadas, micrófonos inalámbricos y cableado oculto.',
	},
	{
		image: 'https://images.unsplash.com/photo-1438232999611-9952fec585c0?auto=format&fit=crop&w=1600&q=80',
		alt: 'Interior de iglesia con sistema de sonido profesional',
		tag: 'Iglesias y templos',
		title: 'Sistemas de sonido para cultos y eventos en vivo',
		desc: 'Diseñamos cobertura uniforme en naves amplias: voces inteligibles, música equilibrada y operación sencilla para el equipo técnico.',
		detail: 'Parlantes de columna, mezcladores digitales, monitoreo y zonas de audio.',
	},
	{
		image: 'https://images.unsplash.com/photo-1507901747481-84a4f64fda6d?auto=format&fit=crop&w=1600&q=80',
		alt: 'Auditorio con escenario, proyección y sistema de sonido',
		tag: 'Auditorios',
		title: 'Auditorios con proyección láser y audio distribuido',
		desc: 'Trabajamos la acústica del recinto, la proyección de gran formato y la microfonía para presentaciones, conciertos y conferencias.',
		detail: 'Proyección 4K/láser, line array, consola digital y cabina técnica.',
	},
	{
		image: 'https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?auto=format&fit=crop&w=1600&q=80',
		alt: 'Restaurante con ambientación musical y pantallas',
		tag: 'Restaurantes y retail',
		title: 'Ambientación sonora y pantallas para locales comerciales',
		desc: 'Música por zonas, pantallas para menú o branding y control centralizado para operar el local día a día.',
		detail: 'Audio multizona, streaming, pantallas comerciales y soporte remoto.',
	},
];

const services = [
	{
		title: 'Sistemas de sonido',
		desc: 'Diseño acústico, selección de equipos, instalación y calibración para salas, auditorios, iglesias y espacios comerciales.',
		items: ['Parlantes activos y pasivos', 'Amplificación y procesamiento DSP', 'Microfonía inalámbrica', 'Medición y ecualización'],
	},
	{
		title: 'Videoproyección y salas AV',
		desc: 'Proyectores, pantallas, videoconferencia y control integrado para reuniones, capacitaciones y presentaciones.',
		items: ['Proyectores láser y LED', 'Pantallas y soportes', 'Matrices HDMI y extensores', 'Control por tablet o botonera'],
	},
	{
		title: 'Infraestructura e instalación',
		desc: 'Canalización, cableado estructurado, soportería y terminaciones prolijas que sostienen el sistema en el tiempo.',
		items: ['Canalización técnica oculta', 'Montaje de proyectores y pantallas', 'Patching y etiquetado', 'Pruebas y documentación'],
	},
	{
		title: 'Soporte y mantención',
		desc: 'Acompañamos después de la entrega: ajustes, ampliaciones y respuesta cuando el sistema lo necesita.',
		items: ['Capacitación de operadores', 'Mantención preventiva', 'Ampliación de zonas', 'Atención en terreno y remota'],
	},
];

const processSteps = [
	'Visita al recinto: medidas, uso del espacio y restricciones técnicas.',
	'Propuesta técnica con equipos, planos de instalación y presupuesto.',
	'Ejecución en terreno con cableado oculto y montaje certificado.',
	'Pruebas, calibración, capacitación y entrega documentada.',
];
---

<Layout
	title="Mizo | Ingeniería e instalación de audio y videoproyección"
	description="Diseñamos e instalamos sistemas de sonido, videoproyección y salas audiovisuales para colegios, iglesias, auditorios, restaurantes y empresas en Chile."
>
	<HeroCarousel slides={heroSlides} />

	<section class="border-b border-gray-200 bg-white py-14">
		<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
			<div class="grid gap-8 lg:grid-cols-[1fr_1.2fr] lg:items-center">
				<div>
					<p class="text-xs font-bold uppercase tracking-[0.2em] text-accent-main">Quiénes somos</p>
					<h2 class="mt-3 text-3xl font-black text-ink md:text-4xl">
						Proyectos de audio y video hechos para operar todos los días
					</h2>
					<p class="mt-4 text-base leading-relaxed text-gray-600">
						En Mizo llevamos más de una década instalando sistemas de sonido y videoproyección en Chile. No vendemos cajas sueltas: diseñamos la solución completa, la montamos en terreno y la dejamos calibrada para quien la va a usar.
					</p>
					<p class="mt-3 text-base leading-relaxed text-gray-600">
						Trabajamos con colegios, iglesias, auditorios, restaurantes, empresas e industria. Cada proyecto parte por entender el espacio, no por empujar un catálogo.
					</p>
				</div>
				<div class="grid grid-cols-2 gap-4">
					<div class="rounded-xl border border-gray-200 bg-gray-50 p-5">
						<p class="text-3xl font-black text-brand-orange">+120</p>
						<p class="mt-1 text-sm font-semibold text-gray-700">Proyectos instalados</p>
					</div>
					<div class="rounded-xl border border-gray-200 bg-gray-50 p-5">
						<p class="text-3xl font-black text-accent-main">4</p>
						<p class="mt-1 text-sm font-semibold text-gray-700">Rubros principales</p>
					</div>
					<div class="rounded-xl border border-gray-200 bg-gray-50 p-5">
						<p class="text-3xl font-black text-brand-orange">2</p>
						<p class="mt-1 text-sm font-semibold text-gray-700">Bases: Frutillar y Santiago</p>
					</div>
					<div class="rounded-xl border border-gray-200 bg-gray-50 p-5">
						<p class="text-3xl font-black text-accent-main">1</p>
						<p class="mt-1 text-sm font-semibold text-gray-700">Equipo técnico propio</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="bg-charcoal py-16 text-white">
		<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
			<div class="max-w-2xl">
				<p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-orange">Servicios</p>
				<h2 class="mt-3 text-3xl font-black md:text-4xl">Lo que hacemos en cada proyecto</h2>
				<p class="mt-4 text-base leading-relaxed text-gray-400">
					Desde la primera visita técnica hasta la entrega final. Estos son los frentes donde más trabajamos.
				</p>
			</div>
			<div class="mt-10 grid gap-5 md:grid-cols-2">
				{services.map((service) => (
					<article class="rounded-2xl border border-charcoal-muted bg-charcoal-light p-6">
						<h3 class="text-xl font-black text-white">{service.title}</h3>
						<p class="mt-3 text-sm leading-relaxed text-gray-400">{service.desc}</p>
						<ul class="mt-4 space-y-2">
							{service.items.map((item) => (
								<li class="flex items-start gap-2 text-sm text-gray-300">
									<span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-accent-main"></span>
									{item}
								</li>
							))}
						</ul>
					</article>
				))}
			</div>
			<div class="mt-8 text-center">
				<a href="/servicios" class="inline-flex rounded-md border border-white/20 px-6 py-3 text-sm font-bold text-white transition hover:border-accent-main hover:text-accent-light">
					Ver detalle de servicios
				</a>
			</div>
		</div>
	</section>

	<ProjectsSection />

	<section class="border-y border-gray-200 bg-gray-50 py-16">
		<div class="mx-auto grid max-w-7xl gap-10 px-4 sm:px-6 lg:grid-cols-[0.9fr_1.1fr] lg:items-center lg:px-8">
			<div>
				<p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-orange">Cómo trabajamos</p>
				<h2 class="mt-3 text-3xl font-black text-ink md:text-4xl">De la visita técnica a la entrega</h2>
				<p class="mt-4 text-base leading-relaxed text-gray-600">
					Sin pasos innecesarios. Un ingeniero revisa cada propuesta antes de comprometer equipos y fechas.
				</p>
				<a href="/contacto" class="mt-7 inline-flex rounded-md bg-accent-main px-6 py-3 text-sm font-bold text-white transition hover:bg-accent-hover">
					Agendar visita técnica
				</a>
			</div>
			<div class="grid gap-3">
				{processSteps.map((step, index) => (
					<div class="flex gap-4 rounded-xl border border-gray-200 bg-white p-5">
						<span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-charcoal text-sm font-black text-brand-orange">{index + 1}</span>
						<p class="self-center text-sm font-semibold leading-relaxed text-gray-800">{step}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<Brands />

	<ShowcasePreview />

	<section class="bg-charcoal py-16 text-white">
		<div class="mx-auto max-w-7xl px-4 text-center sm:px-6 lg:px-8">
			<p class="text-xs font-bold uppercase tracking-[0.2em] text-accent-main">Contacto</p>
			<h2 class="mt-3 text-3xl font-black md:text-4xl">Cuéntanos tu proyecto y te respondemos con una propuesta</h2>
			<p class="mx-auto mt-4 max-w-xl text-base text-gray-400">
				Llámanos, escríbenos o agenda una visita. Revisamos el recinto y te devolvemos una cotización con equipos y plazos.
			</p>
			<div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
				<a href="tel:+56994390870" class="rounded-md bg-white px-6 py-3 text-sm font-bold text-ink transition hover:bg-gray-100">+56 9 9439 0870</a>
				<a href="mailto:ventas@mizo.cl" class="rounded-md border border-white/20 px-6 py-3 text-sm font-bold text-white transition hover:border-accent-main">ventas@mizo.cl</a>
				<a href="https://wa.me/56994390870?text=Hola%20Mizo,%20necesito%20cotizar%20un%20proyecto%20de%20audio%20o%20videoproyecci%C3%B3n" target="_blank" rel="noopener noreferrer" class="rounded-md bg-brand-orange px-6 py-3 text-sm font-bold text-white transition hover:bg-brand-orange-hover">WhatsApp</a>
			</div>
		</div>
	</section>
</Layout>
