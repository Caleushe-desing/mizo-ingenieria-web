---
import Layout from '../layouts/Layout.astro';
import Brands from '../components/Brands.astro';

const contactCards = [
	{ label: 'Teléfono directo', value: '+56 9 9439 0870', href: 'tel:+56994390870' },
	{ label: 'Correo comercial', value: 'ventas@mizo.cl', href: 'mailto:ventas@mizo.cl' },
	{ label: 'WhatsApp ingeniería', value: 'Responder ahora', href: 'https://wa.me/56994390870?text=Hola%20Mizo,%20quiero%20configurar%20una%20soluci%C3%B3n%20audiovisual' },
];

const solutionAreas = [
	{
		title: 'Plantas industriales',
		desc: 'Audio de avisos, evacuación, zonas críticas y operación continua para entornos exigentes.',
		meta: 'Seguridad operacional',
	},
	{
		title: 'Salas de reuniones',
		desc: 'Videoconferencias claras, cámaras, micrófonos, pantallas y control simple para equipos híbridos.',
		meta: 'Colaboración corporativa',
	},
	{
		title: 'Auditorios',
		desc: 'Proyección, sonido distribuido, microfonía y calibración para alta inteligibilidad.',
		meta: 'Experiencia de alto impacto',
	},
	{
		title: 'Locales comerciales',
		desc: 'Música ambiental, pantallas, zonas de audio y experiencia de marca para clientes.',
		meta: 'Ambiente y conversión',
	},
];

const processSteps = [
	'Levantamos intención, entorno y dimensiones.',
	'Preparamos una pre-configuración técnica.',
	'Un ingeniero valida acústica, estructura y operación.',
	'Entregamos propuesta de solución corporativa.',
];

const fieldGallery = [
	{
		title: 'Auditorios y teatros',
		desc: 'Proyección láser, cobertura sonora, control técnico y acústica aplicada para alta concurrencia.',
		tag: 'Proyección + acústica',
		image: 'https://images.unsplash.com/photo-1507901747481-84a4f64fda6d?auto=format&fit=crop&w=1400&q=80',
	},
	{
		title: 'Plantas industriales',
		desc: 'Voceo IP, audio de evacuación, zonas operativas y continuidad para espacios críticos.',
		tag: 'Evacuación + voceo IP',
		image: 'https://images.unsplash.com/photo-1581093458791-9d09cc08742a?auto=format&fit=crop&w=1400&q=80',
	},
	{
		title: 'Proyecciones corporativas',
		desc: 'Salas limpias, videowall, pantallas LED y sistemas preparados para operación ejecutiva.',
		tag: 'Pantallas profesionales',
		image: 'https://images.unsplash.com/photo-1497366754035-f200968a6e72?auto=format&fit=crop&w=1400&q=80',
	},
];
---

<Layout
	title="Mizo | Soluciones de Ingeniería Audiovisual Corporativa"
	description="Diseña una solución audiovisual corporativa para tu espacio con la Aplicación Configuradora de Sistemas Audiovisuales de Mizo."
>
	<section class="relative overflow-hidden bg-slate-950 text-white">
		<div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(#0284c7 1px, transparent 1px); background-size: 26px 26px;"></div>
		<div class="absolute -right-24 top-12 h-80 w-80 rounded-full bg-[#0284c7]/30 blur-3xl"></div>
		<div class="absolute -bottom-28 left-12 h-72 w-72 rounded-full bg-cyan-400/20 blur-3xl"></div>

		<div class="relative mx-auto grid max-w-7xl gap-10 px-4 py-20 sm:px-6 lg:grid-cols-[1.05fr_0.95fr] lg:items-center lg:px-8 lg:py-28">
			<div>
				<span class="inline-flex rounded-full border border-white/15 bg-white/10 px-4 py-2 text-xs font-black uppercase tracking-[0.24em] text-cyan-100 backdrop-blur">
					Ingeniería audiovisual por intención de compra
				</span>
				<h1 class="mt-6 max-w-4xl text-4xl font-black leading-tight text-white md:text-6xl">
					¿Necesitas equipar tu espacio?
				</h1>
				<p class="mt-5 max-w-2xl text-lg leading-8 text-slate-300 md:text-xl">
					Usa nuestra Aplicación Configuradora de Sistemas Audiovisuales y diseña tu solución de nivel corporativo en 3 pasos.
				</p>
				<div class="mt-8 flex flex-col gap-3 sm:flex-row">
					<a href="/configurador" class="inline-flex items-center justify-center rounded-full bg-[#0284c7] px-7 py-4 text-sm font-black text-white shadow-xl shadow-sky-900/30 transition hover:-translate-y-0.5 hover:bg-sky-700">
						Abrir configurador audiovisual
					</a>
					<a href="https://wa.me/56994390870?text=Hola%20Mizo,%20necesito%20asesor%C3%ADa%20para%20equipar%20mi%20espacio" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center rounded-full border border-white/20 px-7 py-4 text-sm font-black text-white transition hover:bg-white/10">
						Hablar por WhatsApp
					</a>
				</div>

				<div class="mt-8 grid gap-3 sm:grid-cols-3">
					{contactCards.map((item) => (
						<a href={item.href} target={item.href.startsWith('http') ? '_blank' : undefined} rel={item.href.startsWith('http') ? 'noopener noreferrer' : undefined} class="rounded-2xl border border-white/10 bg-white/10 p-4 backdrop-blur transition hover:border-[#0284c7] hover:bg-[#0284c7]/20">
							<p class="text-xs font-black uppercase tracking-[0.18em] text-cyan-100">{item.label}</p>
							<p class="mt-1 text-sm font-bold text-white">{item.value}</p>
						</a>
					))}
				</div>
			</div>

			<div class="rounded-[2rem] border border-white/10 bg-white p-4 text-slate-950 shadow-2xl">
				<div class="rounded-[1.5rem] bg-slate-50 p-5">
					<div class="flex items-center justify-between">
						<p class="text-xs font-black uppercase tracking-[0.2em] text-[#0284c7]">Mizo Configurator</p>
						<span class="rounded-full bg-emerald-100 px-3 py-1 text-xs font-black text-emerald-700">Online</span>
					</div>
					<div class="mt-5 rounded-3xl bg-slate-950 p-5 text-white">
						<p class="text-sm font-bold text-cyan-100">Pre-configuración inteligente</p>
						<p class="mt-2 text-3xl font-black">Entorno + dimensión + propósito</p>
						<div class="mt-5 grid gap-3">
							{['Planta Industrial', 'Sala de Reuniones', 'Auditorio'].map((item, index) => (
								<div class={`rounded-2xl border px-4 py-3 ${index === 1 ? 'border-[#0284c7] bg-[#0284c7]/20' : 'border-white/10 bg-white/5'}`}>
									<p class="text-sm font-black">{item}</p>
									<p class="text-xs text-slate-300">Validación técnica por ingeniero Mizo</p>
								</div>
							))}
						</div>
					</div>
					<div class="mt-4 grid grid-cols-3 gap-3 text-center">
						<div class="rounded-2xl bg-white p-4 shadow-sm">
							<p class="text-2xl font-black text-[#0284c7]">3</p>
							<p class="text-xs font-bold text-slate-500">pasos</p>
						</div>
						<div class="rounded-2xl bg-white p-4 shadow-sm">
							<p class="text-2xl font-black text-[#0284c7]">2h</p>
							<p class="text-xs font-bold text-slate-500">contacto</p>
						</div>
						<div class="rounded-2xl bg-white p-4 shadow-sm">
							<p class="text-2xl font-black text-[#0284c7]">AV</p>
							<p class="text-xs font-bold text-slate-500">ingeniería</p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="bg-white py-16">
		<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
			<div class="max-w-3xl">
				<p class="text-xs font-black uppercase tracking-[0.22em] text-[#0284c7]">Soluciones por intención</p>
				<h2 class="mt-3 text-3xl font-black text-slate-950 md:text-5xl">No partimos por equipos. Partimos por el espacio, el uso y el resultado esperado.</h2>
			</div>
			<div class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-4">
				{solutionAreas.map((area) => (
					<article class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:border-[#0284c7] hover:shadow-xl">
						<p class="text-xs font-black uppercase tracking-[0.2em] text-[#0284c7]">{area.meta}</p>
						<h3 class="mt-4 text-2xl font-black text-slate-950">{area.title}</h3>
						<p class="mt-3 text-base leading-7 text-slate-600">{area.desc}</p>
					</article>
				))}
			</div>
		</div>
	</section>

	<section class="bg-slate-50 py-16">
		<div class="mx-auto grid max-w-7xl gap-10 px-4 sm:px-6 lg:grid-cols-[0.9fr_1.1fr] lg:items-center lg:px-8">
			<div>
				<p class="text-xs font-black uppercase tracking-[0.22em] text-[#0284c7]">Proceso Mizo</p>
				<h2 class="mt-3 text-3xl font-black text-slate-950 md:text-5xl">Diseño guiado, validación humana y propuesta técnica.</h2>
				<p class="mt-4 text-lg leading-8 text-slate-600">
					La aplicación acelera el diagnóstico comercial, pero la decisión final la valida un ingeniero considerando acústica, estructura, cableado y operación real.
				</p>
				<a href="/configurador" class="mt-7 inline-flex rounded-full bg-[#0284c7] px-7 py-4 text-sm font-black text-white shadow-lg transition hover:bg-sky-700">
					Configurar mi solución
				</a>
			</div>
			<div class="grid gap-4">
				{processSteps.map((step, index) => (
					<div class="flex gap-4 rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">
						<span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-[#0284c7] text-sm font-black text-white">{index + 1}</span>
						<p class="self-center text-lg font-bold text-slate-800">{step}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<section class="bg-white py-16">
		<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
			<div class="mb-10 flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
				<div class="max-w-3xl">
					<p class="text-xs font-black uppercase tracking-[0.22em] text-[#0284c7]">Soluciones de Ingeniería en Terreno</p>
					<h2 class="mt-3 text-3xl font-black text-slate-950 md:text-5xl">Implementaciones visuales, limpias y preparadas para operación profesional.</h2>
				</div>
				<a href="/configurador" class="inline-flex rounded-full bg-[#0284c7] px-6 py-3 text-sm font-black text-white shadow-lg transition hover:bg-sky-700">
					Iniciar diagnóstico
				</a>
			</div>

			<div class="grid gap-5 lg:grid-cols-3">
				{fieldGallery.map((item, index) => (
					<article class={`group relative overflow-hidden rounded-[2rem] bg-slate-950 shadow-xl ${index === 0 ? 'lg:col-span-2' : ''}`}>
						<img src={item.image} alt={item.title} class="h-80 w-full object-cover opacity-75 transition duration-500 group-hover:scale-105 group-hover:opacity-90" loading="lazy" width="1400" height="900" />
						<div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/35 to-transparent"></div>
						<div class="absolute bottom-0 left-0 right-0 p-6 text-white">
							<span class="inline-flex rounded-full bg-[#0284c7] px-3 py-1 text-[0.65rem] font-black uppercase tracking-[0.18em] text-white">{item.tag}</span>
							<h3 class="mt-4 text-3xl font-black text-white">{item.title}</h3>
							<p class="mt-2 max-w-xl text-sm leading-6 text-white/80">{item.desc}</p>
						</div>
					</article>
				))}
			</div>
		</div>
	</section>

	<Brands />

	<section class="bg-slate-950 py-16 text-white">
		<div class="mx-auto max-w-7xl px-4 text-center sm:px-6 lg:px-8">
			<p class="text-xs font-black uppercase tracking-[0.22em] text-cyan-200">Contacto comercial directo</p>
			<h2 class="mt-3 text-3xl font-black text-white md:text-5xl">Habla con Mizo antes de definir equipamiento.</h2>
			<div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
				<a href="tel:+56994390870" class="rounded-full bg-white px-6 py-3 text-sm font-black text-slate-950 transition hover:bg-cyan-50">+56 9 9439 0870</a>
				<a href="mailto:ventas@mizo.cl" class="rounded-full border border-white/20 px-6 py-3 text-sm font-black text-white transition hover:bg-white/10">ventas@mizo.cl</a>
				<a href="https://wa.me/56994390870?text=Hola%20Mizo,%20quiero%20dise%C3%B1ar%20una%20soluci%C3%B3n%20audiovisual" target="_blank" rel="noopener noreferrer" class="rounded-full bg-green-600 px-6 py-3 text-sm font-black text-white transition hover:bg-green-700">WhatsApp</a>
			</div>
		</div>
	</section>
</Layout>
