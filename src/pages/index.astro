---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
import ClientLogos from '../components/ClientLogos.astro'; // <--- IMPORTACIÓN NUEVA
---

<Layout title="Mizo Ingeniería | Ingeniería que Inspira Confianza" description="Mizo ofrece soluciones de desarrollo de software, integración de sistemas y consultoría Cloud para el sector industrial.">
    
    <section class="bg-gray-900 py-24 sm:py-32"> 
        <div class="max-w-8xl mx-auto px-4 sm:px-6 lg:px-8 text-center"> 
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-tight">
    Instalaciones que <span class="text-blue-500">Perduran.</span>
</h1>
            <p class="mt-4 text-xl text-gray-400 max-w-4xl mx-auto">
                Tecnología que Conecta. Ofrecemos soluciones integrales de instalaciones eléctricas, sistemas de seguridad, audio y software a medida para empresas y casas.
            </p>

            <div class="mt-10 flex flex-col sm:flex-row justify-center space-y-4 sm:space-y-0 sm:space-x-6">
                <a href="/servicios" class="px-8 py-3 text-lg font-medium rounded-md text-gray-900 bg-accent-main hover:bg-accent-hover transition duration-300 shadow-xl">
                    Ver Nuestros Servicios
                </a>
                <a href="/contacto" class="px-8 py-3 text-lg font-medium rounded-md text-accent-main bg-gray-800 hover:bg-gray-700 transition duration-300 border border-accent-main/50">
                    Hablemos de su Proyecto
                </a>
            </div>
        </div>
    </section>

    <section id="especialidades" class="bg-gray-800 py-20">
        <div class="max-w-8xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
           <h2 class="text-3xl lg:text-4xl font-bold text-white mb-10 border-b-4 border-blue-500 pb-2 inline-block">
    Nuestras Especialidades
</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-8">
                <Card 
                    title="Instalaciones Eléctricas"
                    description="Diseño y montaje de infraestructuras eléctricas seguras y eficientes, optimizando la distribución de potencia en entornos industriales."
                    icon="⚡"
                />
                <Card 
                    title="Sistemas de Audio Ambiental"
                    description="Implementación de soluciones de audio profesional y megafonía con zonificación inteligente para espacios comerciales y productivos."
                    icon="🎧"
                />
                <Card 
                    title="Cámaras de Seguridad y CCTV"
                    description="Vigilancia avanzada con sistemas CCTV e IP, ofreciendo monitoreo remoto y analíticas para seguridad y control de procesos."
                    icon="📹"
                />
                <Card 
                    title="Desarrollo de Software"
                    description="Creación de soluciones de software a medida (ERP/CRM) para automatizar la gestión y optimizar la toma de decisiones empresariales."
                    icon="💻"
                />
            </div>
        </div>
    </section>

    <section id="nosotros-cta" class="bg-gray-900 py-16">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
            <div>
                <h2 class="text-4xl font-extrabold text-white mb-4">Ingeniería que Inspira Confianza</h2>
                <p class="text-lg text-gray-400">
                    Mizo no solo construye proyectos; somos tu socio estratégico que garantiza **solidez, transparencia** y un enfoque que no encontrarás en otra firma.
                </p>
                <div class="mt-8">
                    <a href="/nosotros" class="px-6 py-3 border border-accent-main/50 text-base font-medium rounded-md text-accent-main hover:bg-accent-main hover:text-gray-900 transition duration-300">
                        Conozca Nuestra Filosofía
                    </a>
                </div>
            </div>
            
            <div class="bg-gray-800 h-64 rounded-xl flex items-center justify-center p-0 border border-gray-700 overflow-hidden">
                <img 
                    src="/mizo-confianza.jpg" 
                    alt="Diagrama que representa la integración de hardware y software en Mizo Ingeniería"
                    class="w-full h-full object-cover" 
                    loading="lazy" 
                    width="800"
                    height="600"
                />
            </div>
        </div>
    </section>

    <section id="contacto-final" class="bg-gray-800 py-20">
        <div class="max-w-8xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <h2 class="text-4xl font-bold text-white mb-4">¿Tiene un proyecto?</h2>
            <p class="text-xl text-gray-400 mb-8">
                Solicite una cotización hoy mismo para empezar a diseñar su solución a medida.
            </p>
            <a href="/contacto" class="inline-block px-10 py-4 text-xl font-bold rounded-md text-gray-900 bg-accent-main hover:bg-accent-hover transition duration-300 shadow-xl">
                Solicitar una Cotización Hoy
            </a>
        </div>
    </section>
    
    <ClientLogos /> </Layout>