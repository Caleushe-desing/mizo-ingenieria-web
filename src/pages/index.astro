---
import Layout from '../layouts/Layout.astro';
import ClientLogos from '../components/ClientLogos.astro';
import Brands from '../components/Brands.astro';

const audioCount = 'Catálogo MySQL';
const proyectorCount = 'Catálogo MySQL';
const camaraCount = 'Catálogo MySQL';

const heroSlides = [
	{
		kicker: 'Oferta de proyecto audiovisual',
		title: 'Transforma tu Auditorio',
		description: 'Proyectores láser de alto brillo con instalación, calibración certificada y capacitación de uso incluida.',
		price: 'Proyecto desde $2.490.000',
		cta: 'Cotizar Proyecto Aquí',
		url: '/contacto?tipo=auditorio-proyector-laser',
		badge: 'Proyector láser + ingeniería',
		accent: 'from-accent-dark via-accent-main to-cyan-500',
		image: 'https://images.unsplash.com/photo-1497366754035-f200968a6e72?auto=format&fit=crop&w=900&q=80',
		imageAlt: 'Auditorio corporativo equipado con proyección profesional',
		visualTitle: 'Proyección láser calibrada',
		visualDetail: 'Brillo, tiro, pantalla y control ajustados para tu sala.',
	},
	{
		kicker: 'Audio profesional instalado',
		title: 'Sonido claro para salas, iglesias y eventos',
		description: 'Parlantes, amplificación, zonificación y ajuste acústico para que el sistema quede listo para operar.',
		price: 'Diseño + instalación desde $1.290.000',
		cta: 'Diseñar mi Sistema',
		url: '/contacto?tipo=audio-profesional',
		badge: 'Audio calibrado',
		accent: 'from-slate-950 via-gray-800 to-accent-main',
		image: 'https://images.unsplash.com/photo-1516280440614-37939bbacd81?auto=format&fit=crop&w=900&q=80',
		imageAlt: 'Sistema de audio profesional preparado para calibración',
		visualTitle: 'Cobertura sonora homogénea',
		visualDetail: 'Diseño acústico, potencia y zonas sin puntos ciegos.',
	},
	{
		kicker: 'Domótica y control',
		title: 'Controla imagen, sonido e iluminación',
		description: 'Soluciones integradas para salas premium, home cinema y espacios corporativos con soporte técnico en Chile.',
		price: 'Integración desde $890.000',
		cta: 'Cotizar Integración',
		url: '/contacto?tipo=domotica-audiovisual',
		badge: 'Llave en mano',
		accent: 'from-indigo-950 via-accent-dark to-emerald-500',
		image: 'https://images.unsplash.com/photo-1558002038-1055907df827?auto=format&fit=crop&w=900&q=80',
		imageAlt: 'Control domótico integrado para sala audiovisual',
		visualTitle: 'Escenas y operación simple',
		visualDetail: 'Un solo flujo para audio, video, iluminación y soporte.',
	},
];

const categoryTiles = [
	{ title: 'Audio Profesional', countLabel: audioCount, icon: '🔊', url: '/productos', desc: 'Cajas activas, line array, parlantes de muro y sonido distribuido' },
	{ title: 'Proyectores', countLabel: proyectorCount, icon: '📽️', url: '/productos', desc: 'Proyección para auditorios, salas de reunión y home cinema' },
	{ title: 'Domótica', countLabel: 'Proyectos a medida', icon: '🏠', url: '/productos', desc: 'Control integrado de audio, video, iluminación y escenas' },
	{ title: 'Seguridad', countLabel: camaraCount, icon: '📹', url: '/productos', desc: 'Cámaras, monitoreo y videovigilancia conectada' },
];

const fallbackSolutionPacks = [
	{
		etiqueta: 'LLAVE EN MANO',
		titulo: 'Pack Sala de Reuniones Premium',
		descripcion: 'Audio, proyección, cableado, montaje y configuración para entregar una sala lista para operar.',
		ideal_para: 'Oficinas, directorios y salas híbridas',
	},
	{
		etiqueta: 'ALTA DEMANDA',
		titulo: 'Pack Auditorio Láser Pro',
		descripcion: 'Proyección de alto brillo, audio distribuido e instalación profesional para espacios de alta concurrencia.',
		ideal_para: 'Colegios, auditorios, iglesias y centros de eventos',
	},
	{
		etiqueta: 'EXPERIENCIA PREMIUM',
		titulo: 'Pack Home Cinema Inmersivo',
		descripcion: 'Imagen, sonido envolvente, soportes, cableado y calibración para una experiencia audiovisual completa.',
		ideal_para: 'Casas, quinchos y salas privadas',
	},
];

const engineeringServices = [
	{
		title: 'Diseño acústico y cobertura',
		desc: 'Modelamos potencia, dispersión, zonas y puntos de escucha para que el sistema sea inteligible y estable.',
		meta: 'Audio profesional',
	},
	{
		title: 'Canalización y cableado oculto',
		desc: 'Trazados limpios, etiquetado, pasadas técnicas y terminaciones pensadas para mantenimiento real.',
		meta: 'Infraestructura AV',
	},
	{
		title: 'Soportería pesada y montaje',
		desc: 'Anclajes, soportes, pantallas, proyectores y parlantes instalados con criterio estructural.',
		meta: 'Montaje certificado',
	},
	{
		title: 'Calibración de audio y proyección láser',
		desc: 'Ajuste fino de niveles, imagen, geometría, escenas de operación y capacitación al usuario final.',
		meta: 'Puesta en marcha',
	},
];

const trust = [
	{ icon: '🚚', title: 'Despacho a todo Chile', desc: 'Coordinamos la entrega' },
	{ icon: '🛠️', title: 'Instalación profesional', desc: 'Sonido y proyección' },
	{ icon: '✅', title: 'Equipos originales', desc: 'Marcas reconocidas' },
	{ icon: '🔒', title: 'Pago seguro', desc: 'Mercado Pago' },
];
---

<Layout
	title="Mizo | Tienda de Audio y Video + Instalación Profesional"
	description="Compra parlantes, proyectores y cámaras en Chile, con instalación profesional de sistemas de sonido y proyección. Equipos originales, despacho y pago seguro."
>
	<!-- HERO MARKETPLACE: BANNERS QUE VENDEN PROYECTOS -->
	<section class="relative overflow-hidden bg-slate-100 py-8 sm:py-10">
		<div class="absolute inset-0 opacity-[0.06]" style="background-image: radial-gradient(#15616d 1.2px, transparent 1.2px); background-size: 22px 22px;"></div>
		<div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="grid grid-cols-1 lg:grid-cols-[1fr_320px] gap-5">
				<div class="hero-carousel" aria-label="Ofertas de proyectos audiovisuales">
					{heroSlides.map((slide, index) => (
						<article id={`hero-slide-${index + 1}`} class={`hero-slide bg-gradient-to-br ${slide.accent}`}>
							<div class="relative z-10 max-w-2xl">
								<span class="inline-flex rounded-full bg-white/15 px-3 py-1 text-xs font-black uppercase tracking-[0.18em] text-white backdrop-blur">
									{slide.kicker}
								</span>
								<h1 class="mt-5 text-4xl md:text-5xl lg:text-6xl font-black leading-tight text-white">
									{slide.title}
								</h1>
								<p class="mt-4 text-lg text-white/85 md:text-xl">{slide.description}</p>
								<div class="mt-6 flex flex-col gap-3 sm:flex-row sm:items-center">
									<a href={slide.url} class="inline-flex items-center justify-center rounded-full bg-amber-300 px-6 py-3 text-sm font-black text-gray-950 shadow-lg transition hover:bg-amber-200">
										{slide.cta}
									</a>
									<span class="text-sm font-bold text-white/90">{slide.price}</span>
								</div>
							</div>

							<div class="hero-product-card" aria-hidden="true">
								<div class="overflow-hidden rounded-3xl bg-white/95 p-3 shadow-2xl backdrop-blur">
									<div class="relative h-56 overflow-hidden rounded-2xl bg-slate-900">
										<img
											src={slide.image}
											alt={slide.imageAlt}
											class="h-full w-full object-cover"
											loading={index === 0 ? 'eager' : 'lazy'}
											width="900"
											height="620"
										/>
										<div class="absolute inset-0 bg-gradient-to-t from-slate-950/85 via-slate-950/20 to-transparent"></div>
										<div class="absolute bottom-0 left-0 right-0 p-4 text-white">
											<p class="text-[0.65rem] font-black uppercase tracking-[0.18em] text-amber-300">{slide.badge}</p>
											<p class="mt-1 text-xl font-black leading-tight">{slide.visualTitle}</p>
										</div>
									</div>
									<div class="mt-3 rounded-2xl border border-slate-200 bg-slate-50 p-4">
										<p class="text-sm font-bold leading-snug text-slate-700">{slide.visualDetail}</p>
										<p class="mt-3 inline-flex rounded-full bg-amber-300 px-3 py-1 text-xs font-black text-gray-950">
											Instalación y calibración profesional
										</p>
									</div>
								</div>
							</div>
						</article>
					))}
				</div>

				<aside class="grid gap-5">
					<div class="rounded-3xl border border-gray-200 bg-white p-6 shadow-sm">
						<p class="text-xs font-black uppercase tracking-[0.18em] text-accent-main">Compra inteligente</p>
						<h2 class="mt-3 text-2xl font-black text-gray-950">Equipo + diseño + montaje</h2>
						<p class="mt-2 text-sm text-gray-600">
							El precio del producto te orienta. La cotización real optimiza el sistema completo para tu espacio.
						</p>
						<a href="/servicios" class="mt-5 inline-flex rounded-full bg-accent-main px-5 py-2.5 text-sm font-black text-white transition hover:bg-accent-hover">
							Ver ingeniería Mizo
						</a>
					</div>
					<div class="rounded-3xl bg-gray-950 p-6 text-white shadow-sm">
						<p class="text-sm font-bold text-amber-300">Asesoría en todo Chile</p>
						<p class="mt-2 text-3xl font-black">Cotiza antes de comprar mal.</p>
						<p class="mt-2 text-sm text-white/70">Te ayudamos a elegir brillo, potencia, cobertura, cableado y ubicación correcta.</p>
					</div>
				</aside>
			</div>

			<div class="mt-4 flex justify-center gap-2" aria-label="Navegación de banners">
				{heroSlides.map((_, index) => (
					<a href={`#hero-slide-${index + 1}`} class="h-2.5 w-8 rounded-full bg-accent-main/30 transition hover:bg-accent-main">
						<span class="sr-only">Ver banner {index + 1}</span>
					</a>
				))}
			</div>
		</div>
	</section>

	<!-- BARRA DE CONFIANZA -->
	<section class="bg-white border-y border-gray-100">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 grid grid-cols-2 lg:grid-cols-4 gap-6">
			{trust.map((t) => (
				<div class="flex items-center gap-3">
					<span class="text-2xl">{t.icon}</span>
					<div>
						<p class="text-sm font-bold text-gray-900 leading-tight">{t.title}</p>
						<p class="text-xs text-gray-500">{t.desc}</p>
					</div>
				</div>
			))}
		</div>
	</section>

	<!-- CATEGORÍAS -->
	<section class="bg-white py-16">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-10">
				<h2 class="text-3xl lg:text-4xl font-bold text-gray-900">Explora por categoría</h2>
				<p class="mt-2 text-gray-600">Encuentra el equipo ideal para tu proyecto.</p>
			</div>
			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
				{categoryTiles.map((c) => (
					<a href={c.url} class="group relative overflow-hidden rounded-2xl border border-gray-200 bg-gradient-to-br from-accent-soft to-white p-8 hover:shadow-lg hover:border-accent-light transition duration-300">
						<div class="text-5xl mb-4">{c.icon}</div>
						<h3 class="text-xl font-bold text-gray-900 group-hover:text-accent-main transition">{c.title}</h3>
						<p class="mt-1 text-sm text-gray-600">{c.desc}</p>
						<p class="mt-4 inline-flex items-center text-sm font-semibold text-accent-main">
							{c.countLabel}
							<svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
						</p>
					</a>
				))}
			</div>
		</div>
	</section>

	<!-- PRODUCTOS DESTACADOS: GANCHO MARKETPLACE -->
	<section class="bg-slate-100 py-16">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="flex flex-col lg:flex-row lg:items-end lg:justify-between mb-10 gap-5">
				<div>
					<span class="inline-flex items-center rounded-full bg-white px-3 py-1 text-xs font-bold uppercase tracking-[0.18em] text-accent-main shadow-sm">
						Marketplace audiovisual
					</span>
					<h2 class="mt-4 text-3xl lg:text-4xl font-extrabold text-gray-900">Productos destacados</h2>
					<p class="mt-2 max-w-2xl text-gray-600">
						Productos con mayor rotación de ventas dentro de Mizo, seleccionados por demanda, desempeño y frecuencia de uso en proyectos reales.
					</p>
				</div>
				<a href="/productos" class="inline-flex items-center justify-center rounded-full bg-white px-5 py-3 text-sm font-bold text-accent-main shadow-sm hover:bg-accent-main hover:text-white transition">
					Ver toda la tienda
					<svg class="w-5 h-5 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
				</a>
			</div>

			<div data-featured-products-grid class="grid w-full grid-cols-1 gap-6 sm:grid-cols-2 md:grid-cols-3 xl:grid-cols-4">
				<div class="col-span-full rounded-3xl border border-gray-200 bg-white p-8 text-center text-gray-600">
					Cargando productos destacados configurados desde el admin...
				</div>
			</div>
		</div>
	</section>

	<!-- SOLUTIONS PACKS: COMBOS LLAVE EN MANO -->
	<section class="bg-white py-20">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-3xl text-center">
				<span class="inline-flex items-center rounded-full bg-accent-main/10 px-4 py-1.5 text-sm font-bold text-accent-main">
					Soluciones completas
				</span>
				<h2 class="mt-4 text-3xl lg:text-4xl font-extrabold text-gray-900">Packs diseñados, instalados y entregados funcionando</h2>
				<p class="mt-3 text-lg text-gray-600">
					Para clientes que no quieren armar una compra pieza por pieza: diseñamos el sistema, seleccionamos los equipos y ejecutamos la instalación llave en mano.
				</p>
			</div>

			<div id="home-packs-grid" class="mt-12 grid w-full grid-cols-1 gap-6 lg:grid-cols-3" data-home-packs-grid>
				{fallbackSolutionPacks.map((pack, index) => {
					const accent = [
						'from-accent-dark via-accent-main to-teal-500',
						'from-slate-950 via-blue-900 to-accent-main',
						'from-indigo-950 via-accent-dark to-emerald-500',
					][index % 3];
					return (
						<article class="relative flex h-full w-full flex-col overflow-hidden rounded-3xl border border-gray-200 bg-white shadow-lg transition duration-300 hover:-translate-y-1 hover:border-accent-light hover:shadow-2xl">
							<div class={`bg-gradient-to-br ${accent} p-6 text-white`}>
								<div class="flex items-start justify-between gap-4">
									<span class="rounded-full bg-white/15 px-3 py-1 text-xs font-black uppercase tracking-wide text-white backdrop-blur">{pack.etiqueta}</span>
									<span class="rounded-full bg-amber-300 px-3 py-1 text-xs font-black text-gray-950">Diseño + instalación</span>
								</div>
								<h3 class="mt-6 text-2xl font-black leading-tight text-white">{pack.titulo}</h3>
								<p class="mt-4 text-sm leading-relaxed text-white/85">{pack.descripcion}</p>
							</div>
							<div class="flex flex-1 flex-col p-5 sm:p-6">
								<p class="text-xs font-bold uppercase tracking-wide text-gray-500">Ideal para</p>
								<p class="mt-1 text-base font-bold text-gray-900">{pack.ideal_para}</p>
								<div class="mt-6 grid gap-3 rounded-2xl border border-accent-main/15 bg-accent-soft/50 p-4 text-sm text-gray-800">
									<div class="flex items-start gap-3"><span class="mt-0.5 inline-flex h-5 w-5 items-center justify-center rounded-full bg-accent-main text-xs font-black text-white">✓</span><span>Levantamiento técnico y propuesta a medida.</span></div>
									<div class="flex items-start gap-3"><span class="mt-0.5 inline-flex h-5 w-5 items-center justify-center rounded-full bg-accent-main text-xs font-black text-white">✓</span><span>Equipos, instalación y puesta en marcha coordinada.</span></div>
									<div class="flex items-start gap-3"><span class="mt-0.5 inline-flex h-5 w-5 items-center justify-center rounded-full bg-accent-main text-xs font-black text-white">✓</span><span>Soporte local posterior a la entrega.</span></div>
								</div>
								<a href={`/contacto?pack=${encodeURIComponent(pack.titulo)}`} class="mt-6 inline-flex w-full items-center justify-center rounded-xl bg-accent-main px-5 py-3 text-sm font-black text-white shadow-md transition hover:bg-accent-hover">Cotizar esta solución</a>
							</div>
						</article>
					);
				})}
			</div>
		</div>
	</section>

	<!-- SERVICIOS PREMIUM -->
	<section class="relative overflow-hidden bg-white py-20">
		<div class="absolute inset-x-0 top-0 h-48 bg-gradient-to-b from-accent-soft to-transparent"></div>
		<div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="grid grid-cols-1 gap-10 lg:grid-cols-[0.95fr_1.05fr] lg:items-center">
				<div>
					<span class="inline-flex rounded-full bg-accent-main/10 px-4 py-1.5 text-sm font-black uppercase tracking-[0.16em] text-accent-main">
						Servicios de ingeniería audiovisual
					</span>
					<h2 class="mt-5 text-3xl font-black leading-tight text-gray-950 sm:text-4xl lg:text-5xl">
						Diseñamos, montamos y calibramos sistemas que quedan listos para operar.
					</h2>
					<p class="mt-5 text-lg leading-relaxed text-gray-600">
						Mizo no instala “cajas”. Integramos acústica, infraestructura, soportería, energía, control y puesta en marcha para que cada sala se escuche, se vea y se opere con estándar profesional.
					</p>
					<div class="mt-8 grid grid-cols-2 gap-3 sm:flex sm:flex-wrap">
						<span class="rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm font-black text-slate-700 shadow-sm">Diseño acústico</span>
						<span class="rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm font-black text-slate-700 shadow-sm">Cableado oculto</span>
						<span class="rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm font-black text-slate-700 shadow-sm">Soportería pesada</span>
						<span class="rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm font-black text-slate-700 shadow-sm">Calibración láser</span>
					</div>
					<a href="/servicios" class="mt-8 inline-flex items-center justify-center rounded-full bg-accent-main px-6 py-3 text-sm font-black text-white shadow-lg transition hover:bg-accent-hover">
						Conoce nuestros servicios
						<svg class="ml-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
					</a>
				</div>

				<div class="grid gap-5">
					<div class="relative min-h-[320px] overflow-hidden rounded-[2rem] bg-slate-950 shadow-2xl">
						<img
							src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?auto=format&fit=crop&w=1000&q=80"
							alt="Canalización y montaje profesional de infraestructura audiovisual"
							class="h-full min-h-[320px] w-full object-cover opacity-80"
							loading="lazy"
							width="1000"
							height="700"
						/>
						<div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/35 to-transparent"></div>
						<div class="absolute bottom-0 left-0 right-0 p-6 text-white">
							<p class="text-xs font-black uppercase tracking-[0.18em] text-amber-300">Preparado para fotografía de obra real</p>
							<h3 class="mt-2 text-2xl font-black">Infraestructura invisible, resultado impecable</h3>
						</div>
					</div>
					<div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
						{engineeringServices.map((service) => (
							<article class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">
								<p class="text-[0.65rem] font-black uppercase tracking-[0.16em] text-accent-main">{service.meta}</p>
								<h3 class="mt-2 text-lg font-black text-gray-950">{service.title}</h3>
								<p class="mt-2 text-sm leading-relaxed text-gray-600">{service.desc}</p>
							</article>
						))}
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- NOSOTROS PREMIUM -->
	<section class="bg-slate-950 py-20 text-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="grid grid-cols-1 gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
				<div class="order-2 lg:order-1">
					<div class="grid grid-cols-2 gap-4">
						<div class="overflow-hidden rounded-[1.75rem] bg-white/10 p-3">
							<img
								src="https://images.unsplash.com/photo-1581090464777-f3220bbe1b8b?auto=format&fit=crop&w=700&q=80"
								alt="Planificación técnica de integración audiovisual"
								class="h-56 w-full rounded-2xl object-cover"
								loading="lazy"
								width="700"
								height="520"
							/>
						</div>
						<div class="mt-10 overflow-hidden rounded-[1.75rem] bg-white/10 p-3">
							<img
								src="https://images.unsplash.com/photo-1581092160607-ee22621dd758?auto=format&fit=crop&w=700&q=80"
								alt="Equipo técnico revisando montaje e ingeniería en terreno"
								class="h-56 w-full rounded-2xl object-cover"
								loading="lazy"
								width="700"
