<script is:inline>
	(function () {
		const grid = document.querySelector('[data-home-packs-grid]');
		if (!grid) return;
		const esc = (value) => String(value ?? '').replace(/[&<>"']/g, (ch) => ({
			'&': '&amp;',
			'<': '&lt;',
			'>': '&gt;',
			'"': '&quot;',
			"'": '&#39;',
		}[ch]));

		function packTemplate(pack, index) {
			const accent = [
				'from-accent-dark via-accent-main to-teal-500',
				'from-slate-950 via-blue-900 to-accent-main',
				'from-indigo-950 via-accent-dark to-emerald-500',
			][index % 3];
			const title = pack.titulo || 'Solución completa Mizo';
			const href = `/contacto?pack=${encodeURIComponent(title)}`;
			return `<article class="relative flex h-full w-full flex-col overflow-hidden rounded-3xl border border-gray-200 bg-white shadow-lg transition duration-300 hover:-translate-y-1 hover:border-accent-light hover:shadow-2xl">
				<div class="bg-gradient-to-br ${accent} p-6 text-white">
					<div class="flex items-start justify-between gap-4">
						<span class="rounded-full bg-white/15 px-3 py-1 text-xs font-black uppercase tracking-wide text-white backdrop-blur">${esc(pack.etiqueta || 'SOLUCIÓN')}</span>
						<span class="rounded-full bg-amber-300 px-3 py-1 text-xs font-black text-gray-950">Diseño + instalación</span>
					</div>
					<h3 class="mt-6 text-2xl font-black leading-tight text-white">${esc(title)}</h3>
					<p class="mt-4 text-sm leading-relaxed text-white/85">${esc(pack.descripcion || '')}</p>
				</div>
				<div class="flex flex-1 flex-col p-5 sm:p-6">
					<p class="text-xs font-bold uppercase tracking-wide text-gray-500">Ideal para</p>
					<p class="mt-1 text-base font-bold text-gray-900">${esc(pack.ideal_para || 'Proyectos audiovisuales, corporativos y educacionales')}</p>
					<div class="mt-6 grid gap-3 rounded-2xl border border-accent-main/15 bg-accent-soft/50 p-4 text-sm text-gray-800">
						<div class="flex items-start gap-3"><span class="mt-0.5 inline-flex h-5 w-5 items-center justify-center rounded-full bg-accent-main text-xs font-black text-white">✓</span><span>Levantamiento técnico y propuesta a medida.</span></div>
						<div class="flex items-start gap-3"><span class="mt-0.5 inline-flex h-5 w-5 items-center justify-center rounded-full bg-accent-main text-xs font-black text-white">✓</span><span>Equipos, instalación y puesta en marcha coordinada.</span></div>
						<div class="flex items-start gap-3"><span class="mt-0.5 inline-flex h-5 w-5 items-center justify-center rounded-full bg-accent-main text-xs font-black text-white">✓</span><span>Soporte local posterior a la entrega.</span></div>
					</div>
					<a href="${href}" class="mt-6 inline-flex w-full items-center justify-center rounded-xl bg-accent-main px-5 py-3 text-sm font-black text-white shadow-md transition hover:bg-accent-hover">Cotizar esta solución</a>
				</div>
			</article>`;
		}

		async function fetchJsonWithRetry(url, attempts = 2) {
			let lastError;
			for (let attempt = 0; attempt < attempts; attempt += 1) {
				const controller = new AbortController();
				const timeout = window.setTimeout(() => controller.abort(), 8000);
				try {
					const response = await fetch(url, {
						headers: { Accept: 'application/json' },
						cache: 'no-store',
						signal: controller.signal,
					});
					const payload = await response.json();
					if (!response.ok || !payload?.ok) throw new Error(payload?.error || 'Respuesta inválida.');
					return payload;
				} catch (error) {
					lastError = error;
					await new Promise((resolve) => window.setTimeout(resolve, 450 * (attempt + 1)));
				} finally {
					window.clearTimeout(timeout);
				}
			}
			throw lastError || new Error('No se pudo cargar.');
		}

		async function loadPacks() {
			try {
				const payload = await fetchJsonWithRetry('/api/home-packs.php?ts=' + Date.now(), 2);
				const packs = Array.isArray(payload.packs) ? payload.packs : [];
				if (packs.length) grid.innerHTML = packs.map(packTemplate).join('');
			} catch (error) {
				console.warn('Usando respaldo local de soluciones completas.', error);
			}
		}

		loadPacks();
	})();
</script>

<script is:inline>
	(function () {
		const grid = document.querySelector('[data-featured-products-grid]');
		if (!grid) return;

		const fmt = (value) => '$' + Number(value || 0).toLocaleString('es-CL');
		const categoryIcon = { sonido: '🔊', proyector: '📽️', camara: '📹' };
		const esc = (value) => String(value ?? '').replace(/[&<>"']/g, (ch) => ({
			'&': '&amp;',
			'<': '&lt;',
			'>': '&gt;',
			'"': '&quot;',
			"'": '&#39;',
		}[ch]));

		function cardTemplate(slot) {
			const product = slot.product || {};
			const price = Number(product.price) || 0;
			const detailUrl = product.sku ? `/productos/detalle?sku=${encodeURIComponent(product.sku)}` : '/productos';
			const cartId = product.sku || product.id || product.name;
			const image = product.image || '/mizo-logo.png';
			const brand = String(product.brand || '').trim();
			const publicBrand = brand && brand.toLowerCase() !== 'mizo' ? brand : '';
			const displayCategory = product.categoryLabel || product.category || 'Producto';
			const available = product.available !== false && Number(product.stock) > 0;
			const lowStock = available && Number(product.stock) <= 5;
			const installation = product.installation || slot.installation || {};
			const installationPrice = Number(installation.salePrice || installation.baseInstallationPrice || 0);
			const showInstallation = product.showInstallation === true || Number(product.mostrar_instalacion || slot.mostrar_instalacion || 0) === 1;
			const hasInstallation = (showInstallation || Boolean(slot.installation)) && installationPrice > 0;
			const solutionTotal = Number(product.solutionTotal || (price + installationPrice));
			const projectTypeLabel = product.projectTypeLabel || 'Proyecto de instalación';
			const roomSizeLabel = product.roomSizeLabel || installation.roomSizeLabel || 'Pequeña';
			const brandMarkup = publicBrand
				? `<p class="mt-1 text-xs font-semibold uppercase tracking-wide text-gray-500 line-clamp-1">${esc(publicBrand)}</p>`
				: '';

			return `<article class="product-item group flex h-full w-full flex-col overflow-hidden rounded-3xl border border-gray-200 bg-white shadow-sm transition duration-300 hover:-translate-y-1 hover:border-accent-light hover:shadow-xl" data-product-card data-sku="${esc(product.sku || '')}" data-published="${product.published === false ? '0' : '1'}" data-brand="${esc(publicBrand)}">
				<a href="${esc(detailUrl)}" data-astro-reload class="flex flex-1 flex-col text-inherit" aria-label="Ver detalle de ${esc(product.name)}">
					<div class="relative border-b border-gray-100 bg-gradient-to-b from-gray-50 to-white">
						<div class="flex h-56 items-center justify-center p-4">
							<img src="${esc(image)}" alt="${esc(product.name)}" class="max-h-[190px] w-auto object-contain mix-blend-multiply transition duration-500 group-hover:scale-105" loading="lazy" width="260" height="260" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
							<span class="hidden absolute inset-0 items-center justify-center text-4xl bg-accent-soft" aria-hidden="true">${esc(categoryIcon[product.category] || '📦')}</span>
						</div>
						<span class="absolute left-2 top-2 rounded-full bg-emerald-50 px-2 py-0.5 text-[0.58rem] font-black uppercase tracking-wide text-emerald-700 shadow-sm">
							Mejor Precio Garantizado
						</span>
						${lowStock ? `<span class="absolute bottom-2 left-2 rounded-full bg-amber-500 px-2 py-0.5 text-[0.68rem] font-bold text-white shadow">Últimas ${Number(product.stock)}</span>` : ''}
					</div>

					<div class="flex flex-1 flex-col p-4 pb-3">
						<div class="mb-2 flex items-center justify-between gap-2">
							<span class="truncate rounded-full bg-accent-soft px-2 py-0.5 text-[0.58rem] font-black uppercase tracking-wide text-accent-main">Categoría: ${esc(displayCategory)}</span>
							<span class="max-w-[6rem] truncate font-mono text-[0.65rem] font-bold text-gray-400">${esc(product.sku || '')}</span>
						</div>
						<h3 class="min-h-[2.35rem] text-base font-black leading-snug text-gray-950 transition group-hover:text-accent-main line-clamp-2">${esc(product.name)}</h3>
						${brandMarkup}

						${hasInstallation ? `<div class="mt-3 rounded-2xl border-2 border-accent-main/20 bg-accent-soft/70 p-4 shadow-sm">
							<p class="text-[0.68rem] font-black uppercase tracking-[0.16em] text-accent-main">Instalación profesional prioritaria</p>
							<div class="mt-2 space-y-1.5 text-xs font-bold text-slate-600">
								<div class="flex items-center justify-between gap-2">
									<span>Equipo solo</span>
									<span class="product-price text-slate-950" data-fallback-price="${price}">${fmt(price)}</span>
								</div>
								<div class="flex items-center justify-between gap-2">
									<span>+ Instalación profesional base</span>
									<span class="text-slate-950">${fmt(installationPrice)}</span>
								</div>
								<div class="flex items-center justify-between gap-2 border-t border-slate-200 pt-1.5 text-sm font-black text-gray-950">
									<span>Total solución</span>
									<span>${fmt(solutionTotal)}</span>
								</div>
							</div>
							<p class="mt-2 text-[0.65rem] font-bold leading-snug text-slate-500">${esc(projectTypeLabel)} · Sala ${esc(roomSizeLabel)}</p>
							<p class="product-stock-status mt-1.5 inline-flex items-center gap-1.5 rounded-full px-2 py-0.5 text-[0.68rem] font-black ${available ? 'bg-green-50 text-green-700' : 'bg-red-50 text-red-700'}" data-stock-status>
								<span class="inline-block h-1.5 w-1.5 rounded-full ${available ? 'bg-green-500' : 'bg-red-500'}" data-stock-dot></span>
								<span data-stock-label>${available ? `Stock · ${Number(product.stock)} disp.` : 'Sin Stock'}</span>
							</p>
							<p class="mt-2 rounded-lg bg-amber-50 px-2 py-1.5 text-[0.62rem] font-semibold leading-snug text-amber-900">
								⚠️ Valor de instalación referencial estimado para las dimensiones seleccionadas. El precio final puede variar y está sujeto a una visita técnica en terreno obligatoria para la validación de factibilidad y cierre del proyecto.
							</p>
						</div>` : `<div class="mt-2.5">
							<p class="text-[0.62rem] font-bold uppercase tracking-wide text-gray-400">Precio venta</p>
							<p class="text-xl font-black tracking-tight text-gray-950">
								<span class="product-price" data-fallback-price="${price}">${fmt(price)}</span>
							</p>
							<p class="product-stock-status mt-1.5 inline-flex items-center gap-1.5 rounded-full px-2 py-0.5 text-[0.68rem] font-black ${available ? 'bg-green-50 text-green-700' : 'bg-red-50 text-red-700'}" data-stock-status>
								<span class="inline-block h-1.5 w-1.5 rounded-full ${available ? 'bg-green-500' : 'bg-red-500'}" data-stock-dot></span>
								<span data-stock-label>${available ? `Stock · ${Number(product.stock)} disp.` : 'Sin Stock'}</span>
							</p>
						</div>`}
						<p class="mt-3 flex-1 text-xs leading-snug text-gray-600 line-clamp-2">${esc(product.description || 'Producto publicado en el catálogo Mizo.')}</p>
					</div>
				</a>

				<div class="px-4 pb-4">
					<button type="button" data-add-to-cart data-id="${esc(cartId)}" data-name="${esc(product.name)}" data-price="${price}" data-image="${esc(image)}" data-qty="1" class="add-to-cart-card inline-flex w-full items-center justify-center gap-1.5 rounded-lg bg-accent-main px-3 py-2 text-xs font-black text-white transition hover:bg-accent-hover disabled:cursor-not-allowed disabled:opacity-50" ${available ? '' : 'disabled'}>
						<span aria-hidden="true">🛒</span>
						Agregar al Carrito
					</button>
				</div>
			</article>`;
		}

		function setStockStatus(item, stock, available) {
			const status = item.querySelector('[data-stock-status]');
			const dot = item.querySelector('[data-stock-dot]');
			const label = item.querySelector('[data-stock-label]');
			const button = item.querySelector('[data-add-to-cart]');
			if (!status || !dot || !label) return;
			status.classList.toggle('bg-green-50', available);
			status.classList.toggle('text-green-700', available);
			status.classList.toggle('bg-red-50', !available);
			status.classList.toggle('text-red-700', !available);
			dot.classList.toggle('bg-green-500', available);
			dot.classList.toggle('bg-red-500', !available);
			label.textContent = available ? `Stock · ${stock} disp.` : 'Sin Stock';
			if (button) button.disabled = !available;
		}

		async function fetchJsonWithRetry(url, attempts = 2) {
			let lastError;
			for (let attempt = 0; attempt < attempts; attempt += 1) {
				const controller = new AbortController();
				const timeout = window.setTimeout(() => controller.abort(), 9000);
				try {
					const response = await fetch(url, {
						headers: { Accept: 'application/json' },
						cache: 'no-store',
						signal: controller.signal,
					});
					const payload = await response.json();
					if (!response.ok || !payload?.ok) throw new Error(payload?.error || 'Respuesta inválida.');
					return payload;
				} catch (error) {
					lastError = error;
					await new Promise((resolve) => window.setTimeout(resolve, 500 * (attempt + 1)));
				} finally {
					window.clearTimeout(timeout);
				}
			}
			throw lastError || new Error('No se pudo cargar.');
		}

		async function refreshLiveStockSequentially() {
			const items = Array.from(grid.querySelectorAll('.product-item[data-sku]'));
			for (const item of items) {
				const sku = item.getAttribute('data-sku');
				if (!sku) continue;
				try {
					const response = await fetch(`/api-get-live-stock.php?sku=${encodeURIComponent(sku)}&ts=${Date.now()}`, {
						headers: { Accept: 'application/json' },
						cache: 'no-store',
					});
					const payload = await response.json();
					if (response.ok && payload?.ok) {
						setStockStatus(item, Number(payload.stock) || 0, Boolean(payload.disponible));
					}
				} catch (error) {
					console.warn('No se pudo refrescar stock vivo en Home', { sku, error });
				}
				await new Promise((resolve) => window.setTimeout(resolve, 250));
			}
		}

		async function renderDynamicFeatured() {
			let slots = [];
			try {
				const featuredPayload = await fetchJsonWithRetry(`/api/obtener-destacados.php?ts=${Date.now()}`, 2);
				slots = Array.isArray(featuredPayload.slots)
					? featuredPayload.slots
						.filter((slot) => slot?.product && slot.product.published !== false)
						.slice(0, 8)
					: [];
			} catch (e) {
				console.warn('No se pudieron cargar destacados configurados desde el admin.', e);
			}

			if (slots.length) {
				grid.innerHTML = slots.map(cardTemplate).join('');
				refreshLiveStockSequentially();
			} else {
				grid.innerHTML = '<div class="col-span-full rounded-3xl border border-gray-200 bg-white p-8 text-center text-gray-600">No hay productos destacados configurados desde el admin.</div>';
			}
		}

		renderDynamicFeatured();
	})();
</script>

