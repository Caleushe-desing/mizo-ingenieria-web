---
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import ClientLogos from '../components/ClientLogos.astro';
import { products, featuredProducts } from '../data/products';

const destacados = featuredProducts(8);

const audioCount = products.filter((p) => p.category === 'sonido').length;
const proyectorCount = products.filter((p) => /proyector/i.test(p.name)).length;
const camaraCount = products.filter((p) => /c[áa]mara/i.test(p.name)).length;

const categoryTiles = [
	{ title: 'Parlantes y Audio', count: audioCount, icon: '🔊', url: '/productos?cat=sonido', desc: 'Cajas activas, line array y portátiles' },
	{ title: 'Proyectores', count: proyectorCount, icon: '📽️', url: '/productos?q=proyector', desc: 'Para salas, eventos y home cinema' },
	{ title: 'Cámaras', count: camaraCount, icon: '📹', url: '/productos?q=camara', desc: 'Seguridad y videovigilancia WiFi' },
];

const trust = [
	{ icon: '🚚', title: 'Despacho a todo Chile', desc: 'Coordinamos la entrega' },
	{ icon: '🛠️', title: 'Instalación profesional', desc: 'Sonido y proyección' },
	{ icon: '✅', title: 'Equipos originales', desc: 'Marcas reconocidas' },
	{ icon: '🔒', title: 'Pago seguro', desc: 'Mercado Pago' },
];
---

<Layout
	title="Mizo | Tienda de Audio y Video + Instalación Profesional"
	description="Compra parlantes, proyectores y cámaras en Chile, con instalación profesional de sistemas de sonido y proyección. Equipos originales, despacho y pago seguro."
>
	<!-- HERO TIENDA -->
	<section class="relative bg-gradient-to-b from-accent-soft to-white py-16 sm:py-24 overflow-hidden">
		<div class="absolute inset-0 -z-10 opacity-[0.04]" style="background-image: radial-gradient(#2563eb 1.2px, transparent 1.2px); background-size: 22px 22px;"></div>
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
			<span class="inline-block px-4 py-1.5 mb-5 text-sm font-semibold rounded-full bg-accent-main/10 text-accent-main">
				Tienda + Instalación profesional
			</span>
			<h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-gray-900 leading-tight max-w-4xl mx-auto">
				Equipos de <span class="text-accent-main">audio y video</span>, instalados como corresponde
			</h1>
			<p class="mt-5 text-lg sm:text-xl text-gray-600 max-w-3xl mx-auto">
				Compra parlantes, proyectores y cámaras de las mejores marcas. Y si quieres, nosotros los instalamos: sistemas de sonido y proyección listos para funcionar.
			</p>

			<!-- Buscador hero -->
			<form action="/productos" method="get" role="search" class="mt-8 max-w-2xl mx-auto">
				<div class="relative">
					<input
						type="search"
						name="q"
						placeholder="¿Qué estás buscando? Ej: parlante JBL, proyector Wanbo..."
						aria-label="Buscar productos"
						class="w-full pl-12 pr-28 py-4 rounded-full border border-gray-300 bg-white text-base text-gray-900 placeholder-gray-400 shadow-md focus:border-accent-main focus:ring-2 focus:ring-accent-main/20 focus:outline-none transition"
					/>
					<svg class="absolute left-4 top-1/2 -translate-y-1/2 h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m21 21-4.35-4.35M17 11a6 6 0 11-12 0 6 6 0 0112 0z"/></svg>
					<button type="submit" class="absolute right-2 top-1/2 -translate-y-1/2 px-5 py-2.5 rounded-full text-sm font-semibold text-white bg-accent-main hover:bg-accent-hover transition">
						Buscar
					</button>
				</div>
			</form>

			<div class="mt-5 flex flex-wrap justify-center gap-2 text-sm">
				<span class="text-gray-500">Populares:</span>
				<a href="/productos?q=jbl" class="text-accent-main hover:underline">JBL</a>
				<a href="/productos?q=proyector" class="text-accent-main hover:underline">Proyectores</a>
				<a href="/productos?q=reolink" class="text-accent-main hover:underline">Cámaras Reolink</a>
				<a href="/productos?cat=sonido" class="text-accent-main hover:underline">Parlantes</a>
			</div>
		</div>
	</section>

	<!-- BARRA DE CONFIANZA -->
	<section class="bg-white border-y border-gray-100">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 grid grid-cols-2 lg:grid-cols-4 gap-6">
			{trust.map((t) => (
				<div class="flex items-center gap-3">
					<span class="text-2xl">{t.icon}</span>
					<div>
						<p class="text-sm font-bold text-gray-900 leading-tight">{t.title}</p>
						<p class="text-xs text-gray-500">{t.desc}</p>
					</div>
				</div>
			))}
		</div>
	</section>

	<!-- CATEGORÍAS -->
	<section class="bg-white py-16">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-10">
				<h2 class="text-3xl lg:text-4xl font-bold text-gray-900">Explora por categoría</h2>
				<p class="mt-2 text-gray-600">Encuentra el equipo ideal para tu proyecto.</p>
			</div>
			<div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
				{categoryTiles.map((c) => (
					<a href={c.url} class="group relative overflow-hidden rounded-2xl border border-gray-200 bg-gradient-to-br from-accent-soft to-white p-8 hover:shadow-lg hover:border-accent-light transition duration-300">
						<div class="text-5xl mb-4">{c.icon}</div>
						<h3 class="text-xl font-bold text-gray-900 group-hover:text-accent-main transition">{c.title}</h3>
						<p class="mt-1 text-sm text-gray-600">{c.desc}</p>
						<p class="mt-4 inline-flex items-center text-sm font-semibold text-accent-main">
							Ver {c.count} productos
							<svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
						</p>
					</a>
				))}
			</div>
		</div>
	</section>

	<!-- PRODUCTOS DESTACADOS -->
	<section class="bg-accent-soft py-16">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="flex flex-col sm:flex-row sm:items-end sm:justify-between mb-10 gap-4">
				<div>
					<h2 class="text-3xl lg:text-4xl font-bold text-gray-900">Más vendidos</h2>
					<p class="mt-2 text-gray-600">Equipos profesionales con opción de instalación.</p>
				</div>
				<a href="/productos" class="inline-flex items-center font-semibold text-accent-main hover:text-accent-hover">
					Ver toda la tienda
					<svg class="w-5 h-5 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
				</a>
			</div>
			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
				{destacados.map((product) => <ProductCard product={product} />)}
			</div>
		</div>
	</section>

	<!-- INSTALACIÓN (DIFERENCIADOR) -->
	<section class="bg-white py-20">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center max-w-3xl mx-auto mb-12">
				<span class="inline-block px-4 py-1.5 mb-4 text-sm font-semibold rounded-full bg-accent-main/10 text-accent-main">
					Nuestro corazón: la instalación
				</span>
				<h2 class="text-3xl lg:text-4xl font-bold text-gray-900">No solo te vendemos el equipo. Lo dejamos funcionando.</h2>
				<p class="mt-4 text-lg text-gray-600">
					La verdadera diferencia está en una instalación bien hecha. Diseñamos, montamos y configuramos sistemas de sonido y proyección profesionales para que todo suene y se vea perfecto.
				</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
				<div class="rounded-2xl border border-gray-200 p-8 hover:shadow-lg transition duration-300">
					<div class="text-4xl mb-4">🔊</div>
					<h3 class="text-xl font-bold text-gray-900 mb-2">Sistemas de sonido</h3>
					<p class="text-gray-600">Audio profesional, megafonía y música ambiental con zonificación para comercios, eventos, iglesias y hogares.</p>
				</div>
				<div class="rounded-2xl border border-gray-200 p-8 hover:shadow-lg transition duration-300">
					<div class="text-4xl mb-4">📽️</div>
					<h3 class="text-xl font-bold text-gray-900 mb-2">Proyección y audiovisual</h3>
					<p class="text-gray-600">Proyectores, pantallas y salas de reuniones. Imagen nítida y configuración óptima para cada espacio.</p>
				</div>
				<div class="rounded-2xl border border-gray-200 p-8 hover:shadow-lg transition duration-300">
					<div class="text-4xl mb-4">📹</div>
					<h3 class="text-xl font-bold text-gray-900 mb-2">Videovigilancia</h3>
					<p class="text-gray-600">Instalación de cámaras de seguridad WiFi y cableadas, con acceso remoto desde tu celular.</p>
				</div>
			</div>

			<div class="mt-10 text-center">
				<a href="/servicios" class="inline-block px-8 py-3.5 text-lg font-semibold rounded-md text-white bg-accent-main hover:bg-accent-hover transition duration-300 shadow-lg">
					Conoce nuestros servicios de instalación
				</a>
			</div>
		</div>
	</section>

	<!-- POR QUÉ MIZO -->
	<section class="bg-accent-soft py-20">
		<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
			<div>
				<h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">Un solo proveedor, de principio a fin</h2>
				<p class="text-lg text-gray-600 mb-6">
					Compra el equipo y déjanos la instalación. Mizo combina venta e ingeniería para entregarte una solución completa, prolija y garantizada.
				</p>
				<ul class="space-y-3">
					{[
						'Equipos de marcas reconocidas y originales',
						'Instalación según normativa chilena',
						'Cobertura en Frutillar, Santiago y todo Chile',
						'Asesoría técnica antes, durante y después',
					].map((item) => (
						<li class="flex items-start text-gray-700">
							<svg class="w-6 h-6 text-accent-main mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
							{item}
						</li>
					))}
				</ul>
				<div class="mt-8">
					<a href="/nosotros" class="px-6 py-3 border border-accent-main text-base font-semibold rounded-md text-accent-main hover:bg-accent-main hover:text-white transition duration-300">
						Conoce a Mizo
					</a>
				</div>
			</div>

			<div class="h-72 lg:h-80 rounded-2xl overflow-hidden border border-gray-200 shadow-sm bg-white flex items-center justify-center">
				<img
					src="/mizo-confianza.jpg"
					alt="Equipo de Mizo trabajando en una instalación"
					class="w-full h-full object-cover"
					loading="lazy"
					width="800"
					height="600"
				/>
			</div>
		</div>
	</section>

	<!-- CTA FINAL -->
	<section class="bg-accent-main py-16">
		<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
			<h2 class="text-3xl sm:text-4xl font-extrabold text-white mb-4">¿Compras el equipo o lo quieres instalado?</h2>
			<p class="text-lg sm:text-xl text-blue-100 mb-8">
				Escríbenos y te asesoramos para elegir el equipo correcto y, si lo necesitas, lo instalamos por ti.
			</p>
			<div class="flex flex-col sm:flex-row justify-center gap-4">
				<a href="/productos" class="inline-block px-10 py-4 text-lg font-bold rounded-md text-accent-main bg-white hover:bg-blue-50 transition duration-300 shadow-lg">
					Ir a la tienda
				</a>
				<a href="/contacto" class="inline-block px-10 py-4 text-lg font-bold rounded-md text-white border-2 border-white hover:bg-white hover:text-accent-main transition duration-300">
					Solicitar Cotización
				</a>
			</div>
		</div>
	</section>

	<ClientLogos />
</Layout>
