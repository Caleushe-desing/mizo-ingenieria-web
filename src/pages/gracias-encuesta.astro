---
// src/pages/gracias-encuesta.astro - Página de Agradecimiento Específica para Encuestas de Satisfacción
import Layout from '../layouts/Layout.astro';
---

<Layout title="¡Gracias por tu Feedback! | Mizo" description="Hemos recibido tu encuesta de satisfacción. Tu opinión es muy valiosa.">
    
    <section class="relative isolate flex min-h-[80vh] items-center justify-center overflow-hidden bg-ink py-24 text-white sm:py-32">
        <img src="https://images.unsplash.com/photo-1497366754035-f200968a6e72?auto=format&fit=crop&w=1600&q=80" alt="" aria-hidden="true" class="absolute inset-0 h-full w-full object-cover" loading="eager" width="1600" height="900" />
        <div class="absolute inset-0 bg-gradient-to-b from-ink/85 via-ink/82 to-ink/95"></div>
        <div class="absolute inset-0 opacity-[0.12]" style="background-image: radial-gradient(#1c9bd8 1px, transparent 1px); background-size: 26px 26px;"></div>
        <div class="relative mx-auto max-w-2xl rounded-[2rem] border border-white/12 bg-white/[0.06] px-6 py-12 text-center shadow-2xl backdrop-blur sm:px-10">
            
            <div class="mx-auto mb-6 flex h-20 w-20 items-center justify-center rounded-full border border-white/15 bg-white/10 text-4xl backdrop-blur">⭐</div>
            
            <h1 class="text-balance text-3xl font-black leading-[1.1] tracking-tight text-white sm:text-4xl">
                ¡Gracias por tu <span class="text-accent-light">feedback</span>!
            </h1>
            
            <p class="mx-auto mt-5 max-w-xl text-pretty text-lg leading-relaxed text-white/70">
                Hemos recibido tu Encuesta de Satisfacción. Valoramos enormemente tu opinión, ya que nos ayuda a mantener nuestros estándares de excelencia.
            </p>
            
            <p class="mx-auto mt-3 max-w-xl text-base leading-relaxed text-white/55">
                Si dejaste un testimonio, este será revisado por nuestro equipo antes de ser publicado.
            </p>

            <a 
                href="/" 
                class="mt-9 inline-flex justify-center rounded-full bg-accent-main px-8 py-3.5 text-sm font-black text-white shadow-lg transition hover:bg-accent-hover focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-ink focus:ring-accent-main"
            >
                Volver a la página principal
            </a>
            
        </div>
    </section>
    
</Layout>