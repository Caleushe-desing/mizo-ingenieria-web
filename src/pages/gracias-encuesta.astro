---
// src/pages/gracias-encuesta.astro - Página de Agradecimiento Específica para Encuestas de Satisfacción
import Layout from '../layouts/Layout.astro';
---

<Layout title="¡Gracias por tu Feedback! | Mizo" description="Hemos recibido tu encuesta de satisfacción. Tu opinión es muy valiosa.">
    
    <section class="bg-gradient-to-b from-accent-soft to-white py-24 sm:py-32 min-h-[80vh] flex items-center justify-center">
        <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center bg-white p-10 rounded-2xl shadow-sm border border-gray-200">
            
            <div class="text-7xl mb-6">⭐</div>
            
            <h1 class="text-4xl font-extrabold text-gray-900 mb-4">
                ¡Gracias por tu <span class="text-accent-main">feedback</span>!
            </h1>
            
            <p class="mt-4 text-xl text-gray-600 mb-8">
                Hemos recibido tu Encuesta de Satisfacción. Valoramos enormemente tu opinión, ya que nos ayuda a mantener nuestros estándares de excelencia.
            </p>
            
            <p class="text-lg text-gray-500 mb-10">
                Si dejaste un testimonio, este será revisado por nuestro equipo antes de ser publicado.
            </p>

            <a 
                href="/" 
                class="inline-flex justify-center py-3 px-8 rounded-md shadow-sm text-lg font-bold text-white bg-accent-main hover:bg-accent-hover focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-accent-main transition duration-300"
            >
                Volver a la página principal
            </a>
            
        </div>
    </section>
    
</Layout>