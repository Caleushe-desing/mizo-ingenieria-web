---
import Layout from '../layouts/Layout.astro';
import SectionCTA from '../components/SectionCTA.astro';
import PageHero from '../components/PageHero.astro';

const testimonials = [
	{ quote: "Aquí estará tu testimonio.", author: "—", icon: "🔊" },
	{ quote: "Aquí estará tu testimonio.", author: "—", icon: "📽️" },
	{ quote: "Aquí estará tu testimonio.", author: "—", icon: "⚡" },
];
---

<Layout
	title="Testimonios | Mizo"
	description="Opiniones de nuestros clientes sobre instalaciones de sonido, audiovisual, electricidad y venta de equipos."
>
	<PageHero
		eyebrow="Testimonios"
		title="Lo que dicen nuestros clientes"
		subtitle="La confianza de nuestros clientes es el mejor reflejo de nuestro compromiso con la calidad. Acabamos de inaugurar esta sección y ya estamos recopilando sus historias."
		image="https://images.unsplash.com/photo-1497366754035-f200968a6e72?auto=format&fit=crop&w=1600&q=80"
		align="center"
	/>

	<section class="py-20 bg-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<h2 class="text-3xl font-extrabold text-gray-900 text-center mb-12">Historias de Éxito</h2>

			<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
				{testimonials.map((t) => (
					<div class="bg-white p-8 rounded-xl shadow-sm border border-gray-200 flex flex-col justify-between">
						<div class="text-4xl mb-4 inline-flex h-14 w-14 items-center justify-center rounded-lg bg-accent-soft">{t.icon}</div>
						<p class="text-lg italic text-gray-700 mb-6 flex-grow">"{t.quote}"</p>
						<p class="text-accent-main font-semibold border-t border-gray-100 pt-4">— {t.author}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<SectionCTA
		title="¿Tienes un proyecto en mente?"
		subtitle="Cuéntanos tus desafíos y te enviaremos una propuesta personalizada y sin compromiso."
		buttonText="Solicitar Cotización"
		buttonLink="/contacto"
	/>
</Layout>
