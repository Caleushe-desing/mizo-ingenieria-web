---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
---

<Layout title="Encuesta de Satisfacción | Mizo" description="Formulario exclusivo para clientes Mizo para evaluar el servicio y dejar un testimonio.">
    
    <PageHero
        eyebrow="Clientes Mizo"
        title="Tu opinión, nuestro impulso"
        subtitle="Gracias por confiar en Mizo. Te pedimos unos minutos para evaluar tu experiencia y, si lo deseas, dejar un testimonio."
        image="https://images.unsplash.com/photo-1507901747481-84a4f64fda6d?auto=format&fit=crop&w=1600&q=80"
        align="center"
        size="sm"
    />

    <section class="bg-white py-16 sm:py-20">
        <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

            <div class="bg-white p-8 md:p-12 rounded-2xl shadow-sm border border-gray-200">
                
                <h2 class="text-2xl font-extrabold text-gray-900 mb-8">Encuesta Rápida de Satisfacción</h2>

                <form 
                    name="satisfaction-survey" 
                    method="POST" 
                    action="/gracias-encuesta"
                    data-netlify="true" 
                    class="space-y-8"
                >
                    <input type="hidden" name="form-name" value="satisfaction-survey" />
                    <input type="hidden" name="type" value="encuesta-y-testimonio" />

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 border-b border-gray-200 pb-6">
                        <div>
                            <label for="client_name" class="block text-sm font-medium text-gray-700">Tu Nombre o Nombre de la Empresa</label>
                            <input type="text" id="client_name" name="client_name" required class="mt-1 block w-full bg-white border border-gray-300 text-gray-900 rounded-md shadow-sm p-3 focus:ring-accent-main focus:border-accent-main">
                        </div>
                        <div>
                            <label for="project_ref" class="block text-sm font-medium text-gray-700">Referencia del Proyecto (Opcional)</label>
                            <input type="text" id="project_ref" name="project_ref" class="mt-1 block w-full bg-white border border-gray-300 text-gray-900 rounded-md shadow-sm p-3 focus:ring-accent-main focus:border-accent-main">
                        </div>
                    </div>

                    <div class="space-y-6 border-b border-gray-200 pb-6">
                        <h3 class="text-lg font-semibold text-gray-900">Evalúa el servicio (1 = Muy Insatisfecho, 5 = Muy Satisfecho)</h3>

                        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center">
                            <label class="block text-base text-gray-700 w-full sm:w-1/2">1. Calidad del trabajo / instalación:</label>
                            <div class="flex space-x-4 mt-2 sm:mt-0">
                                {[1, 2, 3, 4, 5].map(rating => (
                                    <label class="flex items-center space-x-1 text-gray-600 cursor-pointer hover:text-accent-main transition duration-200">
                                        <input type="radio" name="rating_quality" value={rating} required class="h-4 w-4 text-accent-main border-gray-300 focus:ring-accent-main" />
                                        <span>{rating}</span>
                                    </label>
                                ))}
                            </div>
                        </div>

                        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center">
                            <label class="block text-base text-gray-700 w-full sm:w-1/2">2. Cumplimiento de plazos y puntualidad:</label>
                            <div class="flex space-x-4 mt-2 sm:mt-0">
                                {[1, 2, 3, 4, 5].map(rating => (
                                    <label class="flex items-center space-x-1 text-gray-600 cursor-pointer hover:text-accent-main transition duration-200">
                                        <input type="radio" name="rating_punctuality" value={rating} required class="h-4 w-4 text-accent-main border-gray-300 focus:ring-accent-main" />
                                        <span>{rating}</span>
                                    </label>
                                ))}
                            </div>
                        </div>
                        
                        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center">
                            <label class="block text-base text-gray-700 w-full sm:w-1/2">3. Atención y comunicación del equipo:</label>
                            <div class="flex space-x-4 mt-2 sm:mt-0">
                                {[1, 2, 3, 4, 5].map(rating => (
                                    <label class="flex items-center space-x-1 text-gray-600 cursor-pointer hover:text-accent-main transition duration-200">
                                        <input type="radio" name="rating_attention" value={rating} required class="h-4 w-4 text-accent-main border-gray-300 focus:ring-accent-main" />
                                        <span>{rating}</span>
                                    </label>
                                ))}
                            </div>
                        </div>

                    </div>

                    <div>
                        <h3 class="text-lg font-semibold text-gray-900 mb-3">4. ¿Quieres dejar un testimonio? (Opcional)</h3>
                        <label for="testimony_message" class="block text-sm font-medium text-gray-600 mb-2">Si tu experiencia fue positiva, ¿podríamos usar tu comentario en nuestro sitio web?</label>
                        <textarea id="testimony_message" name="testimony_message" rows="4" placeholder="Escribe aquí tu testimonio..." class="mt-1 block w-full bg-white border border-gray-300 text-gray-900 rounded-md shadow-sm p-3 focus:ring-accent-main focus:border-accent-main"></textarea>
                    </div>

                    <button type="submit" class="w-full inline-flex justify-center py-3 px-4 rounded-md shadow-sm text-lg font-bold text-white bg-accent-main hover:bg-accent-hover focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-accent-main transition duration-300">
                        Enviar mi Encuesta y Feedback
                    </button>
                </form>
            </div>
        </div>
    </section>
    
</Layout>
