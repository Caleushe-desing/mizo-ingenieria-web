---
const title = 'Leads de Diagnóstico Técnico | Mizo Admin';
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="robots" content="noindex, nofollow" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<title>{title}</title>
		<script is:inline>
			window.tailwind = window.tailwind || {};
			window.tailwind.config = {
				theme: {
					extend: {
						colors: {
							'accent-main': '#0284c7',
							'accent-soft': '#e0f2fe',
						},
					},
				},
			};
		</script>
		<script is:inline src="https://cdn.tailwindcss.com"></script>
	</head>
	<body class="min-h-screen bg-slate-100 text-slate-950">
		<main class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
			<header class="flex flex-col gap-4 rounded-3xl border border-slate-200 bg-white p-6 shadow-sm sm:flex-row sm:items-end sm:justify-between">
				<div>
					<a href="/admin" class="text-sm font-black text-accent-main">← Volver al panel central</a>
					<p class="mt-4 text-xs font-black uppercase tracking-[0.22em] text-accent-main">Mizo Admin</p>
					<h1 class="mt-2 text-3xl font-black">Leads de Diagnóstico Técnico</h1>
					<p class="mt-2 max-w-2xl text-sm leading-6 text-slate-500">
						Listado de clientes capturados por el Asistente de Diagnóstico Técnico Mizo. Los leads se leen desde MySQL o desde el archivo runtime <code>leads.json</code>.
					</p>
				</div>
				<a href="/configurador" class="rounded-full bg-accent-main px-5 py-3 text-sm font-black text-white shadow-lg transition hover:bg-sky-700">
					Abrir asistente
				</a>
			</header>

			<section id="login-card" class="mx-auto mt-8 max-w-md rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
				<p class="text-xs font-black uppercase tracking-[0.2em] text-accent-main">Acceso protegido</p>
				<h2 class="mt-2 text-2xl font-black">Ingresa la clave admin</h2>
				<form id="login-form" class="mt-5 space-y-3">
					<input id="password" type="password" autocomplete="current-password" placeholder="Clave privada" class="w-full rounded-2xl border border-slate-300 px-4 py-3 text-sm outline-none focus:border-accent-main focus:ring-4 focus:ring-sky-100" required />
					<button class="w-full rounded-2xl bg-accent-main px-4 py-3 text-sm font-black text-white hover:bg-sky-700">Ver leads</button>
					<p id="login-error" class="hidden rounded-2xl bg-red-50 px-4 py-3 text-sm font-bold text-red-700"></p>
				</form>
			</section>

			<section id="panel" class="mt-8 hidden">
				<div class="mb-5 grid gap-3 sm:grid-cols-3">
					<div class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">
						<p class="text-xs font-black uppercase text-slate-400">Total leads</p>
						<p id="lead-count" class="mt-2 text-3xl font-black text-slate-950">0</p>
					</div>
					<div class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">
						<p class="text-xs font-black uppercase text-slate-400">Fuente</p>
						<p id="lead-source" class="mt-2 text-3xl font-black text-slate-950">-</p>
					</div>
					<div class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">
						<p class="text-xs font-black uppercase text-slate-400">Escritura JSON</p>
						<p id="storage-status" class="mt-2 text-lg font-black text-slate-950">-</p>
					</div>
				</div>

				<div class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">
					<div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
						<div>
							<h2 class="text-2xl font-black">Clientes capturados</h2>
							<p class="text-sm text-slate-500">Haz clic en “Ver resumen técnico” para revisar el diagnóstico.</p>
						</div>
						<button id="refresh" class="rounded-full border border-slate-300 px-5 py-3 text-sm font-black text-slate-700 hover:border-accent-main hover:text-accent-main">
							Actualizar
						</button>
					</div>
					<div id="lead-list" class="mt-5 grid gap-3"></div>
				</div>
			</section>
		</main>

		<div id="modal" class="fixed inset-0 z-50 hidden bg-slate-950/70 p-4">
			<div class="mx-auto mt-10 max-h-[85vh] max-w-4xl overflow-hidden rounded-3xl bg-white shadow-2xl">
				<div class="flex items-start justify-between gap-4 border-b border-slate-200 p-5">
					<div>
						<p id="modal-meta" class="text-xs font-black uppercase tracking-[0.2em] text-accent-main"></p>
						<h3 id="modal-title" class="mt-2 text-2xl font-black"></h3>
					</div>
					<button id="modal-close" class="rounded-full border border-slate-300 px-4 py-2 text-sm font-black text-slate-700">Cerrar</button>
				</div>
				<pre id="modal-body" class="max-h-[65vh] overflow-auto whitespace-pre-wrap bg-slate-950 p-5 text-sm leading-6 text-slate-100"></pre>
			</div>
		</div>

		<script is:inline>
			(function () {
				const loginCard = document.getElementById('login-card');
				const loginForm = document.getElementById('login-form');
				const password = document.getElementById('password');
				const loginError = document.getElementById('login-error');
				const panel = document.getElementById('panel');
				const list = document.getElementById('lead-list');
				const count = document.getElementById('lead-count');
				const source = document.getElementById('lead-source');
				const storage = document.getElementById('storage-status');
				const refresh = document.getElementById('refresh');
				const modal = document.getElementById('modal');
				const modalTitle = document.getElementById('modal-title');
				const modalMeta = document.getElementById('modal-meta');
				const modalBody = document.getElementById('modal-body');
				const modalClose = document.getElementById('modal-close');
				let adminPassword = sessionStorage.getItem('mizoAdminPassword') || '';
				let leads = [];

				const esc = (value) => String(value ?? '').replace(/[&<>"']/g, (ch) => ({
					'&': '&amp;',
					'<': '&lt;',
					'>': '&gt;',
					'"': '&quot;',
					"'": '&#039;',
				}[ch]));

				function showError(message) {
					loginError.textContent = message;
					loginError.classList.remove('hidden');
				}

				function hideError() {
					loginError.classList.add('hidden');
					loginError.textContent = '';
				}

				function formatDate(value) {
					const date = new Date(value);
					if (Number.isNaN(date.getTime())) return value || '-';
					return date.toLocaleString('es-CL', { dateStyle: 'short', timeStyle: 'short' });
				}

				function summaryText(lead) {
					return [
						`Nombre: ${lead.nombre || ''}`,
						`Empresa: ${lead.empresa || ''}`,
						`Teléfono: ${lead.telefono || ''}`,
						`Correo: ${lead.correo || ''}`,
						`Fecha: ${formatDate(lead.createdAt)}`,
						'',
						`Entorno: ${lead.espacio || 'No indicado'}`,
						`Especialidad: ${lead.especialidad || 'No indicada'}`,
						`Dimensión: ${lead.dimension || 'No indicada'}`,
						`Origen: ${lead.source || 'Asistente de Diagnóstico Técnico Mizo'}`,
						'',
						'Resumen técnico:',
						lead.resumenTecnico || lead.detalles || 'Sin resumen técnico.',
						'',
						'Productos precalificados:',
						lead.productos || 'Sin productos registrados.',
					].join('\n');
				}

				function openModal(lead) {
					modalTitle.textContent = `${lead.nombre || 'Lead'} · ${lead.empresa || 'Sin empresa'}`;
					modalMeta.textContent = `${formatDate(lead.createdAt)} · ${lead.correo || ''}`;
					modalBody.textContent = summaryText(lead);
					modal.classList.remove('hidden');
				}

				function renderLeads() {
					count.textContent = String(leads.length);
					if (!leads.length) {
						list.innerHTML = '<div class="rounded-2xl border border-slate-200 bg-slate-50 p-8 text-center text-slate-500">Aún no hay leads guardados.</div>';
						return;
					}
					list.innerHTML = leads.map((lead, index) => `
						<article class="grid gap-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm lg:grid-cols-[1fr_auto] lg:items-center">
							<div>
								<p class="text-xs font-black uppercase text-slate-400">${esc(formatDate(lead.createdAt))}</p>
								<h3 class="mt-1 text-xl font-black text-slate-950">${esc(lead.nombre || 'Sin nombre')}</h3>
								<div class="mt-2 flex flex-wrap gap-2 text-sm font-semibold text-slate-600">
									<span>${esc(lead.empresa || 'Sin empresa')}</span>
									<span>·</span>
									<a class="text-accent-main" href="mailto:${esc(lead.correo || '')}">${esc(lead.correo || 'Sin correo')}</a>
									<span>·</span>
									<span>${esc(lead.telefono || 'Sin teléfono')}</span>
								</div>
								<p class="mt-2 text-sm text-slate-500">${esc(lead.espacio || 'Sin entorno')} · ${esc(lead.especialidad || 'Sin especialidad')} · ${esc(lead.dimension || 'Sin dimensión')}</p>
							</div>
							<button class="view-summary rounded-full bg-accent-main px-5 py-3 text-sm font-black text-white hover:bg-sky-700" data-index="${index}">
								Ver resumen técnico
							</button>
						</article>
					`).join('');
					list.querySelectorAll('.view-summary').forEach((button) => {
						button.addEventListener('click', () => openModal(leads[Number(button.dataset.index)]));
					});
				}

				async function loadLeads() {
					hideError();
					const response = await fetch('/api/guardar-lead.php', {
						method: 'POST',
						headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
						body: JSON.stringify({ action: 'list', password: adminPassword }),
					});
					const payload = await response.json().catch(() => null);
					if (!response.ok || !payload?.success) {
						throw new Error(payload?.error || 'No se pudieron cargar los leads.');
					}
					leads = Array.isArray(payload.leads) ? payload.leads : [];
					source.textContent = payload.source || '-';
					storage.textContent = payload.storage?.fileWritable ? 'OK' : (payload.storage?.dirWritable ? 'Directorio OK' : 'Revisar permisos');
					loginCard.classList.add('hidden');
					panel.classList.remove('hidden');
					renderLeads();
				}

				loginForm.addEventListener('submit', async (event) => {
					event.preventDefault();
					adminPassword = password.value;
					try {
						await loadLeads();
						sessionStorage.setItem('mizoAdminPassword', adminPassword);
					} catch (error) {
						showError(error.message || 'Clave incorrecta.');
					}
				});

				refresh.addEventListener('click', () => loadLeads().catch((error) => showError(error.message || 'No se pudo actualizar.')));
				modalClose.addEventListener('click', () => modal.classList.add('hidden'));
				modal.addEventListener('click', (event) => {
					if (event.target === modal) modal.classList.add('hidden');
				});

				if (adminPassword) {
					password.value = adminPassword;
					loadLeads().catch(() => sessionStorage.removeItem('mizoAdminPassword'));
				}
			})();
		</script>
	</body>
</html>
