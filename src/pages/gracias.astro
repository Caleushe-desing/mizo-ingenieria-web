---
// src/pages/gracias.astro - Página de confirmación después del envío del formulario
import Layout from '../layouts/Layout.astro';
---

<Layout title="¡Mensaje Enviado! | Mizo" description="Confirmación de envío de la solicitud de contacto a Mizo.">
    
    <section class="relative isolate flex min-h-[80vh] items-center justify-center overflow-hidden bg-ink py-28 text-white sm:py-40">
        <img src="https://images.unsplash.com/photo-1507901747481-84a4f64fda6d?auto=format&fit=crop&w=1600&q=80" alt="" aria-hidden="true" class="absolute inset-0 h-full w-full object-cover" loading="eager" width="1600" height="900" />
        <div class="absolute inset-0 bg-gradient-to-b from-ink/85 via-ink/82 to-ink/95"></div>
        <div class="absolute inset-0 opacity-[0.12]" style="background-image: radial-gradient(#1c9bd8 1px, transparent 1px); background-size: 26px 26px;"></div>
        <div class="pointer-events-none absolute -top-24 right-0 h-72 w-72 rounded-full bg-accent-main/20 blur-3xl"></div>
        <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            
            <div class="mx-auto mb-8 flex h-20 w-20 items-center justify-center rounded-full border border-white/15 bg-white/10 text-4xl backdrop-blur">
                ✅
            </div>

            <h1 id="gracias-titulo" class="text-balance text-4xl font-black leading-[1.1] tracking-tight text-white sm:text-5xl">
                ¡Gracias por tu <span class="text-accent-light">solicitud</span>!
            </h1>
            
            <p id="gracias-texto" class="mx-auto mt-6 max-w-xl text-pretty text-lg leading-relaxed text-white/70">
                Hemos recibido tu mensaje y un miembro de nuestro equipo se pondrá en contacto contigo a la brevedad.
                Normalmente respondemos en el transcurso de un día hábil.
            </p>

            <div class="mt-10">
                <a 
                    href="/" 
                    class="inline-flex items-center justify-center py-4 px-8 rounded-lg shadow-lg text-lg font-bold text-white bg-accent-main hover:bg-accent-hover focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-accent-main transition duration-300 transform hover:scale-105"
                >
                    Volver a la Página Principal
                </a>
            </div>

        </div>
    </section>

    <script is:inline>
        (function () {
            const params = new URLSearchParams(window.location.search);
            const status = params.get('status') || params.get('collection_status');
            const isPayment = params.has('payment_id') || params.has('collection_id') || status;
            if (!isPayment) return;

            // Llega desde Mercado Pago: vaciamos carrito y datos de envío.
            try {
                localStorage.removeItem('mizo-cart');
                localStorage.removeItem('mizo-ship-quote');
                localStorage.removeItem('mizo-delivery');
                if (window.__mizoUpdateCartBadge) window.__mizoUpdateCartBadge();
            } catch (e) {}

            const titulo = document.getElementById('gracias-titulo');
            const texto = document.getElementById('gracias-texto');
            if (status === 'approved' || status === 'success') {
                if (titulo) titulo.innerHTML = '¡Gracias por tu <span class="text-accent-main">compra</span>!';
                if (texto) texto.textContent = 'Tu pago fue aprobado correctamente. Te contactaremos para coordinar la entrega de tus productos.';

                // Respaldo: avisa a ventas/admin si el webhook aún no llegó.
                const paymentId = params.get('payment_id') || params.get('collection_id');
                if (paymentId) {
                    const key = 'mizo-notified-' + paymentId;
                    if (!sessionStorage.getItem(key)) {
                        sessionStorage.setItem(key, '1');
                        fetch('/.netlify/functions/confirmar-compra', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ payment_id: paymentId }),
                        }).catch(function () {});
                    }
                }
            } else if (status === 'pending' || status === 'in_process') {
                if (titulo) titulo.innerHTML = 'Tu pago está <span class="text-accent-main">en proceso</span>';
                if (texto) texto.textContent = 'Estamos esperando la confirmación del pago. Te avisaremos en cuanto se acredite.';
            } else {
                if (titulo) titulo.innerHTML = 'Gracias por tu <span class="text-accent-main">visita</span>';
                if (texto) texto.textContent = 'Si tuviste algún problema con el pago, puedes intentarlo nuevamente o escribirnos por WhatsApp.';
            }
        })();
    </script>

</Layout>