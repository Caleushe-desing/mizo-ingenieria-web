---
import Layout from '../layouts/Layout.astro';

const environments = [
	{
		value: 'Auditorios / Teatros',
		title: 'Auditorios / Teatros',
		desc: 'Proyección avanzada, acústica, inteligibilidad y operación para alta concurrencia.',
		focus: 'Proyección avanzada y acústica',
		image: 'https://images.unsplash.com/photo-1507901747481-84a4f64fda6d?auto=format&fit=crop&w=1200&q=80',
		needsProjection: true,
	},
	{
		value: 'Gimnasios / Espacios Deportivos',
		title: 'Gimnasios / Espacios Deportivos',
		desc: 'Amplificación de alta potencia, dispersión y cobertura homogénea en espacios reverberantes.',
		focus: 'Alta potencia y dispersión',
		image: 'https://images.unsplash.com/photo-1546519638-68e109498ffc?auto=format&fit=crop&w=1200&q=80',
		needsProjection: false,
	},
	{
		value: 'Plantas Industriales / Logística',
		title: 'Plantas Industriales / Logística',
		desc: 'Sistemas de evacuación, voceo IP, zonas críticas y continuidad operacional.',
		focus: 'Evacuación y voceo IP',
		image: 'https://images.unsplash.com/photo-1581093458791-9d09cc08742a?auto=format&fit=crop&w=1200&q=80',
		needsProjection: false,
	},
	{
		value: 'Salas de Reuniones Corporativas',
		title: 'Salas de Reuniones Corporativas',
		desc: 'Videoconferencia inteligente, captura de voz, cámaras, pantallas y control simple.',
		focus: 'Videoconferencia inteligente',
		image: 'https://images.unsplash.com/photo-1497366754035-f200968a6e72?auto=format&fit=crop&w=1200&q=80',
		needsProjection: true,
	},
];

const projectionOptions = [
	{
		value: 'Sí, Proyección Láser Gran Formato',
		title: 'Sí, Proyección Láser Gran Formato',
		desc: 'Alta luminosidad, óptica adecuada, pantalla y calibración para presentaciones críticas.',
		image: 'https://images.unsplash.com/photo-1517457373958-b7bdd4587205?auto=format&fit=crop&w=1200&q=80',
	},
	{
		value: 'Sí, Videowall / Pantalla LED',
		title: 'Sí, Videowall / Pantalla LED',
		desc: 'Módulos LED, procesadores, estructura, control y operación para visualización continua.',
		image: 'https://images.unsplash.com/photo-1551434678-e076c223a692?auto=format&fit=crop&w=1200&q=80',
	},
	{
		value: 'No, solo audio',
		title: 'No, solo audio',
		desc: 'Sistema enfocado en inteligibilidad, cobertura sonora y operación robusta sin componente visual.',
		image: 'https://images.unsplash.com/photo-1516280440614-37939bbacd81?auto=format&fit=crop&w=1200&q=80',
	},
];

const dimensions = [
	{ value: 'Pequeño (hasta 50 m²)', title: 'Pequeño', desc: 'Hasta 50 m²', image: 'https://images.unsplash.com/photo-1556761175-b413da4baf72?auto=format&fit=crop&w=1200&q=80' },
	{ value: 'Mediano (50-150 m²)', title: 'Mediano', desc: '50-150 m²', image: 'https://images.unsplash.com/photo-1497366811353-6870744d04b2?auto=format&fit=crop&w=1200&q=80' },
	{ value: 'Grande (Más de 150 m²)', title: 'Grande', desc: 'Más de 150 m²', image: 'https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&w=1200&q=80' },
];

const purposes = [
	{ value: 'Audio de evacuación/avisos', title: 'Audio de evacuación/avisos', desc: 'Inteligibilidad, zonas y continuidad operativa.', image: 'https://images.unsplash.com/photo-1517048676732-d65bc937f952?auto=format&fit=crop&w=1200&q=80' },
	{ value: 'Videoconferencias claras', title: 'Videoconferencias claras', desc: 'Captura de voz, cámara, pantalla y control.', image: 'https://images.unsplash.com/photo-1556761175-4b46a572b786?auto=format&fit=crop&w=1200&q=80' },
	{ value: 'Música ambiental de alta fidelidad', title: 'Música ambiental de alta fidelidad', desc: 'Cobertura equilibrada y experiencia sonora premium.', image: 'https://images.unsplash.com/photo-1514933651103-005eec06c04b?auto=format&fit=crop&w=1200&q=80' },
];
---

<Layout
	title="Configurador Audiovisual | Mizo"
	description="Aplicación configuradora de sistemas audiovisuales corporativos para plantas industriales, salas, auditorios y locales comerciales."
>
	<section class="min-h-[calc(100vh-12rem)] bg-slate-50 font-sans">
		<div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
			<div class="mb-8 grid gap-6 lg:grid-cols-[1fr_auto] lg:items-end">
				<div>
					<span class="inline-flex rounded-full bg-sky-100 px-4 py-2 text-xs font-black uppercase tracking-[0.22em] text-[#0284c7]">
						Aplicación Configuradora Mizo
					</span>
					<h1 class="mt-4 max-w-4xl text-4xl font-black tracking-tight text-slate-950 md:text-6xl">
						Diseña tu solución audiovisual de nivel corporativo.
					</h1>
					<p class="mt-4 max-w-2xl text-lg leading-8 text-slate-600">
						Responde tres decisiones clave y nuestro sistema preparará una base técnica para que un ingeniero de Mizo valide tu proyecto.
					</p>
				</div>
				<div class="rounded-3xl border border-slate-200 bg-white p-4 shadow-sm">
					<p class="text-xs font-black uppercase tracking-[0.18em] text-slate-500">Contacto directo</p>
					<div class="mt-3 grid gap-2 text-sm font-bold text-slate-800">
						<a href="tel:+56994390870" class="hover:text-[#0284c7]">+56 9 9439 0870</a>
						<a href="mailto:ventas@mizo.cl" class="hover:text-[#0284c7]">ventas@mizo.cl</a>
						<a href="https://wa.me/56994390870?text=Hola%20Mizo,%20quiero%20usar%20el%20configurador%20audiovisual" target="_blank" rel="noopener noreferrer" class="text-green-700 hover:text-green-800">WhatsApp inmediato</a>
					</div>
				</div>
			</div>

			<div class="overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-xl">
				<div class="border-b border-slate-200 bg-white p-5">
					<div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
						<div>
							<p class="text-sm font-black text-slate-950">Pre-configuración guiada</p>
							<p class="text-sm text-slate-500">Entorno, proyección condicional, dimensión, propósito y validación técnica.</p>
						</div>
						<div class="flex gap-2" aria-label="Progreso del configurador">
							{[1, 2, 3, 4].map((step) => (
								<span class="step-pill flex h-9 w-9 items-center justify-center rounded-full border border-slate-200 bg-slate-50 text-sm font-black text-slate-500" data-progress-step={step}>{step}</span>
							))}
						</div>
					</div>
				</div>

				<div class="relative min-h-[36rem] p-5 sm:p-8 lg:p-10">
					<div class="config-step" data-step="entorno">
						<div class="max-w-3xl">
							<p class="text-xs font-black uppercase tracking-[0.22em] text-[#0284c7]">Paso 1 · Entorno</p>
							<h2 class="mt-3 text-3xl font-black text-slate-950">¿Qué tipo de espacio necesitas equipar?</h2>
						</div>
						<div class="mt-8 grid gap-4 md:grid-cols-2">
							{environments.map((option) => (
								<button type="button" class="option-card visual-card group text-left" data-field="entorno" data-value={option.value} data-focus={option.focus} data-needs-projection={String(option.needsProjection)} style={`background-image: linear-gradient(135deg, rgba(15,23,42,0.86), rgba(2,132,199,0.36)), url('${option.image}');`}>
									<span class="inline-flex rounded-full bg-white/15 px-3 py-1 text-[0.65rem] font-black uppercase tracking-[0.18em] text-cyan-100 backdrop-blur">{option.focus}</span>
									<span class="mt-10 block text-2xl font-black text-white">{option.title}</span>
									<span class="mt-2 block text-sm leading-6 text-white/80">{option.desc}</span>
								</button>
							))}
						</div>
					</div>

					<div class="config-step hidden" data-step="proyeccion">
						<div class="max-w-3xl">
							<p class="text-xs font-black uppercase tracking-[0.22em] text-[#0284c7]">Sub-paso · Imagen profesional</p>
							<h2 class="mt-3 text-3xl font-black text-slate-950">¿Requiere Sistema de Proyección o Pantallas Profesionales?</h2>
							<p class="mt-3 text-base text-slate-500">Esta pregunta se activa para auditorios, teatros y salas corporativas.</p>
						</div>
						<div class="mt-8 grid gap-4 lg:grid-cols-3">
							{projectionOptions.map((option) => (
								<button type="button" class="option-card visual-card text-left" data-field="proyeccion" data-value={option.value} style={`background-image: linear-gradient(135deg, rgba(15,23,42,0.84), rgba(2,132,199,0.34)), url('${option.image}');`}>
									<span class="block text-xl font-black text-white">{option.title}</span>
									<span class="mt-3 block text-sm leading-6 text-white/80">{option.desc}</span>
								</button>
							))}
						</div>
					</div>

					<div class="config-step hidden" data-step="dimension">
						<div class="max-w-3xl">
							<p class="text-xs font-black uppercase tracking-[0.22em] text-[#0284c7]">Paso 2 · Dimensión</p>
							<h2 class="mt-3 text-3xl font-black text-slate-950">¿Cuál es la escala aproximada del espacio?</h2>
						</div>
						<div class="mt-8 grid gap-4 md:grid-cols-3">
							{dimensions.map((option) => (
								<button type="button" class="option-card visual-card text-left" data-field="dimension" data-value={option.value} style={`background-image: linear-gradient(135deg, rgba(15,23,42,0.82), rgba(2,132,199,0.26)), url('${option.image}');`}>
									<span class="block text-2xl font-black text-white">{option.title}</span>
									<span class="mt-2 block text-sm leading-6 text-white/80">{option.desc}</span>
								</button>
							))}
						</div>
					</div>

					<div class="config-step hidden" data-step="proposito">
						<div class="max-w-3xl">
							<p class="text-xs font-black uppercase tracking-[0.22em] text-[#0284c7]">Paso 3 · Propósito</p>
							<h2 class="mt-3 text-3xl font-black text-slate-950">¿Cuál es el objetivo principal del sistema?</h2>
						</div>
						<div class="mt-8 grid gap-4 lg:grid-cols-3">
							{purposes.map((option) => (
								<button type="button" class="option-card visual-card text-left" data-field="proposito" data-value={option.value} style={`background-image: linear-gradient(135deg, rgba(15,23,42,0.82), rgba(2,132,199,0.26)), url('${option.image}');`}>
									<span class="block text-xl font-black text-white">{option.title}</span>
									<span class="mt-2 block text-sm leading-6 text-white/80">{option.desc}</span>
								</button>
							))}
						</div>
					</div>

					<div class="config-step hidden" data-step="lead">
						<div id="loading-panel" class="flex min-h-[26rem] flex-col items-center justify-center text-center">
							<div class="h-16 w-16 animate-spin rounded-full border-4 border-slate-200 border-t-[#0284c7]"></div>
							<p class="mt-6 text-xl font-black text-slate-950">Calculando pre-configuración óptima...</p>
							<p class="mt-2 max-w-xl text-sm text-slate-500">Cruzando entorno, dimensión y propósito para preparar la validación técnica.</p>
						</div>

						<div id="lead-panel" class="hidden">
							<div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
								<div class="rounded-3xl bg-slate-950 p-6 text-white">
									<p class="text-xs font-black uppercase tracking-[0.22em] text-cyan-200">Paso 4 · Validación técnica</p>
									<h2 class="mt-3 text-3xl font-black text-white">Tu configuración requiere revisión de ingeniería.</h2>
									<p class="mt-4 text-base leading-7 text-slate-300">
										Para garantizar que esta configuración responda perfectamente a la acústica y estructura de tu espacio, un Ingeniero de Mizo debe validar los coeficientes. Te contactaremos en menos de 2 horas
									</p>
									<div class="mt-6 space-y-3 text-sm">
										<p><strong>Entorno:</strong> <span data-summary="entorno">-</span></p>
										<p><strong>Especialidad:</strong> <span data-summary="entornoDetalle">-</span></p>
										<p><strong>Proyección / Pantallas:</strong> <span data-summary="proyeccion">-</span></p>
										<p><strong>Dimensión:</strong> <span data-summary="dimension">-</span></p>
										<p><strong>Propósito:</strong> <span data-summary="proposito">-</span></p>
									</div>
								</div>

								<form id="configurator-form" class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
									<input type="text" name="website" class="hidden" tabindex="-1" autocomplete="off" aria-hidden="true">
									<input type="hidden" name="espacio" data-hidden-field="entorno">
									<input type="hidden" name="especialidad" data-hidden-field="entornoDetalle">
									<input type="hidden" name="proyeccion" data-hidden-field="proyeccion">
									<input type="hidden" name="dimension" data-hidden-field="dimension">
									<input type="hidden" name="proposito" data-hidden-field="proposito">
									<input type="hidden" name="pack" value="Configurador audiovisual Mizo">
									<input type="hidden" name="detalles" data-hidden-field="detalles">

									<div class="grid gap-4 sm:grid-cols-2">
										<label class="block">
											<span class="text-sm font-black text-slate-700">Nombre</span>
											<input name="nombre" required type="text" autocomplete="name" class="mt-1 w-full rounded-2xl border border-slate-300 px-4 py-3 text-sm outline-none transition focus:border-[#0284c7] focus:ring-4 focus:ring-sky-100">
										</label>
										<label class="block">
											<span class="text-sm font-black text-slate-700">Empresa</span>
											<input name="empresa" required type="text" autocomplete="organization" class="mt-1 w-full rounded-2xl border border-slate-300 px-4 py-3 text-sm outline-none transition focus:border-[#0284c7] focus:ring-4 focus:ring-sky-100">
										</label>
										<label class="block">
											<span class="text-sm font-black text-slate-700">Teléfono</span>
											<input name="telefono" required type="tel" autocomplete="tel" class="mt-1 w-full rounded-2xl border border-slate-300 px-4 py-3 text-sm outline-none transition focus:border-[#0284c7] focus:ring-4 focus:ring-sky-100">
										</label>
										<label class="block">
											<span class="text-sm font-black text-slate-700">Correo</span>
											<input name="correo" required type="email" autocomplete="email" class="mt-1 w-full rounded-2xl border border-slate-300 px-4 py-3 text-sm outline-none transition focus:border-[#0284c7] focus:ring-4 focus:ring-sky-100">
										</label>
									</div>

									<button id="configurator-submit" type="submit" class="mt-6 inline-flex w-full items-center justify-center rounded-2xl bg-[#0284c7] px-6 py-4 text-sm font-black text-white shadow-lg transition hover:bg-sky-700 disabled:cursor-not-allowed disabled:opacity-60">
										Solicitar validación de ingeniería
									</button>
									<p id="configurator-status" class="mt-4 hidden rounded-2xl px-4 py-3 text-sm font-bold"></p>
									<p class="mt-4 text-center text-xs font-semibold text-slate-400">Tus datos se usan únicamente para responder esta solicitud técnica.</p>
								</form>
							</div>
						</div>
					</div>

					<div class="mt-8 flex items-center justify-between border-t border-slate-200 pt-6">
						<button id="prev-step" type="button" class="rounded-full border border-slate-200 px-5 py-3 text-sm font-black text-slate-600 transition hover:border-[#0284c7] hover:text-[#0284c7] disabled:cursor-not-allowed disabled:opacity-40">Volver</button>
						<p class="text-sm font-bold text-slate-400"><span id="step-label">Paso 1</span></p>
					</div>
				</div>
			</div>
		</div>
	</section>
</Layout>

<style>
	.option-card {
		border: 1px solid #e2e8f0;
		border-radius: 1.5rem;
		background: #ffffff;
		padding: 1.5rem;
		box-shadow: 0 10px 30px rgb(15 23 42 / 0.04);
		transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease, background 180ms ease;
	}
	.option-card:hover,
	.option-card.is-selected {
		border-color: #0284c7;
		background: #f0f9ff;
		box-shadow: 0 18px 40px rgb(2 132 199 / 0.14);
		transform: translateY(-2px);
	}
	.visual-card {
		min-height: 15rem;
		background-position: center;
		background-size: cover;
		color: #ffffff;
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		overflow: hidden;
	}
	.visual-card.is-selected {
		outline: 3px solid #0284c7;
		outline-offset: 3px;
	}
	.config-step {
		animation: configuratorFade 260ms ease both;
	}
	@keyframes configuratorFade {
		from { opacity: 0; transform: translateY(8px); }
		to { opacity: 1; transform: translateY(0); }
	}
</style>

<script is:inline>
	(function () {
		const state = {
			entorno: '',
			entornoDetalle: '',
			proyeccion: 'No aplica',
			dimension: '',
			proposito: '',
			requiresProjection: false,
		};
		let currentStep = 'entorno';
		const history = [];
		const steps = Array.from(document.querySelectorAll('.config-step'));
		const progress = Array.from(document.querySelectorAll('[data-progress-step]'));
		const prev = document.getElementById('prev-step');
		const label = document.getElementById('step-label');
		const loadingPanel = document.getElementById('loading-panel');
		const leadPanel = document.getElementById('lead-panel');
		const form = document.getElementById('configurator-form');
		const submit = document.getElementById('configurator-submit');
		const status = document.getElementById('configurator-status');

		function detailsText() {
			return `Configurador audiovisual Mizo | Entorno: ${state.entorno} | Especialidad: ${state.entornoDetalle} | Proyección/Pantallas: ${state.proyeccion} | Dimensión: ${state.dimension} | Propósito: ${state.proposito}`;
		}

		function visibleStepNumber() {
			if (currentStep === 'entorno') return 1;
			if (currentStep === 'proyeccion') return 1;
			if (currentStep === 'dimension') return 2;
			if (currentStep === 'proposito') return 3;
			return 4;
		}

		function visibleStepLabel() {
			if (currentStep === 'proyeccion') return 'Sub-paso de imagen profesional';
			return `Paso ${visibleStepNumber()} de 4`;
		}

		function goTo(nextStep) {
			if (nextStep !== currentStep) history.push(currentStep);
			currentStep = nextStep;
			render();
		}

		function nextStepFor(field) {
			if (field === 'entorno') return state.requiresProjection ? 'proyeccion' : 'dimension';
			if (field === 'proyeccion') return 'dimension';
			if (field === 'dimension') return 'proposito';
			if (field === 'proposito') return 'lead';
			return 'entorno';
		}

		function updateHiddenFields() {
			document.querySelectorAll('[data-hidden-field]').forEach((input) => {
				const key = input.dataset.hiddenField;
				input.value = key === 'detalles' ? detailsText() : (state[key] || '');
			});
			document.querySelectorAll('[data-summary]').forEach((item) => {
				item.textContent = state[item.dataset.summary] || '-';
			});
		}

		function render() {
			steps.forEach((item) => item.classList.toggle('hidden', item.dataset.step !== currentStep));
			const stepNumber = visibleStepNumber();
			progress.forEach((item) => {
				const active = Number(item.dataset.progressStep) <= stepNumber;
				item.classList.toggle('bg-[#0284c7]', active);
				item.classList.toggle('border-[#0284c7]', active);
				item.classList.toggle('text-white', active);
				item.classList.toggle('bg-slate-50', !active);
				item.classList.toggle('border-slate-200', !active);
				item.classList.toggle('text-slate-500', !active);
			});
			if (label) label.textContent = visibleStepLabel();
			if (prev) prev.disabled = history.length === 0;
			if (currentStep === 'lead') {
				updateHiddenFields();
				loadingPanel.classList.remove('hidden');
				leadPanel.classList.add('hidden');
				window.setTimeout(() => {
					loadingPanel.classList.add('hidden');
					leadPanel.classList.remove('hidden');
				}, 1100);
			}
		}

		document.querySelectorAll('[data-field]').forEach((button) => {
			button.addEventListener('click', () => {
				const field = button.dataset.field;
				state[field] = button.dataset.value || '';
				if (field === 'entorno') {
					state.entornoDetalle = button.dataset.focus || '';
					state.requiresProjection = button.dataset.needsProjection === 'true';
					state.proyeccion = state.requiresProjection ? '' : 'No aplica';
				}
				document.querySelectorAll(`[data-field="${field}"]`).forEach((item) => item.classList.toggle('is-selected', item === button));
				goTo(nextStepFor(field));
			});
		});

		if (prev) {
			prev.addEventListener('click', () => {
				if (!history.length) return;
				currentStep = history.pop();
				render();
			});
		}

		function showStatus(message, error) {
			status.textContent = message;
			status.className = `mt-4 rounded-2xl px-4 py-3 text-sm font-bold ${error ? 'bg-red-50 text-red-700' : 'bg-emerald-50 text-emerald-700'}`;
		}

		if (form) {
			form.addEventListener('submit', async (event) => {
				event.preventDefault();
				updateHiddenFields();
				submit.disabled = true;
				submit.textContent = 'Enviando a ingeniería...';
				try {
					const data = Object.fromEntries(new FormData(form).entries());
					const response = await fetch('/api/enviar-cotizacion-proyecto.php', {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify(data),
					});
					const payload = await response.json().catch(() => null);
					if (!response.ok || !payload?.ok) throw new Error(payload?.error || 'No se pudo enviar la solicitud.');
					form.reset();
					updateHiddenFields();
					showStatus(payload.message || 'Solicitud recibida. Un ingeniero de Mizo te contactará en menos de 2 horas.', false);
				} catch (error) {
					showStatus(error.message || 'No se pudo enviar la solicitud.', true);
				} finally {
					submit.disabled = false;
					submit.textContent = 'Solicitar validación de ingeniería';
				}
			});
		}

		render();
	})();
</script>
