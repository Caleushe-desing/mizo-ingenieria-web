---
import Layout from '../layouts/Layout.astro';

const environments = [
	{
		id: 'auditorio',
		title: 'Auditorio / Teatro',
		label: 'Auditorio',
		desc: 'Proyección avanzada, acústica arquitectónica e inteligibilidad para alta concurrencia.',
		image: 'https://images.unsplash.com/photo-1507901747481-84a4f64fda6d?auto=format&fit=crop&w=1400&q=80',
	},
	{
		id: 'gimnasio',
		title: 'Gimnasio / Espacio Deportivo',
		label: 'Gimnasio',
		desc: 'Alta potencia, dispersión controlada y cobertura sonora en recintos reverberantes.',
		image: 'https://images.unsplash.com/photo-1546519638-68e109498ffc?auto=format&fit=crop&w=1400&q=80',
	},
	{
		id: 'sala',
		title: 'Sala Corporativa',
		label: 'Sala Corporativa',
		desc: 'Videoconferencia inteligente, visualización profesional y operación ejecutiva simple.',
		image: 'https://images.unsplash.com/photo-1497366754035-f200968a6e72?auto=format&fit=crop&w=1400&q=80',
	},
	{
		id: 'planta',
		title: 'Planta Industrial / Logística',
		label: 'Planta Industrial',
		desc: 'Voceo IP, audio de evacuación, zonas operativas y continuidad para espacios críticos.',
		image: 'https://images.unsplash.com/photo-1581093458791-9d09cc08742a?auto=format&fit=crop&w=1400&q=80',
	},
];

const specialties = [
	{ id: 'audio', title: 'Audio', desc: 'Cobertura, SPL, inteligibilidad, microfonía y amplificación.' },
	{ id: 'video', title: 'Video', desc: 'Proyección, pantallas profesionales, videowall, cámaras y visualización.' },
	{ id: 'ambos', title: 'Audio + Video', desc: 'Parlantes, amplificación, proyección, pantalla profesional y conectividad.' },
];

const sizes = [
	{ id: 'pequeno', title: 'Pequeño', desc: 'Hasta 50 m²' },
	{ id: 'mediano', title: 'Mediano', desc: '50-150 m²' },
	{ id: 'grande', title: 'Grande', desc: 'Más de 150 m²' },
];
---

<Layout
	title="Software de Pre-Diseño Audiovisual | Mizo"
	description="Configura una propuesta técnica preliminar con motor de cálculo para soluciones de ingeniería audiovisual Mizo."
>
	<section class="min-h-[calc(100vh-12rem)] bg-slate-950 text-white">
		<div class="absolute inset-0 -z-10 opacity-20" style="background-image: radial-gradient(#0284c7 1px, transparent 1px); background-size: 26px 26px;"></div>
		<div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
			<div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-end">
				<div>
					<span class="inline-flex rounded-full border border-white/15 bg-white/10 px-4 py-2 text-xs font-black uppercase tracking-[0.22em] text-cyan-100 backdrop-blur">
						Software de pre-diseño de ingeniería
					</span>
					<h1 class="mt-5 max-w-4xl text-4xl font-black leading-tight text-white md:text-6xl">
						Simula tu sistema audiovisual con lógica técnica Mizo.
					</h1>
					<p class="mt-4 max-w-2xl text-lg leading-8 text-slate-300">
						Selecciona entorno, especialidad y tamaño. Nuestro motor calcula una propuesta preliminar con equipamiento recomendado antes de la validación en terreno.
					</p>
				</div>
				<div class="grid gap-3 rounded-[2rem] border border-white/10 bg-white/10 p-5 backdrop-blur md:grid-cols-3">
					<div>
						<p class="text-3xl font-black text-cyan-200">SPL</p>
						<p class="mt-1 text-sm text-slate-300">Presión sonora estimada</p>
					</div>
					<div>
						<p class="text-3xl font-black text-cyan-200">AV</p>
						<p class="mt-1 text-sm text-slate-300">Audio, video y control</p>
					</div>
					<div>
						<p class="text-3xl font-black text-cyan-200">2h</p>
						<p class="mt-1 text-sm text-slate-300">Contacto comercial</p>
					</div>
				</div>
			</div>

			<div class="mt-8 overflow-hidden rounded-[2rem] border border-white/10 bg-white text-slate-950 shadow-2xl">
				<div class="grid gap-0 lg:grid-cols-[360px_1fr]">
					<aside class="bg-slate-100 p-5 lg:p-7">
						<p class="text-xs font-black uppercase tracking-[0.2em] text-[#0284c7]">Matriz técnica</p>
						<h2 class="mt-3 text-2xl font-black text-slate-950">Variables de diseño</h2>
						<div class="mt-6 space-y-3 text-sm">
							<div class="rounded-2xl bg-white p-4 shadow-sm">
								<p class="font-black text-slate-950">Entorno</p>
								<p data-current="entorno" class="mt-1 text-slate-500">No seleccionado</p>
							</div>
							<div class="rounded-2xl bg-white p-4 shadow-sm">
								<p class="font-black text-slate-950">Especialidad</p>
								<p data-current="especialidad" class="mt-1 text-slate-500">No seleccionado</p>
							</div>
							<div class="rounded-2xl bg-white p-4 shadow-sm">
								<p class="font-black text-slate-950">Tamaño</p>
								<p data-current="tamano" class="mt-1 text-slate-500">No seleccionado</p>
							</div>
						</div>
						<button id="run-engine" type="button" disabled class="mt-6 inline-flex w-full items-center justify-center rounded-2xl bg-[#0284c7] px-5 py-4 text-sm font-black text-white shadow-lg transition hover:bg-sky-700 disabled:cursor-not-allowed disabled:bg-slate-300">
							Ejecutar pre-diseño IA
						</button>
					</aside>

					<div class="p-5 sm:p-8 lg:p-10">
						<div id="selector-panel">
							<div class="mb-8">
								<p class="text-xs font-black uppercase tracking-[0.22em] text-[#0284c7]">Paso 1 · Entorno</p>
								<h2 class="mt-3 text-3xl font-black text-slate-950">Define el recinto a intervenir.</h2>
							</div>
							<div class="grid gap-4 md:grid-cols-2">
								{environments.map((item) => (
									<button type="button" class="visual-option text-left" data-select="entorno" data-id={item.id} data-label={item.label} style={`background-image: linear-gradient(135deg, rgba(15,23,42,.88), rgba(2,132,199,.28)), url('${item.image}');`}>
										<span class="text-2xl font-black text-white">{item.title}</span>
										<span class="mt-3 block text-sm leading-6 text-white/80">{item.desc}</span>
									</button>
								))}
							</div>

							<div class="mt-10">
								<p class="text-xs font-black uppercase tracking-[0.22em] text-[#0284c7]">Paso 2 · Especialidad</p>
								<h2 class="mt-3 text-3xl font-black text-slate-950">Selecciona el alcance técnico.</h2>
								<div class="mt-5 grid gap-4 lg:grid-cols-3">
									{specialties.map((item) => (
										<button type="button" class="logic-option text-left" data-select="especialidad" data-id={item.id} data-label={item.title}>
											<span class="text-xl font-black text-slate-950">{item.title}</span>
											<span class="mt-2 block text-sm leading-6 text-slate-500">{item.desc}</span>
										</button>
									))}
								</div>
							</div>

							<div class="mt-10">
								<p class="text-xs font-black uppercase tracking-[0.22em] text-[#0284c7]">Paso 3 · Tamaño</p>
								<h2 class="mt-3 text-3xl font-black text-slate-950">Indica la escala aproximada.</h2>
								<div class="mt-5 grid gap-4 lg:grid-cols-3">
									{sizes.map((item) => (
										<button type="button" class="logic-option text-left" data-select="tamano" data-id={item.id} data-label={item.title}>
											<span class="text-xl font-black text-slate-950">{item.title}</span>
											<span class="mt-2 block text-sm leading-6 text-slate-500">{item.desc}</span>
										</button>
									))}
								</div>
							</div>
						</div>

						<div id="analysis-panel" class="hidden min-h-[34rem] flex-col items-center justify-center text-center">
							<div class="relative h-28 w-28">
								<div class="absolute inset-0 rounded-full border-4 border-sky-100"></div>
								<div class="absolute inset-0 animate-spin rounded-full border-4 border-transparent border-t-[#0284c7]"></div>
								<div class="absolute inset-5 rounded-full bg-[#0284c7]/10"></div>
							</div>
							<p class="mt-8 text-xs font-black uppercase tracking-[0.22em] text-[#0284c7]">Motor IA Mizo</p>
							<p id="analysis-text" class="mt-3 max-w-2xl text-3xl font-black text-slate-950">Inicializando matriz técnica...</p>
							<div class="mt-8 h-2 w-full max-w-xl overflow-hidden rounded-full bg-slate-100">
								<div id="analysis-bar" class="h-full w-0 rounded-full bg-[#0284c7] transition-all duration-500"></div>
							</div>
						</div>

						<div id="result-panel" class="hidden">
							<div class="rounded-[2rem] border border-slate-200 bg-slate-50 p-5 sm:p-7">
								<p class="text-xs font-black uppercase tracking-[0.22em] text-[#0284c7]">Informe Técnico Preliminar de Ingeniería</p>
								<div class="mt-4 grid gap-5 lg:grid-cols-[1fr_auto] lg:items-start">
									<div>
										<h2 id="report-title" class="text-3xl font-black text-slate-950">Pre-diseño generado</h2>
										<p id="report-summary" class="mt-3 max-w-3xl text-base leading-7 text-slate-600"></p>
									</div>
									<button id="restart-engine" type="button" class="rounded-full border border-slate-300 px-5 py-3 text-sm font-black text-slate-700 transition hover:border-[#0284c7] hover:text-[#0284c7]">
										Recalcular
									</button>
								</div>

								<div class="mt-6 grid gap-3 md:grid-cols-3">
									<div class="rounded-2xl bg-white p-4 shadow-sm">
										<p class="text-xs font-black uppercase text-slate-400">Entorno</p>
										<p id="result-entorno" class="mt-1 font-black text-slate-950"></p>
									</div>
									<div class="rounded-2xl bg-white p-4 shadow-sm">
										<p class="text-xs font-black uppercase text-slate-400">Especialidad</p>
										<p id="result-especialidad" class="mt-1 font-black text-slate-950"></p>
									</div>
									<div class="rounded-2xl bg-white p-4 shadow-sm">
										<p class="text-xs font-black uppercase text-slate-400">Tamaño</p>
										<p id="result-tamano" class="mt-1 font-black text-slate-950"></p>
									</div>
								</div>
							</div>

							<div class="mt-6 overflow-hidden rounded-[2rem] border border-slate-200 bg-white">
								<div class="border-b border-slate-200 bg-slate-950 px-5 py-4 text-white">
									<p class="text-sm font-black">Equipamiento recomendado por algoritmo</p>
								</div>
								<div id="equipment-list" class="divide-y divide-slate-100"></div>
							</div>

							<div class="mt-6 grid gap-6 lg:grid-cols-[0.95fr_1.05fr]">
								<div class="rounded-[2rem] bg-slate-950 p-6 text-white">
									<p class="text-xs font-black uppercase tracking-[0.22em] text-cyan-200">Validación obligatoria</p>
									<h3 class="mt-3 text-2xl font-black text-white">Cierre técnico antes de compra.</h3>
									<p class="mt-4 text-sm leading-7 text-slate-300">
										Este reporte ha sido generado mediante algoritmos automáticos de cobertura estándar. Sin embargo, para garantizar que la dispersión acústica exacta, las zonas muertas de audio y los ángulos de visión sean 100% compatibles con la estructura física y acústica real de tu espacio, un Ingeniero de Mizo debe validar este informe en terreno antes de la compra. Ingresa tus datos para agendar la visita y enviarte el plano de conectividad
									</p>
								</div>

								<form id="lead-form" class="rounded-[2rem] border-2 border-[#0284c7] bg-white p-6 shadow-xl shadow-sky-900/10">
									<input type="text" name="website" class="hidden" tabindex="-1" autocomplete="off" aria-hidden="true">
									<input type="hidden" name="pack" value="Software de Pre-Diseño IA Mizo">
									<input type="hidden" name="espacio" id="lead-espacio">
									<input type="hidden" name="especialidad" id="lead-especialidad">
									<input type="hidden" name="dimension" id="lead-dimension">
									<input type="hidden" name="proposito" id="lead-proposito">
									<input type="hidden" name="productos" id="lead-productos">
									<input type="hidden" name="detalles" id="lead-detalles">

									<div class="grid gap-4 sm:grid-cols-2">
										<label class="block">
											<span class="text-sm font-black text-slate-700">Nombre</span>
											<input name="nombre" required type="text" autocomplete="name" class="mt-1 w-full rounded-2xl border border-slate-300 px-4 py-3 text-sm outline-none transition focus:border-[#0284c7] focus:ring-4 focus:ring-sky-100">
										</label>
										<label class="block">
											<span class="text-sm font-black text-slate-700">Empresa</span>
											<input name="empresa" required type="text" autocomplete="organization" class="mt-1 w-full rounded-2xl border border-slate-300 px-4 py-3 text-sm outline-none transition focus:border-[#0284c7] focus:ring-4 focus:ring-sky-100">
										</label>
										<label class="block">
											<span class="text-sm font-black text-slate-700">Teléfono</span>
											<input name="telefono" required type="tel" autocomplete="tel" class="mt-1 w-full rounded-2xl border border-slate-300 px-4 py-3 text-sm outline-none transition focus:border-[#0284c7] focus:ring-4 focus:ring-sky-100">
										</label>
										<label class="block">
											<span class="text-sm font-black text-slate-700">Correo</span>
											<input name="correo" required type="email" autocomplete="email" class="mt-1 w-full rounded-2xl border border-slate-300 px-4 py-3 text-sm outline-none transition focus:border-[#0284c7] focus:ring-4 focus:ring-sky-100">
										</label>
									</div>
									<button id="lead-submit" type="submit" class="mt-6 inline-flex w-full items-center justify-center rounded-2xl bg-[#0284c7] px-6 py-4 text-sm font-black text-white shadow-lg transition hover:bg-sky-700 disabled:cursor-not-allowed disabled:opacity-60">
										Agendar visita y recibir plano de conectividad
									</button>
									<p id="lead-status" class="mt-4 hidden rounded-2xl px-4 py-3 text-sm font-bold"></p>
								</form>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>
</Layout>

<style>
	.visual-option,
	.logic-option {
		border: 1px solid #e2e8f0;
		border-radius: 1.5rem;
		box-shadow: 0 12px 34px rgb(15 23 42 / 0.06);
		transition: border-color 180ms ease, box-shadow 180ms ease, transform 180ms ease;
	}
	.visual-option {
		min-height: 17rem;
		background-position: center;
		background-size: cover;
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		padding: 1.5rem;
	}
	.logic-option {
		background: #ffffff;
		padding: 1.25rem;
	}
	.visual-option:hover,
	.visual-option.is-selected,
	.logic-option:hover,
	.logic-option.is-selected {
		border-color: #0284c7;
		box-shadow: 0 18px 46px rgb(2 132 199 / 0.18);
		transform: translateY(-2px);
	}
	.visual-option.is-selected,
	.logic-option.is-selected {
		outline: 3px solid #0284c7;
		outline-offset: 3px;
	}
</style>

<script is:inline>
	(function () {
		const analysisMessages = [
			'IA analizando volumen de aire...',
			'Calculando presión sonora (SPL) necesaria...',
			'Evaluando tiro y lúmenes de proyección...',
			'Sincronizando con catálogo maestro Mizo...',
		];

		const designMatrix = {
			'gimnasio|grande|audio': {
				title: 'Pre-diseño deportivo con audio profesional de alta potencia',
				summary: 'La matriz detectó un recinto deportivo grande con prioridad de audio. Se recomienda arquitectura de alta potencia con dispersión controlada, rack dedicado y microfonía robusta para operación deportiva.',
				equipment: [
					{ qty: 2, unit: 'unidades', name: 'Sistemas de Arreglo Lineal Compacto (Line Array)', note: 'Cobertura principal para gradas y cancha con dispersión controlada.' },
					{ qty: 1, unit: 'unidad', name: 'Rack de Amplificación Profesional de 3200W', note: 'Potencia estimada para alta presión sonora en recintos deportivos.' },
					{ qty: 1, unit: 'unidad', name: 'Consola de Mezcla Behringer con Micrófono UHF Shure', note: 'Operación de eventos, locución deportiva y actividades masivas.' },
				],
			},
			'auditorio|mediano|ambos': {
				title: 'Pre-diseño audiovisual para auditorio mediano',
				summary: 'La matriz detectó un auditorio mediano con necesidad audiovisual completa. Se recomienda proyección láser, pantalla eléctrica y audio de cobertura controlada para inteligibilidad y operación corporativa.',
				equipment: [
					{ qty: 1, unit: 'unidad', name: 'Proyector Láser Profesional (6000 Lúmenes)', note: 'Brillo recomendado para sala mediana con presentaciones críticas.' },
					{ qty: 1, unit: 'unidad', name: 'Pantalla Eléctrica de Proyección 150 pulgadas', note: 'Formato para presentaciones y video institucional.' },
					{ qty: 4, unit: 'unidades', name: 'Parlantes de Cobertura Controlada', note: 'Distribución frontal/lateral para audiencia.' },
					{ qty: 1, unit: 'unidad', name: 'Amplificador Digital Crown', note: 'Potencia y control para parlantes de cobertura controlada.' },
				],
			},
			'sala|pequeno|video': {
				title: 'Pre-diseño para sala corporativa compacta con video IA',
				summary: 'La matriz detectó una sala pequeña orientada a video. Se recomienda una solución todo en uno con tracking IA y pantalla profesional para reuniones híbridas limpias.',
				equipment: [
					{ qty: 1, unit: 'unidad', name: 'Barra de Video Inteligente Logitech Rally con Tracking IA', note: 'Cámara, micrófonos y encuadre automático para reuniones híbridas.' },
					{ qty: 1, unit: 'unidad', name: 'Pantalla Profesional LED 65 pulgadas 4K', note: 'Visualización corporativa para reuniones ejecutivas.' },
				],
			},
			'sala|pequeno|ambos': {
				title: 'Pre-diseño para sala corporativa compacta con audio y video IA',
				summary: 'La matriz detectó una sala pequeña con necesidad audiovisual completa. Se recomienda video inteligente con tracking IA y visualización profesional 4K para reuniones híbridas.',
				equipment: [
					{ qty: 1, unit: 'unidad', name: 'Barra de Video Inteligente Logitech Rally con Tracking IA', note: 'Cámara, micrófonos y encuadre automático para reuniones híbridas.' },
					{ qty: 1, unit: 'unidad', name: 'Pantalla Profesional LED 65 pulgadas 4K', note: 'Visualización corporativa para reuniones ejecutivas.' },
				],
			},
		};

		const fallbacks = {
			audio: [
				{ qty: 4, unit: 'unidades', name: 'Parlantes de Muro de Alta Presión', note: 'Cantidad base ajustable por cálculo acústico.' },
				{ qty: 1, unit: 'unidad', name: 'Amplificador de Potencia Digital con DSP', note: 'Limitación, ecualización y protección de parlantes.' },
				{ qty: 1, unit: 'unidad', name: 'Micrófono Inalámbrico UHF Shure', note: 'Operación vocal, avisos y presentaciones.' },
			],
			video: [
				{ qty: 1, unit: 'unidad', name: 'Proyector Láser Profesional o Pantalla LED Profesional', note: 'Selección final según distancia de visión y luminosidad.' },
				{ qty: 1, unit: 'unidad', name: 'Kit de Conectividad HDMI/USB-C Profesional', note: 'Integración de notebooks, cámaras y fuentes de presentación.' },
				{ qty: 1, unit: 'unidad', name: 'Controlador de Presentación Audiovisual', note: 'Gestión de encendido, fuentes y escenas.' },
			],
			ambos: [
				{ qty: 4, unit: 'unidades', name: 'Parlantes de Cobertura Controlada', note: 'Cobertura inicial estimada para audiencia o zona de trabajo.' },
				{ qty: 1, unit: 'unidad', name: 'Amplificador de Potencia Digital con DSP', note: 'Potencia, limitación y ecualización para audio profesional.' },
				{ qty: 1, unit: 'unidad', name: 'Proyector Láser Profesional o Pantalla LED Profesional', note: 'Definición final por ángulos de visión y luminosidad.' },
				{ qty: 1, unit: 'unidad', name: 'Consola de Audio Digital', note: 'Operación de entradas, micrófonos y niveles de sala.' },
			],
		};

		const state = {
			entorno: null,
			especialidad: null,
			tamano: null,
			report: null,
		};

		const selectorPanel = document.getElementById('selector-panel');
		const analysisPanel = document.getElementById('analysis-panel');
		const resultPanel = document.getElementById('result-panel');
		const runButton = document.getElementById('run-engine');
		const restartButton = document.getElementById('restart-engine');
		const analysisText = document.getElementById('analysis-text');
		const analysisBar = document.getElementById('analysis-bar');
		const equipmentList = document.getElementById('equipment-list');
		const form = document.getElementById('lead-form');
		const submit = document.getElementById('lead-submit');
		const status = document.getElementById('lead-status');

		function updateCurrentLabels() {
			document.querySelector('[data-current="entorno"]').textContent = state.entorno?.label || 'No seleccionado';
			document.querySelector('[data-current="especialidad"]').textContent = state.especialidad?.label || 'No seleccionado';
			document.querySelector('[data-current="tamano"]').textContent = state.tamano?.label || 'No seleccionado';
			runButton.disabled = !(state.entorno && state.especialidad && state.tamano);
		}

		function selectOption(button) {
			const group = button.dataset.select;
			const value = { id: button.dataset.id, label: button.dataset.label };
			state[group] = value;
			document.querySelectorAll(`[data-select="${group}"]`).forEach((item) => item.classList.toggle('is-selected', item === button));
			updateCurrentLabels();
		}

		function calculateDesign() {
			const key = `${state.entorno.id}|${state.tamano.id}|${state.especialidad.id}`;
			const direct = designMatrix[key];
			if (direct) return direct;
			const scaleQty = state.tamano.id === 'grande' ? 2 : 1;
			const base = fallbacks[state.especialidad.id] || fallbacks.ambos;
			return {
				title: `Pre-diseño ${state.entorno.label} ${state.tamano.label}`,
				summary: `La matriz IA generó una propuesta preliminar para ${state.entorno.label}, tamaño ${state.tamano.label}, con especialidad ${state.especialidad.label}. La ingeniería final debe validar cobertura, cableado y condiciones físicas.`,
				equipment: base.map((item) => ({ ...item, qty: Math.max(1, item.qty * scaleQty) })),
			};
		}

		function productText(report) {
			return report.equipment.map((item) => `${item.qty} ${item.unit.toUpperCase()} - ${item.name} (${item.note})`).join('\n');
		}

		function fillLeadFields(report) {
			document.getElementById('lead-espacio').value = state.entorno.label;
			document.getElementById('lead-especialidad').value = state.especialidad.label;
			document.getElementById('lead-dimension').value = state.tamano.label;
			document.getElementById('lead-proposito').value = 'Pre-diseño IA de equipamiento audiovisual';
			document.getElementById('lead-productos').value = productText(report);
			document.getElementById('lead-detalles').value = [
				`Informe: ${report.title}`,
				`Entorno: ${state.entorno.label}`,
				`Especialidad: ${state.especialidad.label}`,
				`Tamaño: ${state.tamano.label}`,
				'Equipamiento:',
				productText(report),
			].join('\n');
		}

		function renderReport(report) {
			document.getElementById('report-title').textContent = report.title;
			document.getElementById('report-summary').textContent = report.summary;
			document.getElementById('result-entorno').textContent = state.entorno.label;
			document.getElementById('result-especialidad').textContent = state.especialidad.label;
			document.getElementById('result-tamano').textContent = state.tamano.label;
			equipmentList.innerHTML = report.equipment.map((item) => `
				<div class="grid gap-4 px-5 py-4 sm:grid-cols-[7rem_1fr] sm:items-center">
					<div class="rounded-2xl bg-[#0284c7] px-4 py-3 text-center text-white shadow-lg shadow-sky-900/15">
						<p class="text-2xl font-black">${item.qty}</p>
						<p class="text-xs font-black uppercase">${item.unit}</p>
					</div>
					<div>
						<p class="text-lg font-black text-slate-950">${item.name}</p>
						<p class="mt-1 text-sm leading-6 text-slate-500">${item.note}</p>
					</div>
				</div>
			`).join('') + '<div class="bg-slate-50 px-5 py-4 text-xs font-semibold italic text-slate-500">*Equipamiento referenciado de los catálogos técnicos de marcas oficiales distribuidas por Mizo.</div>';
			fillLeadFields(report);
		}

		function runAnalysis() {
			selectorPanel.classList.add('hidden');
			resultPanel.classList.add('hidden');
			analysisPanel.classList.remove('hidden');
			analysisPanel.classList.add('flex');
			analysisBar.style.width = '0%';
			let index = 0;
			analysisText.textContent = analysisMessages[0];
			const timer = window.setInterval(() => {
				index += 1;
				analysisBar.style.width = `${Math.min(100, (index / analysisMessages.length) * 100)}%`;
				if (index < analysisMessages.length) {
					analysisText.textContent = analysisMessages[index];
					return;
				}
				window.clearInterval(timer);
				state.report = calculateDesign();
				renderReport(state.report);
				analysisPanel.classList.add('hidden');
				analysisPanel.classList.remove('flex');
				resultPanel.classList.remove('hidden');
			}, 900);
		}

		function showStatus(message, error) {
			status.textContent = message;
			status.className = `mt-4 rounded-2xl px-4 py-3 text-sm font-bold ${error ? 'bg-red-50 text-red-700' : 'bg-emerald-50 text-emerald-700'}`;
		}

		document.querySelectorAll('[data-select]').forEach((button) => {
			button.addEventListener('click', () => selectOption(button));
		});

		runButton.addEventListener('click', runAnalysis);
		restartButton.addEventListener('click', () => {
			resultPanel.classList.add('hidden');
			selectorPanel.classList.remove('hidden');
		});

		form.addEventListener('submit', async (event) => {
			event.preventDefault();
			if (state.report) fillLeadFields(state.report);
			submit.disabled = true;
			submit.textContent = 'Enviando informe a ingeniería...';
			try {
				const data = Object.fromEntries(new FormData(form).entries());
				const response = await fetch('/api/enviar-cotizacion-proyecto.php', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify(data),
				});
				const payload = await response.json().catch(() => null);
				if (!response.ok || !payload?.ok) throw new Error(payload?.error || 'No se pudo enviar la solicitud.');
				form.reset();
				if (state.report) fillLeadFields(state.report);
				showStatus(payload.message || 'Informe enviado. Un ingeniero de Mizo te contactará en menos de 2 horas.', false);
			} catch (error) {
				showStatus(error.message || 'No se pudo enviar la solicitud.', true);
			} finally {
				submit.disabled = false;
				submit.textContent = 'Agendar visita y recibir plano de conectividad';
			}
		});

		updateCurrentLabels();
	})();
</script>
