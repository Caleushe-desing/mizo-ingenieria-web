---
import Layout from '../layouts/Layout.astro';

const contactInfo = [
	{
		title: "Correo Electrónico",
		description: "Envíanos tu consulta o solicitud de cotización.",
		detail: "ventas@mizo.cl",
		icon: "📧",
	},
	{
		title: "Teléfono / WhatsApp",
		description: "Llámanos o escríbenos en horario de oficina.",
		detail: "+56 9 9439 0870",
		icon: "📞",
	},
	{
		title: "Cobertura Nacional",
		description: "Atendemos a lo largo de todo Chile.",
		detail: "Oficinas en Frutillar y Santiago",
		icon: "📍",
	},
];
---

<Layout
	title="Contacto | Mizo"
	description="Contáctanos para cotizaciones de instalación de sonido, audiovisual, electricidad o venta de equipos en Chile."
>
	<section class="bg-gradient-to-b from-accent-soft to-white py-20 sm:py-28">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
			<h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-gray-900 leading-tight">
				Hablemos de tu <span class="text-accent-main">proyecto</span>
			</h1>
			<p class="mt-4 text-lg sm:text-xl text-gray-600 max-w-3xl mx-auto">
				Cuéntanos qué necesitas instalar o comprar y te enviamos una propuesta a la medida.
			</p>
		</div>
	</section>

	<section class="py-20 bg-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 lg:grid-cols-3 gap-12">
			<div class="lg:col-span-1 space-y-6">
				<h2 class="text-2xl font-extrabold text-gray-900 mb-2">Datos de Contacto</h2>

				{contactInfo.map((item) => (
					<div class="p-6 bg-white rounded-xl border border-gray-200 shadow-sm">
						<div class="text-3xl mb-3">{item.icon}</div>
						<h3 class="text-lg font-bold text-gray-900 mb-1">{item.title}</h3>
						<p class="text-gray-500 text-sm mb-2">{item.description}</p>
						<p class="text-accent-main font-semibold">{item.detail}</p>
					</div>
				))}

				<div class="p-6 bg-accent-soft rounded-xl">
					<h3 class="text-lg font-bold text-gray-900 mb-2">Horario de Atención</h3>
					<p class="text-gray-600">Lunes a Viernes: 9:00 - 18:00 hrs</p>
				</div>
			</div>

			<div class="lg:col-span-2 bg-white p-8 rounded-2xl shadow-sm border border-gray-200">
				<h2 class="text-2xl font-extrabold text-gray-900 mb-8">Formulario de Solicitud</h2>

				<form name="contact" method="POST" action="/gracias" data-netlify="true" class="space-y-6">
					<input type="hidden" name="form-name" value="contact" />

					<div>
						<label for="name" class="block text-sm font-medium text-gray-700">Nombre Completo</label>
						<input type="text" id="name" name="name" required class="mt-1 block w-full bg-white border border-gray-300 text-gray-900 rounded-md shadow-sm p-3 focus:ring-accent-main focus:border-accent-main transition duration-200">
					</div>

					<div>
						<label for="email" class="block text-sm font-medium text-gray-700">Correo Electrónico</label>
						<input type="email" id="email" name="email" required class="mt-1 block w-full bg-white border border-gray-300 text-gray-900 rounded-md shadow-sm p-3 focus:ring-accent-main focus:border-accent-main transition duration-200">
					</div>

					<div>
						<label for="service" class="block text-sm font-medium text-gray-700">¿Qué necesitas?</label>
						<select id="service" name="service" required class="mt-1 block w-full bg-white border border-gray-300 text-gray-900 rounded-md shadow-sm p-3 focus:ring-accent-main focus:border-accent-main transition duration-200">
							<option value="">Selecciona una opción</option>
							<option value="sonido">Instalación de Sistemas de Sonido</option>
							<option value="audiovisual">Soluciones Audiovisuales</option>
							<option value="electrico">Instalaciones Eléctricas</option>
							<option value="productos">Compra de Productos / Equipos</option>
							<option value="otro">Otro / Consultoría</option>
						</select>
					</div>

					<div>
						<label for="message" class="block text-sm font-medium text-gray-700">Describe tu proyecto o consulta</label>
						<textarea id="message" name="message" rows="4" required class="mt-1 block w-full bg-white border border-gray-300 text-gray-900 rounded-md shadow-sm p-3 focus:ring-accent-main focus:border-accent-main transition duration-200"></textarea>
					</div>

					<button type="submit" class="w-full inline-flex justify-center py-3 px-4 rounded-md shadow-sm text-lg font-bold text-white bg-accent-main hover:bg-accent-hover focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-accent-main transition duration-300">
						Enviar Solicitud
					</button>
				</form>

				<p class="mt-4 text-center text-sm text-gray-400">
					Tus datos están seguros. No compartiremos tu información con terceros.
				</p>
			</div>
		</div>
	</section>
</Layout>
