---
import Layout from '../layouts/Layout.astro';

const spaces = ['Sala de Clases', 'Auditorio', 'Sala de Reuniones', 'Cine en Casa', 'Otro'];
const badges = ['Ingeniería Certificada', 'Garantía de Satisfacción', 'Soporte Local'];
---

<Layout
	title="Contacto | Mizo"
	description="Contáctanos para cotizaciones de instalación de sonido, audiovisual, electricidad o venta de equipos en Chile."
>
	<section class="relative overflow-hidden bg-slate-950 py-20 sm:py-28">
		<div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(#38bdf8 1px, transparent 1px); background-size: 24px 24px;"></div>
		<div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
				<div>
					<span class="inline-flex rounded-full bg-amber-300 px-4 py-1.5 text-sm font-black text-slate-950">Cotizador guiado de proyectos</span>
					<h1 class="mt-6 text-4xl md:text-5xl lg:text-6xl font-black leading-tight text-white">
						Cuéntanos tu espacio y un ingeniero de Mizo arma la solución.
					</h1>
					<p class="mt-5 text-lg text-slate-300">
						Recibimos tu requerimiento, revisamos dimensiones, uso del espacio y equipamiento esperado para coordinar una visita técnica o propuesta inicial.
					</p>
					<div class="mt-7 grid gap-3 sm:grid-cols-3">
						{badges.map((badge) => (
							<div class="rounded-2xl border border-white/10 bg-white/10 px-4 py-3 text-center text-sm font-black text-white backdrop-blur">
								{badge}
							</div>
						))}
					</div>
					<div class="mt-8 rounded-3xl border border-white/10 bg-white/10 p-5 text-slate-200">
						<p class="font-black text-white">Contacto directo</p>
						<p class="mt-2 text-sm">ventas@mizo.cl · +56 9 9439 0870</p>
						<p class="mt-1 text-sm">Atención de lunes a viernes, 9:00 a 18:00 hrs.</p>
					</div>
				</div>

				<div class="rounded-3xl border border-white/10 bg-white p-5 shadow-2xl sm:p-8">
					<div class="mb-6">
						<p class="text-xs font-black uppercase tracking-[0.22em] text-accent-main">Solicitud técnica</p>
						<h2 class="mt-2 text-2xl font-black text-gray-950">Cotiza tu proyecto</h2>
						<p class="mt-1 text-sm text-gray-500">Tus datos viajan directo a ventas@mizo.cl.</p>
					</div>

					<form id="project-quote-form" class="space-y-5">
						<input type="text" name="website" class="hidden" tabindex="-1" autocomplete="off" aria-hidden="true">
						<input id="selected-space" type="hidden" name="espacio" value="Sala de Reuniones">
						<input id="selected-pack" type="hidden" name="pack" value="">

						<div class="grid gap-4 sm:grid-cols-2">
							<label class="block">
								<span class="text-sm font-bold text-gray-700">Nombre</span>
								<input name="nombre" type="text" required class="mt-1 w-full rounded-xl border border-gray-300 px-4 py-3 text-sm outline-none transition focus:border-accent-main focus:ring-2 focus:ring-accent-main/15">
							</label>
							<label class="block">
								<span class="text-sm font-bold text-gray-700">Teléfono</span>
								<input name="telefono" type="tel" required class="mt-1 w-full rounded-xl border border-gray-300 px-4 py-3 text-sm outline-none transition focus:border-accent-main focus:ring-2 focus:ring-accent-main/15">
							</label>
							<label class="block">
								<span class="text-sm font-bold text-gray-700">Empresa / Institución</span>
								<input name="empresa" type="text" class="mt-1 w-full rounded-xl border border-gray-300 px-4 py-3 text-sm outline-none transition focus:border-accent-main focus:ring-2 focus:ring-accent-main/15">
							</label>
							<label class="block">
								<span class="text-sm font-bold text-gray-700">Correo</span>
								<input name="correo" type="email" required class="mt-1 w-full rounded-xl border border-gray-300 px-4 py-3 text-sm outline-none transition focus:border-accent-main focus:ring-2 focus:ring-accent-main/15">
							</label>
						</div>

						<div>
							<p class="text-sm font-bold text-gray-700">¿Qué espacio necesitas equipar?</p>
							<div class="mt-2 grid gap-2 sm:grid-cols-3" data-space-options>
								{spaces.map((space, index) => (
									<button type="button" data-space={space} class={`rounded-xl border px-3 py-2.5 text-sm font-black transition ${index === 2 ? 'border-accent-main bg-accent-main text-white shadow-sm' : 'border-gray-200 bg-white text-gray-700 hover:border-accent-main hover:bg-accent-soft'}`}>
										{space}
									</button>
								))}
							</div>
						</div>

						<div class="grid gap-4 sm:grid-cols-[12rem_1fr]">
							<label class="block">
								<span class="text-sm font-bold text-gray-700">Tamaño aprox. en m²</span>
								<input name="metros" type="number" min="1" step="1" placeholder="Ej: 45" class="mt-1 w-full rounded-xl border border-gray-300 px-4 py-3 text-sm outline-none transition focus:border-accent-main focus:ring-2 focus:ring-accent-main/15">
							</label>
							<label class="block">
								<span class="text-sm font-bold text-gray-700">Cuéntanos los detalles de tu requerimiento</span>
								<textarea name="detalles" rows="4" required placeholder="Ej: queremos audio para sala de clases, proyector, micrófono y conexión HDMI..." class="mt-1 w-full rounded-xl border border-gray-300 px-4 py-3 text-sm outline-none transition focus:border-accent-main focus:ring-2 focus:ring-accent-main/15"></textarea>
							</label>
						</div>

						<button id="quote-submit" type="submit" class="inline-flex w-full items-center justify-center rounded-xl bg-accent-main px-6 py-4 text-base font-black text-white shadow-lg transition hover:bg-accent-hover disabled:cursor-not-allowed disabled:opacity-60">
							Enviar solicitud técnica
						</button>
						<p id="quote-status" class="hidden rounded-xl px-4 py-3 text-sm font-bold"></p>
						<p class="text-center text-xs font-semibold text-gray-400">Tus datos se usan únicamente para responder esta solicitud.</p>
					</form>
				</div>
			</div>
		</div>
	</section>
</Layout>

<script is:inline>
	(function () {
		const form = document.getElementById('project-quote-form');
		if (!form) return;
		const status = document.getElementById('quote-status');
		const submit = document.getElementById('quote-submit');
		const selectedSpace = document.getElementById('selected-space');
		const selectedPack = document.getElementById('selected-pack');
		const params = new URLSearchParams(window.location.search);
		const pack = params.get('pack') || params.get('tipo') || '';
		if (selectedPack) selectedPack.value = pack;

		const showStatus = (message, error = false) => {
			status.textContent = message;
			status.className = `rounded-xl px-4 py-3 text-sm font-bold ${error ? 'bg-red-50 text-red-700' : 'bg-emerald-50 text-emerald-700'}`;
		};

		document.querySelectorAll('[data-space]').forEach((button) => {
			button.addEventListener('click', () => {
				selectedSpace.value = button.dataset.space || '';
				document.querySelectorAll('[data-space]').forEach((item) => {
					const active = item === button;
					item.classList.toggle('border-accent-main', active);
					item.classList.toggle('bg-accent-main', active);
					item.classList.toggle('text-white', active);
					item.classList.toggle('shadow-sm', active);
					item.classList.toggle('border-gray-200', !active);
					item.classList.toggle('bg-white', !active);
					item.classList.toggle('text-gray-700', !active);
				});
			});
		});

		form.addEventListener('submit', async (event) => {
			event.preventDefault();
			submit.disabled = true;
			submit.textContent = 'Enviando solicitud...';
			try {
				const data = Object.fromEntries(new FormData(form).entries());
				const response = await fetch('/api/guardar-lead.php', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify(data),
				});
				const payload = await response.json().catch(() => null);
				if (!response.ok || !(payload?.success || payload?.ok)) throw new Error(payload?.error || 'No se pudo guardar la solicitud.');
				form.reset();
				selectedSpace.value = 'Sala de Reuniones';
				selectedPack.value = pack;
				showStatus(payload.message || '¡Solicitud recibida con éxito! Un ingeniero de Mizo se pondrá en contacto para coordinar la visita técnica.');
			} catch (error) {
				showStatus(error.message || 'No se pudo enviar la solicitud.', true);
			} finally {
				submit.disabled = false;
				submit.textContent = 'Enviar solicitud técnica';
			}
		});
	})();
</script>
