---
import Layout from '../layouts/Layout.astro';
import SectionCTA from '../components/SectionCTA.astro';

const values = [
	{
		title: 'Confianza Técnica',
		description: 'Solo implementamos soluciones probadas y certificadas, asegurando durabilidad y estricto cumplimiento normativo en cada instalación de sonido, audiovisual o eléctrica.',
		icon: '🛡️',
	},
	{
		title: 'Solución Integral',
		description: 'Vendemos los equipos y los instalamos. Un solo proveedor responsable de principio a fin, sin intermediarios y sin sorpresas.',
		icon: '🔗',
	},
	{
		title: 'Cercanía y Compromiso',
		description: 'Misma calidad técnica para grandes empresas y para tu hogar o pyme, adaptada a tu escala, plazos y presupuesto.',
		icon: '🤝',
	},
];
---

<Layout
	title="Nosotros | Mizo"
	description="Conoce a Mizo: especialistas en instalación de sistemas de sonido, audiovisual e instalaciones eléctricas en Chile, y venta de equipos profesionales."
>
	<section class="bg-gradient-to-b from-accent-soft to-white py-20 sm:py-28">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
			<h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-gray-900 leading-tight">
				La ingeniería detrás de cada <span class="text-accent-main">instalación exitosa</span>
			</h1>
			<p class="mt-4 text-lg sm:text-xl text-gray-600 max-w-3xl mx-auto">
				Somos Mizo, un equipo dedicado a unir sonido, imagen y energía en soluciones que funcionan, duran y se ven bien.
			</p>
		</div>
	</section>

	<section class="py-20 bg-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
			<div>
				<h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
					Nuestra misión: soluciones sólidas y conectadas
				</h2>
				<p class="text-lg text-gray-600 mb-4">
					Ofrecer a empresas y hogares soluciones integrales que abarcan desde la instalación de sistemas de sonido y audiovisuales, hasta instalaciones eléctricas seguras y la venta de los equipos necesarios.
				</p>
				<p class="text-lg text-gray-600">
					Nuestro objetivo es optimizar tus espacios, garantizar la seguridad de tus instalaciones y hacer que la tecnología de alto rendimiento sea una inversión accesible y rentable.
				</p>
				<div class="mt-8">
					<a href="/servicios" class="px-6 py-3 border border-accent-main text-base font-semibold rounded-md text-accent-main hover:bg-accent-main hover:text-white transition duration-300">
						Ver Nuestros Servicios
					</a>
				</div>
			</div>

			<div class="h-80 rounded-2xl overflow-hidden border border-gray-200 shadow-sm bg-accent-soft">
				<img
					src="/mizo-mision.jpg"
					alt="Equipo de Mizo en terreno"
					class="w-full h-full object-cover"
					loading="lazy"
					width="800"
					height="600"
				/>
			</div>
		</div>
	</section>

	<section class="py-20 bg-accent-soft">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
			<h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">Nuestros Pilares</h2>
			<p class="text-lg text-gray-600 max-w-3xl mx-auto mb-12">
				Construimos relaciones duraderas basadas en los principios que nos permiten entregar excelencia en cada proyecto.
			</p>

			<div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-left">
				{values.map((value) => (
					<div class="p-8 bg-white rounded-xl border border-gray-200 shadow-sm">
						<div class="text-4xl mb-4 inline-flex h-14 w-14 items-center justify-center rounded-lg bg-accent-soft">{value.icon}</div>
						<h3 class="text-xl font-bold text-gray-900 mb-3">{value.title}</h3>
						<p class="text-gray-600">{value.description}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<SectionCTA
		title="¿Listo para la solución que funciona?"
		subtitle="Comienza tu proyecto hoy con la ingeniería precisa que tu negocio o tu hogar necesita."
		buttonText="Contáctanos Ahora"
		buttonLink="/contacto"
	/>
</Layout>
