---
import Layout from '../layouts/Layout.astro';
import SectionCTA from '../components/SectionCTA.astro';
import PageHero from '../components/PageHero.astro';

const values = [
	{
		title: 'Ingeniería aplicada',
		description: 'Cada decisión de marca, ubicación, potencia, cableado y control se toma desde el comportamiento real del recinto.',
		kicker: 'Criterio técnico',
	},
	{
		title: 'Integración completa',
		description: 'Unimos audio, video, infraestructura, control y soporte para evitar compras aisladas que no conversan entre sí.',
		kicker: 'AV + infraestructura',
	},
	{
		title: 'Entrega responsable',
		description: 'Instalamos, calibramos, explicamos y dejamos documentación clara para que el sistema pueda operarse con confianza.',
		kicker: 'Soporte local',
	},
];

const capabilities = [
	'Diseño acústico y cobertura sonora',
	'Proyección láser y salas audiovisuales',
	'Canalización y cableado estructural oculto',
	'Soportería pesada y montaje técnico',
	'Control, escenas y capacitación de usuarios',
	'Calibración final y soporte posterior',
];
---

<Layout
	title="Nosotros | Mizo"
	description="Conoce a Mizo: especialistas en instalación de sistemas de sonido, audiovisual e instalaciones eléctricas en Chile, y venta de equipos profesionales."
>
	<PageHero
		eyebrow="Nosotros"
		title="La ingeniería detrás de instalaciones audiovisuales confiables."
		subtitle="Mizo combina selección de equipamiento, diseño técnico, ejecución en terreno y soporte posterior para entregar sistemas que funcionan desde el primer día."
		image="https://images.unsplash.com/photo-1581092160607-ee22621dd758?auto=format&fit=crop&w=1600&q=80"
		chips={["Criterio técnico", "AV + infraestructura", "Soporte local"]}
	/>

	<section class="bg-white py-20">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
			<div>
				<span class="inline-flex rounded-full bg-accent-main/10 px-4 py-1.5 text-xs font-black uppercase tracking-[0.18em] text-accent-main">
					Integradora audiovisual
				</span>
				<h2 class="mt-5 text-3xl font-black leading-tight text-gray-950 lg:text-5xl">
					Nuestra misión: tecnología premium, instalada con criterio y responsabilidad.
				</h2>
				<p class="mt-5 text-lg leading-relaxed text-gray-600">
					Ofrecemos a empresas, instituciones y hogares soluciones integrales que abarcan levantamiento técnico, diseño de sistema, suministro de marcas líderes, montaje profesional y calibración final.
				</p>
				<p class="mt-4 text-lg leading-relaxed text-gray-600">
					Buscamos que cada espacio tenga una experiencia audiovisual clara, segura y fácil de operar, con una instalación que se vea limpia y pueda mantenerse en el tiempo.
				</p>
				<div class="mt-8 grid grid-cols-1 gap-3 sm:grid-cols-2">
					{capabilities.map((item) => (
						<div class="rounded-2xl border border-slate-200 bg-slate-50 p-4 text-sm font-bold text-slate-700">
							{item}
						</div>
					))}
				</div>
				<div class="mt-8">
					<a href="/servicios" class="inline-flex rounded-full border border-accent-main px-6 py-3 text-sm font-black text-accent-main transition hover:bg-accent-main hover:text-white">
						Ver Nuestros Servicios
					</a>
				</div>
			</div>

			<div class="relative min-h-[420px] overflow-hidden rounded-[2rem] border border-gray-200 bg-slate-950 shadow-2xl">
				<img
					src="https://images.unsplash.com/photo-1581090464777-f3220bbe1b8b?auto=format&fit=crop&w=1100&q=80"
					alt="Planificación técnica de un proyecto audiovisual"
					class="h-full min-h-[420px] w-full object-cover opacity-85"
					loading="lazy"
					width="1100"
					height="760"
				/>
				<div class="absolute inset-0 bg-gradient-to-t from-slate-950/85 via-transparent to-transparent"></div>
				<div class="absolute bottom-0 left-0 right-0 p-6 text-white">
					<p class="text-xs font-black uppercase tracking-[0.18em] text-brand-orange">Placeholder fotográfico HD</p>
					<p class="mt-2 text-2xl font-black">Planificación, montaje y puesta en marcha</p>
				</div>
			</div>
		</div>
	</section>

	<section class="py-20 bg-accent-soft">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
			<h2 class="text-3xl font-black text-gray-950 lg:text-4xl">Nuestros pilares</h2>
			<p class="mt-4 text-lg text-gray-600 max-w-3xl mx-auto mb-12">
				Construimos relaciones duraderas basadas en los principios que nos permiten entregar excelencia en cada proyecto.
			</p>

			<div class="grid grid-cols-1 md:grid-cols-3 gap-6 text-left">
				{values.map((value) => (
					<div class="rounded-3xl border border-gray-200 bg-white p-8 shadow-sm">
						<p class="text-xs font-black uppercase tracking-[0.18em] text-accent-main">{value.kicker}</p>
						<h3 class="mt-4 text-xl font-black text-gray-950">{value.title}</h3>
						<p class="mt-3 leading-relaxed text-gray-600">{value.description}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<SectionCTA
		title="¿Listo para la solución que funciona?"
		subtitle="Comienza tu proyecto hoy con la ingeniería precisa que tu negocio o tu hogar necesita."
		buttonText="Contáctanos Ahora"
		buttonLink="/contacto"
	/>
</Layout>
