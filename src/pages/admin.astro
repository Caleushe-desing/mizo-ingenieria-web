			function quoteClientFromForm() {
				return {
					name: $('quote-client-name').value.trim(),
					email: $('quote-client-email').value.trim(),
					phone: $('quote-client-phone').value.trim(),
					rut: $('quote-client-rut').value.trim(),
					address: $('quote-client-address').value.trim(),
				};
			}

			function quoteConditionsFromForm() {
				return $('quote-conditions').value.split('\n').map((line) => line.trim()).filter(Boolean);
			}

			function fillQuoteClientForm(client = {}) {
				$('quote-client-name').value = client.name || '';
				$('quote-client-email').value = client.email || '';
				$('quote-client-phone').value = client.phone || '';
				$('quote-client-rut').value = client.rut || '';
				$('quote-client-address').value = client.address || '';
