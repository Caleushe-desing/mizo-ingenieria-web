						<div class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">
							<div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
								<div>
									<h3 class="text-2xl font-black">Formularios enviados desde la web</h3>
									<p class="text-sm text-slate-500">Diagnóstico técnico, consultas de producto y otros envíos capturados en el sitio.</p>
								</div>
								<div class="flex flex-wrap gap-2">
									<a href="/configurador" class="rounded-full border border-slate-300 px-5 py-2.5 text-xs font-black text-slate-700 hover:bg-slate-50">Abrir asistente</a>
									<a href="/productos" target="_blank" rel="noopener" class="rounded-full border border-slate-300 px-5 py-2.5 text-xs font-black text-slate-700 hover:bg-slate-50">Ver productos</a>
									<button id="refresh-leads" type="button" class="rounded-full bg-accent-main px-5 py-2.5 text-xs font-black text-white hover:bg-accent-hover">Actualizar</button>
								</div>
							</div>
							<p id="leads-status" class="mt-4 hidden text-sm font-semibold text-red-600"></p>
							<div id="lead-list" class="mt-5 grid gap-3"></div>
