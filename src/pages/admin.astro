			}

			function startNewQuote() {
				currentQuote = null;
				editingQuoteNumber = null;
				quoteItems = [];
				fillQuoteClientForm({});
				$('quote-notes').value = '';
				$('quote-email-message').value = '';
				$('quote-saved-link').innerHTML = '';
				renderQuoteItems();
				bootstrapQuotes();
				quoteMessage('Formulario limpio para una nueva cotización.', 'success');
			}

			function renderQuoteCatalogOptions(items) {
				$('quote-catalog-product').innerHTML = '<option value="">Importar producto del catálogo Mizo</option>' + items.map((product) => {
					const price = Number(product.sellingPrice || product.basePrice || 0);
					return `<option value="${escapeHtml(product.id)}">${escapeHtml(product.sku || product.id)} · ${escapeHtml(product.brand || '')} ${escapeHtml(product.name)} · ${clp(price)}</option>`;
				}).join('');
			}

			function quoteTotal() {
				return quoteItems.reduce((sum, item) => sum + (Number(item.quantity) * Number(item.unitPrice)), 0);
			}

			function quoteGrandTotal() {
				const subtotal = quoteTotal();
				return subtotal + Math.round(subtotal * TAX_RATE);
			}

			function renderQuoteItems() {
				const list = $('quote-items-list');
				const subtotal = quoteTotal();
				$('quote-total').innerHTML = `${clp(quoteGrandTotal())}<span class="mt-1 block text-sm font-bold text-white/60">Incluye IVA 19% · Neto ${clp(subtotal)}</span>`;
				if (!quoteItems.length) {
					list.innerHTML = '<div class="rounded-xl border border-dashed border-slate-300 px-4 py-8 text-center text-sm font-semibold text-slate-400">Aún no hay ítems en esta cotización.</div>';
					return;
				}
				list.innerHTML = quoteItems.map((item, index) => `
					<article class="rounded-xl border border-slate-200 bg-slate-50 p-3">
						<div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
							<div class="min-w-0">
								${item.sku ? `<p class="font-mono text-[0.68rem] font-black uppercase text-accent-main">${escapeHtml(item.sku)}</p>` : ''}
								<h4 class="mt-1 text-sm font-black">${escapeHtml(item.name)}</h4>
								<p class="mt-1 text-xs font-semibold text-slate-500">${escapeHtml(item.source === 'catalog' ? 'Catálogo Mizo' : 'Ítem personalizado')}</p>
							</div>
							<button type="button" class="remove-quote-item text-xs font-black text-red-600" data-index="${index}">Eliminar</button>
						</div>
						<div class="mt-3 grid grid-cols-3 gap-2 text-sm">
							<div><p class="text-xs text-slate-500">Cantidad</p><p class="font-black">${Number(item.quantity)}</p></div>
							<div><p class="text-xs text-slate-500">Unitario</p><p class="font-black">${clp(Number(item.unitPrice))}</p></div>
							<div><p class="text-xs text-slate-500">Total</p><p class="font-black">${clp(Number(item.quantity) * Number(item.unitPrice))}</p></div>
						</div>
					</article>
				`).join('');
				list.querySelectorAll('.remove-quote-item').forEach((button) => {
					button.onclick = () => {
						quoteItems.splice(Number(button.dataset.index), 1);
						currentQuote = null;
						$('quote-saved-link').innerHTML = '';
						renderQuoteItems();
					};
				});
			}

			function addQuoteItem(item) {
				quoteItems.push({
					source: item.source || 'manual',
					sku: item.sku || '',
					name: item.name,
					quantity: Math.max(1, Number(item.quantity) || 1),
					unitPrice: Math.max(0, moneyNumber(item.unitPrice)),
				});
				currentQuote = null;
				$('quote-saved-link').innerHTML = '';
				renderQuoteItems();
			}

			function addCatalogQuoteItem() {
				const product = allItems.find((item) => item.id === $('quote-catalog-product').value);
				if (!product) {
					quoteMessage('Selecciona un producto del catálogo.', 'error');
					return;
				}
				const overridePrice = moneyNumber($('quote-catalog-price').value);
				addQuoteItem({
					source: 'catalog',
					sku: product.sku || product.id,
					name: `${product.brand || ''} ${product.name}`.trim(),
					quantity: $('quote-catalog-qty').value,
					unitPrice: overridePrice || Number(product.sellingPrice || product.basePrice || 0),
				});
				$('quote-catalog-product').value = '';
				$('quote-catalog-price').value = '';
				$('quote-catalog-qty').value = '1';
				quoteMessage('Producto agregado a la cotización.', 'success');
			}

			function addManualQuoteItem() {
				const name = $('quote-manual-name').value.trim();
				const price = moneyNumber($('quote-manual-price').value);
				if (!name || !price) {
					quoteMessage('Completa nombre y precio unitario del ítem manual.', 'error');
					return;
				}
				addQuoteItem({
					source: 'manual',
					sku: $('quote-manual-sku').value.trim(),
					name,
					quantity: $('quote-manual-qty').value,
					unitPrice: price,
				});
				['quote-manual-name', 'quote-manual-sku', 'quote-manual-price'].forEach((id) => $(id).value = '');
				$('quote-manual-qty').value = '1';
				quoteMessage('Ítem manual agregado.', 'success');
			}

			async function loadQuoteForEditing(number) {
				try {
					quoteMessage(`Cargando ${number} para edición...`, 'info');
					const data = await apiQuotes('get', { number });
					const quote = data.quote;
					currentQuote = quote;
					editingQuoteNumber = quote.number;
					quoteItems = Array.isArray(quote.items) ? quote.items.map((item) => ({
						source: item.source || 'manual',
						sku: item.sku || '',
						name: item.name || '',
						quantity: Math.max(1, Number(item.quantity) || 1),
						unitPrice: Math.max(0, Number(item.unitPrice) || 0),
					})) : [];
					fillQuoteCompanyForm(quote.company || quoteConfig || {});
					fillQuoteClientForm(quote.client || {});
					$('quote-conditions').value = (quote.conditions || []).join('\n');
					$('quote-notes').value = quote.notes || '';
					$('quote-saved-link').innerHTML = `<a class="text-blue-200 underline" href="${escapeHtml(quote.pdfUrl)}" target="_blank" rel="noopener">Descargar ${escapeHtml(quote.number)}.pdf</a>`;
					$('quote-next-number').textContent = `Editando: ${quote.number}`;
					renderQuoteItems();
					setView('cotizador');
					quoteMessage(`Editando ${quote.number}. Al guardar se creará la siguiente revisión.`, 'success');
				} catch (error) {
					quoteMessage(error.message, 'error');
				}
			}

			async function loadQuotesHistory() {
				const container = $('quotes-history');
				container.innerHTML = '<p class="text-slate-400">Cargando cotizaciones...</p>';
				try {
					const data = await apiQuotes('list');
					const quotes = data.quotes || [];
					if (!quotes.length) {
						container.innerHTML = '<p class="text-slate-400">Aún no hay cotizaciones guardadas.</p>';
						return;
					}
					container.innerHTML = quotes.slice(0, 8).map((quote) => `
						<article class="rounded-xl border border-slate-200 p-3">
							<div class="flex items-start justify-between gap-3">
								<div class="min-w-0">
									<p class="font-black text-slate-950">${escapeHtml(quote.number)}</p>
									<p class="mt-1 text-xs text-slate-500">${escapeHtml(quote.client || 'Cliente')} · ${clp(Number(quote.total) || 0)}</p>
								</div>
								<div class="flex shrink-0 gap-2">
									<button type="button" class="load-quote rounded-full bg-accent-soft px-3 py-1 text-xs font-black text-accent-main" data-number="${escapeHtml(quote.number)}">Editar</button>
									<a class="rounded-full border border-slate-200 px-3 py-1 text-xs font-black text-slate-600 hover:bg-slate-50" href="${escapeHtml(quote.pdfUrl)}" target="_blank" rel="noopener">PDF</a>
									<button type="button" class="delete-quote rounded-full border border-red-200 px-3 py-1 text-xs font-black text-red-600 hover:bg-red-50" data-number="${escapeHtml(quote.number)}">Eliminar</button>
								</div>
							</div>
						</article>
					`).join('');
					container.querySelectorAll('.load-quote').forEach((button) => {
						button.onclick = () => loadQuoteForEditing(button.dataset.number);
					});
					container.querySelectorAll('.delete-quote').forEach((button) => {
						button.onclick = () => deleteQuote(button.dataset.number);
					});
				} catch (error) {
					container.innerHTML = `<p class="text-red-600">${escapeHtml(error.message)}</p>`;
				}
			}

			async function deleteQuote(number) {
				if (!number) return;
				if (!confirm(`¿Eliminar definitivamente el presupuesto ${number}? Esta acción no se puede deshacer.`)) return;

				try {
					quoteMessage(`Eliminando ${number}...`, 'info');
					await apiQuotes('delete_quote', { number });
					if (currentQuote?.number === number || editingQuoteNumber === number) {
						startNewQuote();
					}
					await loadQuotesHistory();
					quoteMessage(`Presupuesto ${number} eliminado correctamente.`, 'success');
				} catch (error) {
					quoteMessage(error.message, 'error');
				}
			}

			async function bootstrapQuotes() {
				try {
					const data = await apiQuotes('bootstrap');
					$('quote-next-number').textContent = `Presupuesto: ${data.nextNumber || 'M1001'}`;
					fillQuoteCompanyForm(data.config || {});
					renderQuoteItems();
					await loadQuotesHistory();
				} catch (error) {
					quoteMessage(error.message, 'error');
				}
			}

			async function saveQuoteConfig() {
				try {
					const config = { ...quoteCompanyFromForm(), defaultConditions: quoteConditionsFromForm() };
					const data = await apiQuotes('save_config', { config });
					fillQuoteCompanyForm(data.config || config);
					quoteMessage('Datos fijos de Mizo guardados.', 'success');
				} catch (error) {
					quoteMessage(error.message, 'error');
				}
			}

			async function saveQuote() {
				if (!quoteItems.length) {
					quoteMessage('Agrega al menos un ítem antes de guardar.', 'error');
					return null;
				}
				try {
					quoteMessage('Generando cotización y PDF...', 'info');
					const updateOf = editingQuoteNumber || currentQuote?.number || '';
					const data = await apiQuotes('create_quote', {
						...(updateOf ? { updateOf } : {}),
						company: quoteCompanyFromForm(),
						client: quoteClientFromForm(),
						items: quoteItems,
						conditions: quoteConditionsFromForm(),
						notes: $('quote-notes').value.trim(),
					});
					currentQuote = data.quote;
					editingQuoteNumber = currentQuote.number;
					$('quote-next-number').textContent = `Presupuesto: ${data.nextNumber || ''}`;
					$('quote-saved-link').innerHTML = `<a class="text-blue-200 underline" href="${escapeHtml(currentQuote.pdfUrl)}" target="_blank" rel="noopener">Descargar ${escapeHtml(currentQuote.number)}.pdf</a>`;
					$('quote-email-to').value = currentQuote.client?.email || $('quote-client-email').value;
					quoteMessage(currentQuote.revision > 0 ? `Revisión ${currentQuote.number} guardada correctamente.` : `Cotización ${currentQuote.number} guardada correctamente.`, 'success');
					await loadQuotesHistory();
					return currentQuote;
				} catch (error) {
					quoteMessage(error.message, 'error');
					return null;
				}
			}

			async function sendQuote() {
				const quote = currentQuote || await saveQuote();
				if (!quote) return;
				try {
					quoteMessage('Enviando PDF por correo...', 'info');
					const data = await apiQuotes('send_quote', {
						number: quote.number,
						to: $('quote-email-to').value.trim(),
						message: $('quote-email-message').value.trim(),
					});
					const sentCount = Array.isArray(data.recipients) ? data.recipients.length : 1;
					quoteMessage(data.sent ? `Cotización ${quote.number} enviada a ${sentCount} destinatario(s).` : data.error || 'El servidor no confirmó el envío.', data.sent ? 'success' : 'error');
				} catch (error) {
					quoteMessage(error.message, 'error');
				}
			}

			function renderQualityReview(products) {
				if (!products.length) {
					$('quality-review-panel').innerHTML = '<div class="rounded-2xl border border-emerald-200 bg-emerald-50 p-5 text-sm font-black text-emerald-700">✅ Inventario 100% cuadrado con los mayoristas.</div>';
					return;
				}
				$('quality-review-panel').innerHTML = `<div class="overflow-x-auto"><table class="min-w-full text-sm"><thead class="bg-slate-950 text-white"><tr><th class="px-4 py-3 text-left">SKU</th><th class="px-4 py-3 text-right">Stock proveedor</th><th class="px-4 py-3 text-right">Stock Mizo</th><th class="px-4 py-3 text-right">Precio proveedor</th><th class="px-4 py-3 text-right">Precio Mizo</th></tr></thead><tbody>${products.map((product) => `<tr class="border-b border-slate-100"><td class="px-4 py-3 font-mono font-black text-accent-main">${escapeHtml(product.sku)}</td><td class="px-4 py-3 text-right font-semibold">${escapeHtml(product.stock_proveedor ?? '—')}</td><td class="px-4 py-3 text-right font-semibold">${escapeHtml(product.stock_mizo ?? '—')}</td><td class="px-4 py-3 text-right font-semibold">${product.precio_proveedor == null ? '—' : clp(product.precio_proveedor)}</td><td class="px-4 py-3 text-right font-semibold">${product.precio_mizo == null ? '—' : clp(product.precio_mizo)}</td></tr>`).join('')}</tbody></table></div>`;
			}

			async function loadQualityReview() {
				$('quality-review-panel').innerHTML = '<p class="text-sm text-slate-500">Cargando reporte de discrepancias...</p>';
				try {
					const response = await fetch('/api-productos-en-revision.php?ts=' + Date.now(), { headers: { Accept: 'application/json' }, cache: 'no-store' });
					const payload = await response.json();
					if (!response.ok || !payload?.ok) throw new Error(payload?.error || 'No se pudo leer el reporte.');
					renderQualityReview(Array.isArray(payload.products) ? payload.products : []);
				} catch (error) {
					console.warn('No se pudo cargar productos bajo revisión.', error);
					renderQualityReview([]);
				}
			}

			function formatLeadDate(value) {
				const date = new Date(value);
				if (Number.isNaN(date.getTime())) return value || '-';
				return date.toLocaleString('es-CL', { dateStyle: 'short', timeStyle: 'short' });
			}

			function formTypeLabel(entry) {
				return entry?.formType === 'consulta-producto' ? 'Consulta producto' : 'Diagnóstico técnico';
			}

			function formTypeBadgeClass(entry) {
				return entry?.formType === 'consulta-producto'
					? 'bg-orange-100 text-orange-800'
					: 'bg-blue-100 text-blue-800';
			}

			function leadSummaryText(lead) {
				if (lead.formType === 'consulta-producto') {
					return [
						'Consulta de producto',
						'',
						'Nombre: ' + (lead.nombre || 'Sin nombre'),
						'Celular: ' + (lead.telefono || 'Sin teléfono'),
						'',
						'Producto: ' + (lead.productoNombre || 'Sin nombre'),
						'ID producto: ' + (lead.productoId || 'No indicado'),
						'Origen: ' + (lead.source || 'Consulta de producto'),
					].join('\n');
				}
				return [
					`Nombre: ${lead.nombre || ''}`,
					`Empresa: ${lead.empresa || ''}`,
					`Teléfono: ${lead.telefono || ''}`,
					`Correo: ${lead.correo || ''}`,
					`Fecha: ${formatLeadDate(lead.createdAt)}`,
					'',
					`Entorno: ${lead.espacio || 'No indicado'}`,
					`Especialidad: ${lead.especialidad || 'No indicada'}`,
					`Dimensión: ${lead.dimension || 'No indicada'}`,
					`Origen: ${lead.source || 'Asistente de Diagnóstico Técnico Mizo'}`,
					'',
					'Resumen técnico:',
					lead.resumenTecnico || lead.detalles || 'Sin resumen técnico.',
					'',
					'Productos precalificados:',
					lead.productos || 'Sin productos registrados.',
				].join('\n');
			}

			function openLeadModal(lead) {
				const titleSuffix = lead.formType === 'consulta-producto'
					? (lead.productoNombre || 'Producto')
					: (lead.empresa || 'Sin empresa');
				$('lead-modal-title').textContent = `${lead.nombre || 'Formulario'} · ${titleSuffix}`;
				$('lead-modal-meta').textContent = `${formatLeadDate(lead.createdAt)} · ${formTypeLabel(lead)}`;
				$('lead-modal-body').textContent = leadSummaryText(lead);
				$('lead-modal').classList.remove('hidden');
			}

			function mergeAdminFormularios() {
				const diagnosticos = adminLeads.map((lead) => ({ ...lead, formType: 'diagnostico' }));
				const consultas = adminConsultas.map((consulta) => ({ ...consulta, formType: 'consulta-producto' }));
				adminFormularios = [...diagnosticos, ...consultas].sort((a, b) => {
					const aTime = Date.parse(a.createdAt || '') || 0;
					const bTime = Date.parse(b.createdAt || '') || 0;
					return bTime - aTime;
				});
			}

			function renderAdminLeads() {
				mergeAdminFormularios();
				$('lead-count').textContent = String(adminFormularios.length);
				$('lead-count-diagnostico').textContent = String(adminLeads.length);
				$('lead-count-consulta').textContent = String(adminConsultas.length);
				const list = $('lead-list');
				if (!adminFormularios.length) {
					list.innerHTML = '<div class="rounded-2xl border border-slate-200 bg-slate-50 p-8 text-center text-slate-500">Aún no hay formularios guardados.</div>';
					return;
				}
				list.innerHTML = adminFormularios.map((lead, index) => `
					<article class="grid gap-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm lg:grid-cols-[1fr_auto] lg:items-center">
						<div>
							<div class="flex flex-wrap items-center gap-2">
								<p class="text-xs font-black uppercase text-slate-400">${escapeHtml(formatLeadDate(lead.createdAt))}</p>
								<span class="rounded-full px-2.5 py-1 text-[0.65rem] font-black uppercase tracking-wide ${formTypeBadgeClass(lead)}">${escapeHtml(formTypeLabel(lead))}</span>
							</div>
							<h3 class="mt-1 text-xl font-black text-slate-950">${escapeHtml(lead.nombre || 'Sin nombre')}</h3>
							<div class="mt-2 flex flex-wrap gap-2 text-sm font-semibold text-slate-600">
								${lead.formType === 'consulta-producto'
									? `<span>${escapeHtml(lead.productoNombre || 'Producto sin nombre')}</span><span>·</span><span>${escapeHtml(lead.telefono || 'Sin teléfono')}</span>`
									: `<span>${escapeHtml(lead.empresa || 'Sin empresa')}</span><span>·</span><a class="text-accent-main" href="mailto:${escapeHtml(lead.correo || '')}">${escapeHtml(lead.correo || 'Sin correo')}</a><span>·</span><span>${escapeHtml(lead.telefono || 'Sin teléfono')}</span>`}
							</div>
							<p class="mt-2 text-sm text-slate-500">${lead.formType === 'consulta-producto'
								? `Consulta por producto · ${escapeHtml(lead.productoId || 'Sin ID')}`
								: `${escapeHtml(lead.espacio || 'Sin entorno')} · ${escapeHtml(lead.especialidad || 'Sin especialidad')} · ${escapeHtml(lead.dimension || 'Sin dimensión')}`}</p>
						</div>
						<button type="button" class="view-lead-summary rounded-full bg-accent-main px-5 py-3 text-sm font-black text-white hover:bg-accent-hover" data-index="${index}">
							Ver detalle
						</button>
					</article>
				`).join('');
				list.querySelectorAll('.view-lead-summary').forEach((button) => {
					button.addEventListener('click', () => openLeadModal(adminFormularios[Number(button.dataset.index)]));
				});
			}

			function showLeadsError(message) {
				const el = $('leads-status');
				el.textContent = message;
				el.classList.remove('hidden');
			}

			function hideLeadsError() {
				const el = $('leads-status');
				el.classList.add('hidden');
				el.textContent = '';
			}

			async function loadAdminLeads() {
				hideLeadsError();
				const list = $('lead-list');
				list.innerHTML = '<p class="text-sm text-slate-500">Cargando formularios...</p>';
				try {
					const [leadsResponse, consultasResponse] = await Promise.all([
						fetch('/api/guardar-lead.php', {
							method: 'POST',
							headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
							body: JSON.stringify({ action: 'list', password: adminPassword }),
						}),
						fetch('/api/consulta-producto.php', {
							method: 'POST',
							headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
							body: JSON.stringify({ action: 'list', password: adminPassword }),
						}),
					]);
					const leadsPayload = await leadsResponse.json().catch(() => null);
					const consultasPayload = await consultasResponse.json().catch(() => null);
					if (!leadsResponse.ok || !leadsPayload?.success) {
						throw new Error(leadsPayload?.error || 'No se pudieron cargar los formularios de diagnóstico.');
					}
					adminLeads = Array.isArray(leadsPayload.leads) ? leadsPayload.leads : [];
					adminConsultas = consultasResponse.ok && consultasPayload?.ok && Array.isArray(consultasPayload.consultas)
						? consultasPayload.consultas
						: [];
					const leadsWritable = leadsPayload.storage?.fileWritable || leadsPayload.storage?.dirWritable;
					const consultasWritable = consultasPayload?.storage?.fileWritable || consultasPayload?.storage?.dirWritable;
					$('storage-status').textContent = leadsWritable && consultasWritable ? 'OK' : (leadsWritable ? 'Parcial' : 'Revisar permisos');
					renderAdminLeads();
				} catch (error) {
					showLeadsError(error.message || 'No se pudieron cargar los formularios.');
					list.innerHTML = '';
				}
			}

			async function loadPedidos() {
				const list = $('pedidos-list');
				list.innerHTML = '<p class="text-sm text-slate-500">Cargando pedidos...</p>';
				try {
					const response = await fetch('/.netlify/functions/pedidos-api', {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({ password: adminPassword, action: 'list' }),
					});
					const data = await response.json();
					if (!response.ok) throw new Error(data.error || 'No se pudieron cargar pedidos.');
					const orders = data.orders || [];
					list.innerHTML = orders.length
						? orders.slice(0, 40).map((order) => `<article class="mb-3 rounded-2xl border border-slate-200 p-4"><p class="font-black">${escapeHtml(order.id || 'Pedido')}</p><p class="text-sm text-slate-500">${escapeHtml(order.customer?.name || 'Cliente')} · ${clp(order.total || 0)}</p></article>`).join('')
						: '<p class="text-sm text-slate-500">Aún no hay pedidos registrados.</p>';
				} catch (error) {
					list.innerHTML = `<p class="rounded-2xl border border-red-200 bg-red-50 p-4 text-sm font-semibold text-red-600">${escapeHtml(error.message)}</p>`;
				}
			}

			async function openAdminSession(password) {
				const payload = await decryptData(password);
				adminPassword = password;
				sessionStorage.setItem('mizoAdminPassword', password);
				$('login-card').classList.add('hidden');
				$('panel').classList.remove('hidden');
				renderCatalog(payload);
				renderQuoteItems();
				await loadShowcaseConfig();
				await bootstrapQuotes();
				await loadQualityReview();
				const initial = (location.hash || '').replace('#', '');
				setView(views[initial] ? initial : initial === 'cotizaciones' ? 'cotizador' : 'catalogo');
			}

			$('login-form').addEventListener('submit', async (event) => {
				event.preventDefault();
				$('login-error').classList.add('hidden');
				try {
					await openAdminSession($('password').value);
				} catch (error) {
					console.warn(error);
					sessionStorage.removeItem('mizoAdminPassword');
					$('login-error').classList.remove('hidden');
				}
			});

			document.querySelectorAll('.admin-nav-btn').forEach((button) => {
				button.addEventListener('click', () => setView(button.dataset.view));
			});
			document.querySelectorAll('.admin-goto-vitrina').forEach((button) => {
				button.addEventListener('click', () => setView('vitrina'));
			});
			$('showcase-mode-all')?.addEventListener('click', async () => {
				if (showcaseMode === 'all') return;
				if (confirm('¿Publicar todos los productos del catálogo en /equipamiento?')) {
					await publishAllShowcase();
				}
			});
			$('showcase-mode-curated')?.addEventListener('click', () => switchShowcaseMode('curated'));
			$('showcase-select-all')?.addEventListener('click', () => {
				switchShowcaseMode('curated');
				allItems.forEach((item, index) => {
					const key = showcaseKey(item);
					if (!key) return;
					showcaseMap.set(key, {
						id: item.id || key,
						sku: item.sku || '',
						sortOrder: index + 1,
						note: showcaseMap.get(key)?.note || '',
					});
				});
				renderShowcaseManager();
			});
			$('showcase-select-none')?.addEventListener('click', () => {
				switchShowcaseMode('curated');
				showcaseMap = new Map();
				renderShowcaseManager();
			});
			$('logout').addEventListener('click', () => {
				sessionStorage.removeItem('mizoAdminPassword');
				location.reload();
			});
			$('catalog-search').addEventListener('input', filterCatalog);
			$('showcase-search')?.addEventListener('input', renderShowcaseManager);
			$('save-showcase')?.addEventListener('click', saveShowcase);
			$('publish-all-showcase')?.addEventListener('click', publishAllShowcase);
			$('proyecto-new')?.addEventListener('click', () => openProjectEditor());
			$('proyecto-editor-close')?.addEventListener('click', closeProjectEditor);
			$('proyecto-save')?.addEventListener('click', async () => {
				try {
					await saveCurrentProject();
				} catch (error) {
					$('proyectos-status').textContent = error.message || 'Error al guardar proyecto.';
				}
			});
			$('proyecto-delete')?.addEventListener('click', async () => {
				try {
					await deleteCurrentProject();
				} catch (error) {
					$('proyectos-status').textContent = error.message || 'Error al eliminar proyecto.';
				}
			});
			$('proyecto-image-input')?.addEventListener('change', async (event) => {
				const files = Array.from(event.target.files || []);
				if (!files.length) return;
				try {
					await uploadProjectImages(files);
				} catch (error) {
					$('proyecto-upload-status').textContent = error.message || 'Error al subir imágenes.';
				}
			});
			$('refresh-quality-review').addEventListener('click', loadQualityReview);
			$('refresh-pedidos').addEventListener('click', loadPedidos);
			$('refresh-leads')?.addEventListener('click', () => loadAdminLeads());
			$('lead-modal-close')?.addEventListener('click', () => $('lead-modal').classList.add('hidden'));
			$('lead-modal')?.addEventListener('click', (event) => {
				if (event.target === $('lead-modal')) $('lead-modal').classList.add('hidden');
			});
			$('save-quote-config').addEventListener('click', saveQuoteConfig);
			$('add-catalog-quote-item').addEventListener('click', addCatalogQuoteItem);
			$('add-manual-quote-item').addEventListener('click', addManualQuoteItem);
			$('new-quote').addEventListener('click', startNewQuote);
			$('clear-quote-items').addEventListener('click', () => {
				quoteItems = [];
				currentQuote = null;
				$('quote-saved-link').innerHTML = '';
				renderQuoteItems();
			});
			$('save-quote').addEventListener('click', saveQuote);
			$('send-quote').addEventListener('click', sendQuote);
			$('refresh-quotes').addEventListener('click', loadQuotesHistory);
			$('quote-client-email').addEventListener('input', (event) => {
				$('quote-email-to').value = event.target.value;
			});
			['quote-catalog-price', 'quote-manual-price'].forEach((id) => {
				$(id).addEventListener('blur', (event) => {
					const value = moneyNumber(event.target.value);
					if (value) event.target.value = clp(value);
				});
			});

			const savedPassword = sessionStorage.getItem('mizoAdminPassword');
			if (savedPassword) {
				$('password').value = savedPassword;
				openAdminSession(savedPassword).catch(() => sessionStorage.removeItem('mizoAdminPassword'));
			}
		</script>
	</body>
</html>
