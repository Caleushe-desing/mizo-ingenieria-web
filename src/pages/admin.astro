				</div>
			</section>
		</main>

		<div id="lead-modal" class="fixed inset-0 z-50 hidden bg-slate-950/70 p-4">
			<div class="mx-auto mt-10 max-h-[85vh] max-w-4xl overflow-hidden rounded-3xl bg-white shadow-2xl">
				<div class="flex items-start justify-between gap-4 border-b border-slate-200 p-5">
					<div>
						<p id="lead-modal-meta" class="text-xs font-black uppercase tracking-[0.2em] text-accent-main"></p>
						<h3 id="lead-modal-title" class="mt-2 text-2xl font-black"></h3>
					</div>
					<button id="lead-modal-close" type="button" class="rounded-full border border-slate-300 px-4 py-2 text-sm font-black text-slate-700">Cerrar</button>
				</div>
				<pre id="lead-modal-body" class="max-h-[65vh] overflow-auto whitespace-pre-wrap bg-slate-950 p-5 text-sm leading-6 text-slate-100"></pre>
			</div>
		</div>

		<script is:inline>
			const fmt = new Intl.NumberFormat('es-CL');
			const clp = (value) => '$' + fmt.format(Number(value) || 0);
			const views = {
				catalogo: 'Catálogo Maestro',
				vitrina: 'Publicar en web',
				proyectos: 'Proyectos web',
				cotizador: 'Cotizador',
				auditoria: 'Auditoría',
				pedidos: 'Pedidos',
				leads: 'Formularios web',
			};
			const IMG_FALLBACK_ONERROR = "if(this.dataset.fallback&&!this.dataset.tried){this.dataset.tried='1';this.referrerPolicy='no-referrer';this.src=this.dataset.fallback}else{this.onerror=null;this.src='/mizo-logo.png';}";
			let adminPassword = '';
			let allItems = [];
			let adminLeads = [];
			let adminConsultas = [];
			let adminFormularios = [];
			let showcaseMap = new Map();
			let showcaseMode = 'all';
			let adminProjects = [];
			let editingProject = null;
			let quoteConfig = null;
			let quoteItems = [];
			let currentQuote = null;
			let editingQuoteNumber = null;
			const TAX_RATE = 0.19;

			function $(id) {
				return document.getElementById(id);
			}

			function escapeHtml(value) {
				return String(value ?? '').replace(/[&<>"']/g, (ch) => ({
					'&': '&amp;',
					'<': '&lt;',
					'>': '&gt;',
					'"': '&quot;',
					"'": '&#39;',
				}[ch]));
			}

			function productImageSrc(item) {
				return item?.image || item?.sourceImage || '/mizo-logo.png';
			}

			function productImageFallback(item) {
				const local = String(item?.image || '');
				const remote = String(item?.sourceImage || '');
				if (local && remote && local !== remote && !/^https?:\/\//i.test(local)) {
					return remote;
				}
				return '/mizo-logo.png';
			}

			function productImageTag(item, alt, className = 'max-h-full max-w-full object-contain') {
				return `<img src="${escapeHtml(productImageSrc(item))}" data-fallback="${escapeHtml(productImageFallback(item))}" alt="${escapeHtml(alt)}" class="${className}" loading="lazy" referrerpolicy="no-referrer" onerror="${IMG_FALLBACK_ONERROR}" />`;
			}

			function moneyNumber(value) {
				return Number(String(value ?? '').replace(/[^\d-]/g, '')) || 0;
			}

			function b64ToBytes(b64) {
				return Uint8Array.from(atob(b64), (c) => c.charCodeAt(0));
			}

			async function decryptData(password) {
				const res = await fetch('/datos-privados.json', { cache: 'no-store' });
				if (!res.ok) throw new Error('No existe datos-privados.json');
				const data = await res.json();
				const enc = new TextEncoder();
				const baseKey = await crypto.subtle.importKey('raw', enc.encode(password), 'PBKDF2', false, ['deriveKey']);
				const key = await crypto.subtle.deriveKey(
					{ name: 'PBKDF2', salt: b64ToBytes(data.salt), iterations: data.iterations, hash: 'SHA-256' },
					baseKey,
					{ name: 'AES-GCM', length: 256 },
					false,
					['decrypt']
				);
				const ptBuf = await crypto.subtle.decrypt(
					{ name: 'AES-GCM', iv: b64ToBytes(data.iv) },
					key,
					b64ToBytes(data.ciphertext)
				);
				return JSON.parse(new TextDecoder().decode(ptBuf));
			}

			function setView(view) {
				Object.keys(views).forEach((name) => {
					$(`view-${name}`).classList.toggle('active', name === view);
				});
				document.querySelectorAll('.admin-nav-btn').forEach((button) => {
					const active = button.dataset.view === view;
					button.classList.toggle('nav-active', active);
					button.classList.toggle('text-slate-600', !active);
					button.classList.toggle('hover:bg-accent-soft', !active);
				});
				$('view-title').textContent = views[view] || views.catalogo;
				if (view === 'auditoria') loadQualityReview();
				if (view === 'pedidos') loadPedidos();
				if (view === 'leads') loadAdminLeads();
				if (view === 'vitrina') renderShowcaseManager();
				if (view === 'proyectos') renderProjectsManager();
				if (view === 'cotizador' && !quoteConfig) bootstrapQuotes();
				location.hash = view === 'catalogo' ? '' : view;
			}

			function renderCatalog(payload) {
				allItems = (Array.isArray(payload.products) ? payload.products : []).map((item) => ({
					...item,
					sourceImage: item.sourceImage || item.source?.image || '',
				}));
				const totalCompra = allItems.reduce((sum, item) => sum + Number(item.basePrice || 0), 0);
				const totalVenta = allItems.reduce((sum, item) => sum + Number(item.sellingPrice || item.basePrice || 0), 0);
				$('catalog-meta').textContent = `${allItems.length} productos · datos al ${payload.generatedAt || 'catálogo cifrado'}`;
				$('catalog-summary').innerHTML = [
					['Productos', allItems.length],
					['Costo total compra', clp(totalCompra)],
					['Total publicado', clp(totalVenta)],
					['Ganancia estimada', clp(totalVenta - totalCompra)],
				].map(([label, value]) => `<article class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm"><p class="text-xs font-black uppercase tracking-wide text-slate-400">${label}</p><p class="mt-2 text-2xl font-black">${value}</p></article>`).join('');
				renderCatalogList(allItems);
				renderQuoteCatalogOptions(allItems);
			}

			function renderCatalogList(items) {
				$('catalog-count').textContent = `${items.length} de ${allItems.length} productos`;
				$('catalog-list').innerHTML = items.slice(0, 120).map((item) => {
					const price = Number(item.sellingPrice || item.basePrice || 0);
					return `<article class="rounded-2xl border border-slate-200 bg-white p-4">
						<div class="flex gap-4">
							<div class="flex h-20 w-20 shrink-0 items-center justify-center rounded-2xl border border-slate-200 bg-slate-50 p-2">
								${productImageTag(item, item.name)}
							</div>
							<div class="min-w-0 flex-1">
								<p class="font-mono text-xs font-black text-accent-main">${escapeHtml(item.sku || item.id || 'SKU')}</p>
								<h4 class="mt-1 line-clamp-2 text-sm font-black">${escapeHtml(item.name)}</h4>
								<p class="mt-1 text-xs font-bold uppercase tracking-wide text-slate-500">${escapeHtml(item.brand || item.store || 'Mizo')}</p>
								<div class="mt-3 flex flex-wrap gap-2 text-xs font-black">
									<span class="rounded-full bg-slate-100 px-3 py-1">Stock ${escapeHtml(item.stock ?? '—')}</span>
									<span class="rounded-full bg-blue-50 px-3 py-1 text-accent-main">${clp(price)}</span>
								</div>
							</div>
						</div>
					</article>`;
				}).join('');
			}

			function filterCatalog() {
				const query = $('catalog-search').value.trim().toLowerCase();
				if (!query) {
					renderCatalogList(allItems);
					return;
				}
				renderCatalogList(allItems.filter((item) => [
					item.id, item.sku, item.name, item.brand, item.store, item.category,
				].some((value) => String(value || '').toLowerCase().includes(query))));
			}

			function showcaseKey(item) {
				return String(item.id || item.sku || '');
			}

			async function loadShowcaseConfig() {
				try {
					const response = await fetch('/api/showcase.php', { headers: { Accept: 'application/json' }, cache: 'no-store' });
					const payload = await response.json();
					showcaseMap = new Map();
					showcaseMode = payload?.mode === 'curated' ? 'curated' : 'all';
					(Array.isArray(payload?.items) ? payload.items : []).forEach((item, index) => {
						const key = String(item.id || item.sku || '');
						if (!key) return;
						showcaseMap.set(key, {
							id: item.id || key,
							sku: item.sku || '',
							sortOrder: Number(item.sortOrder) || index + 1,
							note: item.note || '',
						});
					});
				} catch (error) {
					console.warn('No se pudo cargar vitrina web.', error);
				}
			}

			function renderShowcaseModeUI() {
				const isAll = showcaseMode === 'all';
				const banner = $('showcase-mode-banner');
				const curatedTools = $('showcase-curated-tools');
				const list = $('showcase-list');
				const saveBtn = $('save-showcase');
				const allBtn = $('publish-all-showcase');

				document.querySelectorAll('.showcase-mode-card').forEach((card) => {
					const isAllCard = card.id === 'showcase-mode-all';
					const active = isAll ? isAllCard : !isAllCard;
					card.classList.toggle('border-orange-400', active);
					card.classList.toggle('bg-orange-50', active);
					card.classList.toggle('ring-2', active);
					card.classList.toggle('ring-orange-200', active);
					card.classList.toggle('border-slate-200', !active);
					card.classList.toggle('bg-white', !active);
				});

				if (isAll) {
					banner.className = 'mt-4 rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-semibold text-emerald-800';
					banner.textContent = `Publicado: catálogo completo (${allItems.length} productos visibles en /equipamiento).`;
					banner.classList.remove('hidden');
					curatedTools.classList.add('hidden');
					list.classList.add('hidden');
					saveBtn.classList.add('hidden');
					allBtn.classList.remove('hidden');
				} else {
					const selected = showcaseMap.size;
					banner.className = 'mt-4 rounded-2xl border border-orange-200 bg-orange-50 px-4 py-3 text-sm font-semibold text-orange-900';
					banner.textContent = selected
						? `Modo activo: selección manual. ${selected} producto(s) marcado(s). Pulsa "Guardar selección" para aplicar en /equipamiento.`
						: 'Modo activo: selección manual. Marca los productos con ☑ y luego pulsa "Guardar selección".';
					banner.classList.remove('hidden');
					curatedTools.classList.remove('hidden');
					list.classList.remove('hidden');
					saveBtn.classList.remove('hidden');
					allBtn.classList.add('hidden');
				}
			}

			function switchShowcaseMode(mode) {
				showcaseMode = mode === 'curated' ? 'curated' : 'all';
				renderShowcaseModeUI();
				renderShowcaseManager();
			}

			function renderShowcaseManager() {
				renderShowcaseModeUI();
				if (showcaseMode === 'all') {
					$('showcase-status').textContent = `${allItems.length} productos visibles en /equipamiento (catálogo completo)`;
					return;
				}

				const query = ($('showcase-search')?.value || '').trim().toLowerCase();
				const items = allItems.filter((item) => {
					if (!query) return true;
					return [item.id, item.sku, item.name, item.brand, item.store, item.category]
						.some((value) => String(value || '').toLowerCase().includes(query));
				});
				$('showcase-status').textContent = `${showcaseMap.size} seleccionado(s) · ${items.length} resultados en catálogo`;
				$('showcase-list').innerHTML = items.slice(0, 120).map((item) => {
					const key = showcaseKey(item);
					const active = showcaseMap.has(key);
					const entry = showcaseMap.get(key) || { sortOrder: showcaseMap.size + 1, note: '' };
					return `<article class="rounded-2xl border ${active ? 'border-orange-300 bg-orange-50/40' : 'border-slate-200 bg-white'} p-4">
						<div class="flex gap-4">
							<label class="flex shrink-0 items-start gap-2 pt-1" title="Mostrar en /equipamiento">
								<input type="checkbox" class="showcase-toggle mt-0.5 h-5 w-5 rounded border-slate-300" data-key="${escapeHtml(key)}" ${active ? 'checked' : ''} />
								<span class="text-[0.65rem] font-black uppercase tracking-wide text-orange-700">Web</span>
							</label>
							<div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-xl border border-slate-200 bg-slate-50 p-1.5">
								${productImageTag(item, item.name, 'max-h-full max-w-full object-contain')}
							</div>
							<div class="min-w-0 flex-1">
								<p class="font-mono text-xs font-black text-accent-main">${escapeHtml(item.sku || item.id || 'SKU')}</p>
								<h4 class="mt-1 line-clamp-2 text-sm font-black">${escapeHtml(item.name)}</h4>
								<p class="mt-1 text-xs font-bold uppercase tracking-wide text-slate-500">${escapeHtml(item.brand || 'Mizo')}</p>
								<div class="mt-3 grid gap-2 sm:grid-cols-[90px_minmax(0,1fr)]">
									<input type="number" min="1" value="${escapeHtml(entry.sortOrder || 1)}" data-showcase-order="${escapeHtml(key)}" class="rounded-xl border border-slate-300 px-3 py-2 text-sm ${active ? '' : 'opacity-50'}" ${active ? '' : 'disabled'} placeholder="Orden" />
									<input type="text" value="${escapeHtml(entry.note || '')}" data-showcase-note="${escapeHtml(key)}" class="rounded-xl border border-slate-300 px-3 py-2 text-sm ${active ? '' : 'opacity-50'}" ${active ? '' : 'disabled'} placeholder="Nota editorial (opcional)" />
								</div>
							</div>
						</div>
					</article>`;
				}).join('');

				document.querySelectorAll('.showcase-toggle').forEach((input) => {
					input.addEventListener('change', () => {
						const key = input.getAttribute('data-key') || '';
						if (!key) return;
						if (showcaseMode === 'all') switchShowcaseMode('curated');
						if (input.checked) {
							const item = allItems.find((entry) => showcaseKey(entry) === key);
							showcaseMap.set(key, {
								id: item?.id || key,
								sku: item?.sku || '',
								sortOrder: showcaseMap.size + 1,
								note: '',
							});
						} else {
							showcaseMap.delete(key);
						}
						renderShowcaseManager();
					});
				});

				document.querySelectorAll('[data-showcase-order]').forEach((input) => {
					input.addEventListener('input', () => {
						const key = input.getAttribute('data-showcase-order') || '';
						const entry = showcaseMap.get(key);
						if (!entry) return;
						entry.sortOrder = Number(input.value) || 1;
						showcaseMap.set(key, entry);
					});
				});

				document.querySelectorAll('[data-showcase-note]').forEach((input) => {
					input.addEventListener('input', () => {
						const key = input.getAttribute('data-showcase-note') || '';
						const entry = showcaseMap.get(key);
						if (!entry) return;
						entry.note = input.value.trim();
						showcaseMap.set(key, entry);
					});
				});
			}

			async function saveShowcase() {
				const items = Array.from(showcaseMap.values()).sort((a, b) => (Number(a.sortOrder) || 0) - (Number(b.sortOrder) || 0));
				$('showcase-status').textContent = 'Guardando vitrina web...';
				try {
					const response = await fetch('/api/showcase.php', {
						method: 'POST',
						headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
						body: JSON.stringify({ password: adminPassword, mode: 'curated', items }),
					});
					const payload = await response.json();
					if (!response.ok || !payload?.ok) throw new Error(payload?.error || 'No se pudo guardar la vitrina.');
					showcaseMode = 'curated';
					await loadShowcaseConfig();
					renderShowcaseManager();
					$('showcase-status').textContent = `Selección guardada: ${payload.count || items.length} producto(s) visibles en /equipamiento.`;
				} catch (error) {
					$('showcase-status').textContent = error.message || 'Error al guardar vitrina.';
				}
			}

			async function publishAllShowcase() {
				$('showcase-status').textContent = 'Publicando catálogo completo...';
				try {
					const response = await fetch('/api/showcase.php', {
						method: 'POST',
						headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
						body: JSON.stringify({ password: adminPassword, mode: 'all' }),
					});
					const payload = await response.json();
					if (!response.ok || !payload?.ok) throw new Error(payload?.error || 'No se pudo publicar el catálogo completo.');
					showcaseMode = 'all';
					showcaseMap = new Map();
					await loadShowcaseConfig();
					renderShowcaseManager();
					$('showcase-status').textContent = `Catálogo completo publicado: ${payload.count || 0} producto(s) en /equipamiento.`;
				} catch (error) {
					$('showcase-status').textContent = error.message || 'Error al publicar catálogo completo.';
				}
			}

			function projectImages(project) {
				const images = Array.isArray(project?.images) ? project.images.filter(Boolean) : [];
				if (images.length) return images;
				if (project?.image) return [project.image];
				return [];
			}

			function draftProjectId() {
				return 'borrador-' + Date.now().toString(36);
			}

			function getEditingProjectImages() {
				return projectImages(editingProject);
			}

			async function loadAdminProjects() {
				const response = await fetch('/api/proyectos.php', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
					body: JSON.stringify({ password: adminPassword, action: 'list' }),
				});
				const payload = await response.json();
				if (!response.ok || !payload?.ok) throw new Error(payload?.error || 'No se pudieron cargar los proyectos.');
				adminProjects = Array.isArray(payload.projects) ? payload.projects : [];
				return payload;
			}

			function renderProjectImagesEditor() {
				const container = $('proyecto-images');
				if (!container) return;
				const images = getEditingProjectImages();
				if (!images.length) {
					container.innerHTML = '<p class="col-span-full rounded-xl border border-dashed border-slate-300 bg-white p-4 text-sm text-slate-500">Aún no hay imágenes. Sube una o más fotos del proyecto.</p>';
					return;
				}
				container.innerHTML = images.map((src) => `
					<div class="overflow-hidden rounded-2xl border border-slate-200 bg-white">
						<div class="flex h-28 items-center justify-center bg-slate-50 p-2">
							<img src="${escapeHtml(src)}" alt="" class="max-h-full max-w-full object-contain" loading="lazy" />
						</div>
						<div class="flex items-center justify-between gap-2 border-t border-slate-100 p-2">
							<p class="truncate text-[0.65rem] font-semibold text-slate-500">${escapeHtml(src)}</p>
							<button type="button" class="proyecto-remove-image rounded-full border border-red-200 px-2 py-1 text-[0.65rem] font-black text-red-700 hover:bg-red-50" data-image="${escapeHtml(src)}">Quitar</button>
						</div>
					</div>
				`).join('');

				container.querySelectorAll('.proyecto-remove-image').forEach((button) => {
					button.addEventListener('click', async () => {
						const image = button.getAttribute('data-image') || '';
						if (!image || !editingProject) return;
						if (!editingProject.id || String(editingProject.id).startsWith('borrador-')) {
							editingProject.images = getEditingProjectImages().filter((item) => item !== image);
							renderProjectImagesEditor();
							return;
						}
						try {
							$('proyecto-upload-status').textContent = 'Eliminando imagen...';
							const response = await fetch('/api/proyectos.php', {
								method: 'POST',
								headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
								body: JSON.stringify({
									password: adminPassword,
									action: 'remove_image',
									id: editingProject.id,
									image,
								}),
							});
							const payload = await response.json();
							if (!response.ok || !payload?.ok) throw new Error(payload?.error || 'No se pudo eliminar la imagen.');
							editingProject = payload.project || editingProject;
							await loadAdminProjects();
							const refreshed = adminProjects.find((item) => item.id === editingProject.id);
							if (refreshed) editingProject = refreshed;
							renderProjectImagesEditor();
							renderProjectsManager(false);
							$('proyecto-upload-status').textContent = 'Imagen eliminada.';
						} catch (error) {
							$('proyecto-upload-status').textContent = error.message || 'Error al eliminar imagen.';
						}
					});
				});
			}

			function openProjectEditor(project = null) {
				editingProject = project ? { ...project, images: projectImages(project) } : {
					id: draftProjectId(),
					title: '',
					type: '',
					description: '',
					images: [],
					sortOrder: adminProjects.length + 1,
					published: true,
				};

				$('proyecto-editor').classList.remove('hidden');
				$('proyecto-editor-title').textContent = project?.id ? 'Editar proyecto' : 'Nuevo proyecto';
				$('proyecto-id').value = editingProject.id || '';
				$('proyecto-title').value = editingProject.title || '';
				$('proyecto-type').value = editingProject.type || '';
				$('proyecto-description').value = editingProject.description || '';
				$('proyecto-published').checked = editingProject.published !== false;
				$('proyecto-sort').value = String(editingProject.sortOrder || adminProjects.length + 1);
				$('proyecto-delete').classList.toggle('hidden', !project?.id || String(project.id).startsWith('borrador-'));
				$('proyecto-upload-status').textContent = '';
				renderProjectImagesEditor();
				$('proyecto-editor').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
			}

			function closeProjectEditor() {
				editingProject = null;
				$('proyecto-editor').classList.add('hidden');
				$('proyecto-image-input').value = '';
				$('proyecto-upload-status').textContent = '';
			}

			async function uploadProjectImages(files) {
				if (!editingProject || !files?.length) return;
				let projectId = editingProject.id || draftProjectId();
				if (String(projectId).startsWith('borrador-')) {
					const title = $('proyecto-title').value.trim();
					if (!title) {
						$('proyecto-upload-status').textContent = 'Escribe primero el nombre del proyecto.';
						return;
					}
					$('proyecto-upload-status').textContent = 'Guardando borrador antes de subir imágenes...';
					await saveCurrentProject({ silent: true });
					projectId = editingProject.id;
				}

				for (const file of files) {
					const formData = new FormData();
					formData.append('password', adminPassword);
					formData.append('action', 'upload');
					formData.append('projectId', projectId);
					formData.append('image', file);
					$('proyecto-upload-status').textContent = `Subiendo ${file.name}...`;
					const response = await fetch('/api/proyectos.php', { method: 'POST', body: formData });
					const payload = await response.json();
					if (!response.ok || !payload?.ok) throw new Error(payload?.error || `No se pudo subir ${file.name}.`);
					if (payload.project) {
						editingProject = payload.project;
					} else {
						if (!editingProject.images) editingProject.images = [];
						if (!editingProject.images.includes(payload.image)) {
							editingProject.images.push(payload.image);
						}
					}
				}

				await loadAdminProjects();
				const currentId = editingProject?.id || projectId;
				const refreshed = adminProjects.find((item) => item.id === currentId);
				if (refreshed) {
					editingProject = {
						...refreshed,
						images: Array.from(new Set([...(refreshed.images || []), ...(editingProject?.images || [])])),
					};
				}
				$('proyecto-id').value = editingProject?.id || '';
				renderProjectImagesEditor();
				renderProjectsManager(false);
				$('proyecto-upload-status').textContent = 'Imágenes subidas correctamente.';
				$('proyecto-image-input').value = '';
			}

			async function saveCurrentProject(options = {}) {
				const project = {
					id: $('proyecto-id').value.trim() || undefined,
					title: $('proyecto-title').value.trim(),
					type: $('proyecto-type').value.trim(),
					description: $('proyecto-description').value.trim(),
					sortOrder: Number($('proyecto-sort').value) || 1,
					published: $('proyecto-published').checked,
					images: getEditingProjectImages(),
				};
				if (!project.title) throw new Error('El proyecto debe tener un nombre.');

				if (!options.silent) $('proyectos-status').textContent = 'Guardando proyecto...';
				const response = await fetch('/api/proyectos.php', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
					body: JSON.stringify({ password: adminPassword, action: 'save', project }),
				});
				const payload = await response.json();
				if (!response.ok || !payload?.ok) throw new Error(payload?.error || 'No se pudo guardar el proyecto.');
				editingProject = payload.project || project;
				$('proyecto-id').value = editingProject.id || '';
				$('proyecto-delete').classList.remove('hidden');
				renderProjectImagesEditor();
				await loadAdminProjects();
				renderProjectsManager(false);
				if (!options.silent) {
					$('proyectos-status').textContent = `Proyecto guardado. ${adminProjects.length} proyecto(s) en total.`;
				}
				return payload;
			}

			async function deleteCurrentProject() {
				const id = $('proyecto-id').value.trim();
				if (!id || String(id).startsWith('borrador-')) {
					closeProjectEditor();
					return;
				}
				if (!confirm('¿Eliminar este proyecto y sus imágenes del servidor?')) return;
				$('proyectos-status').textContent = 'Eliminando proyecto...';
				const response = await fetch('/api/proyectos.php', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
					body: JSON.stringify({ password: adminPassword, action: 'delete', id }),
				});
				const payload = await response.json();
				if (!response.ok || !payload?.ok) throw new Error(payload?.error || 'No se pudo eliminar el proyecto.');
				closeProjectEditor();
				await loadAdminProjects();
				renderProjectsManager();
				$('proyectos-status').textContent = `Proyecto eliminado. Quedan ${adminProjects.length} proyecto(s).`;
			}

			async function renderProjectsManager(reload = true) {
				const list = $('proyectos-list');
				if (!list) return;
				try {
					if (reload) {
						$('proyectos-status').textContent = 'Cargando proyectos...';
						await loadAdminProjects();
					}
					const publishedCount = adminProjects.filter((item) => item.published !== false).length;
					$('proyectos-status').textContent = `${adminProjects.length} proyecto(s) · ${publishedCount} publicado(s) en la portada`;

					if (!adminProjects.length) {
						list.innerHTML = '<p class="rounded-2xl border border-dashed border-slate-300 bg-slate-50 p-5 text-sm text-slate-500">Todavía no hay proyectos. Crea el primero con el botón de arriba.</p>';
						return;
					}

					list.innerHTML = adminProjects.map((project) => {
						const images = projectImages(project);
						const cover = images[0] || '';
						const thumb = cover
							? `<img src="${escapeHtml(cover)}" alt="" class="h-full w-full object-cover" loading="lazy" />`
							: '<div class="flex h-full w-full items-center justify-center bg-slate-200 text-[0.6rem] font-bold uppercase tracking-wide text-slate-500">Sin foto</div>';
						return `<article class="rounded-2xl border border-slate-200 bg-white p-4">
							<div class="flex gap-4">
								<div class="flex h-20 w-20 shrink-0 items-center justify-center overflow-hidden rounded-2xl border border-slate-200 bg-slate-50">
									${thumb}
								</div>
								<div class="min-w-0 flex-1">
									<div class="flex flex-wrap items-center gap-2">
										<p class="text-xs font-black uppercase tracking-wide text-brand-orange">${escapeHtml(project.type || 'Proyecto')}</p>
										<span class="rounded-full px-2 py-0.5 text-[0.65rem] font-black ${project.published === false ? 'bg-slate-100 text-slate-500' : 'bg-green-100 text-green-700'}">${project.published === false ? 'Oculto' : 'Publicado'}</span>
										<span class="rounded-full bg-slate-100 px-2 py-0.5 text-[0.65rem] font-black text-slate-500">${images.length} foto(s)</span>
									</div>
									<h4 class="mt-1 line-clamp-2 text-sm font-black">${escapeHtml(project.title)}</h4>
									<p class="mt-1 line-clamp-2 text-xs leading-relaxed text-slate-500">${escapeHtml(project.description || '')}</p>
									<button type="button" class="proyecto-edit mt-3 rounded-full border border-slate-300 px-4 py-2 text-xs font-black text-slate-700 hover:bg-slate-50" data-id="${escapeHtml(project.id)}">Editar</button>
								</div>
							</div>
						</article>`;
					}).join('');

					list.querySelectorAll('.proyecto-edit').forEach((button) => {
						button.addEventListener('click', () => {
							const id = button.getAttribute('data-id') || '';
							const project = adminProjects.find((item) => item.id === id);
							if (project) openProjectEditor(project);
						});
					});
				} catch (error) {
					$('proyectos-status').textContent = error.message || 'Error al cargar proyectos.';
					list.innerHTML = '';
				}
			}

			async function apiQuotes(action, payload = {}) {
				const response = await fetch('/api/quotes.php', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
					cache: 'no-store',
					body: JSON.stringify({ action, password: adminPassword, ...payload }),
				});
				const data = await response.json();
				if (!response.ok || !data?.ok) throw new Error(data?.error || 'No se pudo operar con cotizaciones.');
				return data;
			}

			function quoteMessage(text, type = 'info') {
				const el = $('quote-message');
				el.textContent = text;
				el.className = 'mt-3 text-sm font-semibold ' + (type === 'error' ? 'text-red-600' : type === 'success' ? 'text-green-700' : 'text-slate-500');
			}

			function quoteCompanyFromForm() {
				return {
					companyName: $('quote-company-name').value.trim(),
					taxId: $('quote-company-tax-id').value.trim(),
					phone: $('quote-company-phone').value.trim(),
					email: $('quote-company-email').value.trim(),
					address: $('quote-company-address').value.trim(),
					website: $('quote-company-website').value.trim(),
					logo: $('quote-company-logo').value.trim(),
				};
			}

			function fillQuoteCompanyForm(config) {
				quoteConfig = config || {};
				$('quote-company-name').value = 'Mizo Estilo y Color';
				$('quote-company-tax-id').value = '77.589.163-7';
				$('quote-company-phone').value = '+56 99 4390870';
				$('quote-company-email').value = 'ventas@mizo.cl';
				$('quote-company-address').value = '';
				$('quote-company-website').value = 'www.mizo.cl';
				$('quote-company-logo').value = quoteConfig.logo || '/mizo-logo.png';
				$('quote-conditions').value = (quoteConfig.defaultConditions || [
					'Vigencia de la cotización: 5 días.',
